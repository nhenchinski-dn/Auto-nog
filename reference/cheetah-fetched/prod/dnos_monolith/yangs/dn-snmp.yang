  // typedef statements

  typedef view-name {
    type identifier;
    description
      "The view-name type represents an SNMP VACM view name.";
  }

  typedef version {
    type enumeration {
      enum 1 {
        description
          "Version 1";
      }
      enum 2c {
        description
          "Version 2c";
      }
      enum 3 {
        description
          "Version 3";
      }
    }
  }

  typedef oid {
    type string {
      pattern '[12](\.\d+)*';
    }
    description
      "A type defining how OID should look like.";
  }

  typedef admin-state {
    type enumeration {
      enum enabled;
      enum disabled;
    }
  }

  // grouping statements

  grouping trap-server-config {
    description
      "Configuration items for snmp trap server";
    leaf trap-server-ip {
      type inet:ip-address;
      mandatory true;
      description
        "The IPv4/IPv6 address on which the snmp server listens.";
    }
    leaf vrf {
      type leafref {
        path "/dn-top:drivenets-top/dn-network-services:network-services/dn-vrf:vrfs/dn-vrf:vrf/dn-vrf:vrf-name";
      }
      default "default";
      description
        "The vrf name related to the trap server network.";
      must "('mgmt-ncc-0' or 'mgmt-ncc-1') != current()" {
        error-message "vrf name shall be default, mgmt0 or any user defined VRF.";
      }
    }
    leaf community-name {
      type string;
      mandatory true;
      description
        "A community name that can be represented as a
         YANG string.";
    }
    leaf version {
      description
        "SNMP version used by the engine.";
      type version;
      default "2c";
    }
    leaf port {
      type inet:port-number;
      description
        "The UDP port on which the engine listens.
         If the port is not configured, an engine that
         acts as a Command Responder uses port 161, and
         an engine that acts as a Notification Receiver
         uses port 162.";
      default "162";
    }
    leaf max-throughput {
      type uint16 {
        range "1..1000";
      }
      description
        "Maximum numbers of traps that can be sent to
         the server in one second. If there is a larger
         number of traps generated then everything above
         the value of the throughput will be discarded";
      default "100";
    }
    leaf source-interface {
      type dn-if:base-interface-ref;
      when "(/dn-top:drivenets-top/dn-if:interfaces/dn-if:interface/dn-if:config-items/dn-if:type = 'ianaift:ethernetCsmacd' or
            /dn-top:drivenets-top/dn-if:interfaces/dn-if:interface/dn-if:config-items/dn-if:type = 'ianaift:softwareLoopback' or
            /dn-top:drivenets-top/dn-if:interfaces/dn-if:interface/dn-if:config-items/dn-if:type = 'ianaift:l2vlan' or
            /dn-top:drivenets-top/dn-if:interfaces/dn-if:interface/dn-if:config-items/dn-if:type = 'ianaift:ieee8023adLag')" {
        description
          "target interface must be physical, loopback, bundle or vlan";
      }
      description
        "The name of the source-interface for snmp.";
    }
    leaf trap-source-port {
      description
        "Outgoing traps source port";
      type inet:port-number {
        range "1024..65535";
      }
    }
    leaf admin-state {
      type admin-state;
      description
        "admin-state of SNMP trap-server";
      default "enabled";
    }
    leaf notification-method {
      type enumeration {
        enum trap;
        enum inform;
      }
      default "trap";
    }
    leaf retries {
      type uint8 {
        range "1..5";
      }
      default "3";
      when "../notification-method = 'inform'";
      description
        "Set the number of retries";
    }
    leaf timeout {
      type uint8 {
        range "1..60";
      }
      units "seconds";
      default "10";
      when "../notification-method = 'inform'";
      description
        "Set the timeout";
    }
    leaf hold-down {
      type uint16 {
        range "0 | 60..1200";
      }
      units "seconds";
      default "300";
      when "../notification-method = 'inform'";
      description
        "Set the hold-down period when know acknowledgements are received for 20 consecutive inform messages";
    }
  }

  // data definition statements

  grouping trap-server-top {
    description
      "top-level snmp trap server config and state containers";
    container trap-servers {
      description
        "Configuration of the SNMP engine (trap server).";
      container oper-items {
        config false;
        description
          "State variables for snmp trap server";
        leaf engine-id {
          type dn-snmp:engine-id;
          description
            "The local SNMP engine's administratively assigned unique
             identifier.
             If this leaf is not set, the device automatically
             calculates an engine ID, as described in RFC 3411.  A
             server MAY initialize this leaf with the automatically
             created value.";
          reference
            "RFC 3411: An Architecture for Describing Simple Network
             Management Protocol (SNMP) Management
             Frameworks.
             SNMP-FRAMEWORK-MIB.snmpEngineID";
        }
      }
      list trap-server {
        key "trap-server-ip vrf";
        max-elements 5;
        description
          "Configuration of the transport endpoints on which the
           engine (trap server) listens.";
        leaf trap-server-ip {
          type leafref {
            path "../config-items/trap-server-ip";
          }
          description
            "The IPv4 address on which the engine listens.";
        }
        leaf vrf {
          type leafref {
            path "../config-items/vrf";
          }
          description
            "The vrf name related to the trap server network.";
        }
        container config-items {
          description
            "Configuration data for snmp trap server";
          uses trap-server-config;
        }
        container oper-items {
          config false;
          description
            "State variables for snmp trap server";
          uses trap-server-config;
          leaf hold-down-remaining {
            description
              "Counts the remaining seconds till the exceeding of the hold-down timer";
            type uint32;
            dn-ex:countdown;
            units "seconds";
          }
        }
        uses dn-group:apply-group;
      }
    }
  }

  grouping secret {
    leaf secret {
      type string;
      mandatory true;
      nacm:default-deny-all;
      description
        "Localized secret specified as a list of colon-specified
         hexadecimal octets.";
    }
  }

  grouping user-list {
    leaf user-name {
      type identifier;
      reference
        "RFC 3414: User-based Security Model (USM) for version 3
         of the Simple Network Management Protocol (SNMPv3).
         SNMP-USER-BASED-SM-MIB.usmUserName";
    }
    leaf view-name {
      type view-name;
      description
        "The name of this VACM MIB view.";
      reference
        "RFC 3415: View-based Access Control Model (VACM) for
         the Simple Network Management Protocol (SNMP).
         SNMP-VIEW-BASED-ACM-MIB.vacmViewTreeFamilyName";
      default "viewdefault";
    }
    container authentication {
      presence "enables authentication";
      description
        "Enables authentication of the user.";
      uses secret;
      leaf type {
        mandatory true;
        reference
          "RFC 3414: User-based Security Model (USM) for version 3
           of the Simple Network Management Protocol (SNMPv3).
           SNMP-USER-BASED-SM-MIB.usmUserAuthProtocol
           SNMP-USER-BASED-SM-MIB.usmHMACMD5AuthProtocol
           SNMP-USER-BASED-SM-MIB.usmHMACSHAAuthProtocol";
        type enumeration {
          enum md5;
          enum sha;
        }
      }
    }
    container encryption {
      must '../authentication' {
        error-message "when privacy (confidentiality) is used, "
                    + "authentication must also be used";
      }
      presence "enables encryption";
      uses secret;
      leaf type {
        reference
          "RFC 3414: User-based Security Model (USM) for version 3
           of the Simple Network Management Protocol (SNMPv3).
           SNMP-USER-BASED-SM-MIB.usmUserAuthProtocol
           SNMP-USM-AES-MIB.usmAesCfb128Protocol
           SNMP-USER-BASED-SM-MIB.usmDESPrivProtocol";
        type enumeration {
          enum aes;
          enum des;
        }
      }
    }
  }

  grouping trap-list {
    leaf trap-name {
      type identityref {
        base trap-name;
      }
      description
        "trap name (has unique OID)";
    }
    leaf trap-type {
      type identityref {
        base trap-type;
      }
      description
        "trap type family";
    }
    leaf enabled {
      type boolean;
      default "true";
      description
        "Enables the SNMP trap mib.";
    }
  }

  grouping mib-list {
    leaf view-name {
      type view-name;
      description
        "view name";
    }
    leaf-list included {
      type oid;
      description
        "mib included from this filter.";
    }
    leaf-list excluded {
      type oid;
      description
        "mib excluded from this filter.";
    }
  }

  grouping community-list {
    leaf index {
      type identifier;
      description
        "Index into the community list.";
      reference
        "RFC 3584: Coexistence between Version 1, Version 2,
         and Version 3 of the Internet-standard
         Network Management Framework.
         SNMP-COMMUNITY-MIB.snmpCommunityIndex";
    }
    leaf vrf {
      type leafref {
        path "/dn-top:drivenets-top/dn-network-services:network-services/dn-vrf:vrfs/dn-vrf:vrf/dn-vrf:vrf-name";
      }
      default "default";
      description
        "The name of the vrf.";
      must "('mgmt-ncc-0' or 'mgmt-ncc-1') != current()" {
        error-message "vrf name shall be default, mgmt0 or any user defined VRF.";
      }
    }
    choice name {
      nacm:default-deny-all;
      description
        "The community name, specified as either a string or
         a binary value.  The binary name is used when the
         community name contains characters that are not legal
         in a string.
         If not set, the value of 'security-name' is operationally
         used as the snmpCommunityName.";
      reference
        "RFC 3584: Coexistence between Version 1, Version 2,
         and Version 3 of the Internet-standard
         Network Management Framework.
         SNMP-COMMUNITY-MIB.snmpCommunityName";
      leaf text-name {
        type string;
        description
          "A community name that can be represented as a
           YANG string.";
      }
      leaf binary-name {
        type binary;
        description
          "A community name represented as a binary value.";
      }
    }
    leaf view {
      type view-name;
      description
        "The name of snmp community view.";
      default "viewdefault";
    }
    leaf access {
      type identityref {
        base access;
      }
      description
        "access type community view";
      default "read-only";
    }
    leaf-list client-list {
      type inet:ip-prefix;
      description
        "White list of snmp community authorized clients";
    }
    leaf admin-state {
      type admin-state;
      description
        "Community admin-state of SNMP server";
      default "enabled";
    }
  }

  grouping community-top {
    description
      "top-level community config and state containers";
    container communities {
      description
        "top-level community config and state containers.";
      list community {
        key "index vrf";
        max-elements 10;
        description
          "List of communities per vrf.";
        reference
          "RFC 3584: Coexistence between Version 1, Version 2,
           and Version 3 of the Internet-standard
           Network Management Framework.
           SNMP-COMMUNITY-MIB.snmpCommunityTable";
        leaf index {
          type leafref {
            path "../config-items/index";
          }
          description
            "Index into the community list";
        }
        leaf vrf {
          type leafref {
            path "../config-items/vrf";
          }
          description
            "The vrf name related to the trap server network.";
        }
        container config-items {
          description
            "Configuration data for community";
          uses community-list;
        }
        container oper-items {
          config false;
          description
            "State variables for community";
          uses community-list;
        }
        uses dn-group:apply-group;
      }
    }
  }

  grouping trap-top {
    description
      "top-level trap config and state containers";
    container traps {
      description
        "top-level trap config and state containers.";
      list trap {
        key "trap-name";
        description
          "system snmp trap list";
        leaf trap-name {
          type leafref {
            path "../config-items/trap-name";
          }
          description
            "trap name (unique name)";
        }
        container config-items {
          description
            "Configuration data for trap mibs";
          uses trap-list;
        }
        container oper-items {
          config false;
          description
            "State variables for trap mib";
          uses trap-list;
        }
      }
    }
  }

  grouping view-top {
    description
      "top-level system snmp view config and state containers";
    container views {
      description
        "top-level system snmp view config and state containers.";
      list view {
        key "view-name";
        description
          "system snmp view list";
        leaf view-name {
          type leafref {
            path "../config-items/view-name";
          }
          description
            "view name (unique name)";
        }
        container config-items {
          description
            "Configuration data for view oids";
          uses mib-list;
        }
        container oper-items {
          config false;
          description
            "State variables for view oids";
          uses mib-list;
        }
        uses dn-group:apply-group;
      }
    }
  }

  grouping usm-top {
    description
      "top-level usm config and state containers";
    container usm {
      description
        "Configuration of the User-based Security Model.";
      container local {
        list user {
          key "user-name";
          reference
            "RFC 3414: User-based Security Model (USM) for version 3
             of the Simple Network Management Protocol (SNMPv3).
             SNMP-USER-BASED-SM-MIB.usmUserTable";
          leaf user-name {
            type leafref {
              path "../config-items/user-name";
            }
            description
              "The IPv4 or IPv6 address on which the engine
               listens.";
          }
          container config-items {
            description
              "Configuration data for snmp server";
            uses user-list;
          }
          container oper-items {
            config false;
            description
              "State variables for snmp server";
            uses user-list;
          }
          uses dn-group:apply-group;
        }
      }
    }
  }

  grouping snmp-global {
    description
      "Global configuration data for snmp";
    leaf class-of-service {
      description
        "dscp marking for class-of-service configuration";
      type inet:dscp {
        range "0..56";
      }
      default "16";
    }
    leaf max-packet-size {
      description
        "Maximal size in bytes of SNMP packet that the router can send, including IP and UDP headers.";
      type uint16 {
        range "512..9300";
      }
      default "1500";
    }
    container compatibility-mode {
      leaf cisco {
        description
          "SNMP Cisco compatibility-mode";
        type enumeration {
          enum enabled;
          enum disabled;
        }
        default "enabled";
      }
    }
  }

  grouping snmp-counters {
    description
      "SNMP statistics";
    leaf in-get-pdus {
      type yang:zero-based-counter32;
      description
        "Number of GetRequest PDUs received by the SNMP agent";
    }
    leaf in-getnext-pdus {
      type yang:zero-based-counter32;
      description
        "Number of GetNextRequest PDUs received by the SNMP agent";
    }
    leaf in-getbulk-pdus {
      type yang:zero-based-counter32;
      description
        "Number of GetBulkRequest PDUs received by the SNMP agent";
    }
    leaf out-response-pdus {
      type yang:zero-based-counter32;
      description
        "Number of Response PDUs sent by the SNMP agent";
    }
    leaf out-trap-pdus {
      type yang:zero-based-counter32;
      description
        "Number of Response PDUs sent by the SNMP agent";
    }
  }

  grouping snmp-global-top {
    description
      "top-level global snmp config and state containers";
    container config-items {
      description
        "Global configuration data for snmp";
      uses snmp-global;
    }
    container oper-items {
      config false;
      description
        "Global state variables for snmp";
      uses snmp-global;
      uses snmp-counters;
    }
  }

  grouping snmp-top {
    description
      "top-level snmp config and state containers";
    container snmp {
      description
        "Enclosing container for snmp config and state containers associated with the system";
      uses snmp-global-top;
      uses community-top;
      uses trap-server-top;
      uses usm-top;
      uses trap-top;
      uses view-top;
    }
  }

  // augment statements

  augment "/dn-top:drivenets-top/dn-sys:system" {
    description
      "Adds SNMP configuration to top system model";
    uses snmp-top;
  }
}
