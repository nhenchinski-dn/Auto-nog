  organization
    "DRIVENETS LTD";
  contact
    "DRIVENETS Customer Service <mailto:support@drivenets.com>";
  description
    "Model for managing SNMP configuration -- augments the DN system YANG";

  revision 2025-10-08 {
    description
      "Added dnCfmProactiveTestFailure trap";
  }
  revision 2025-09-16 {
    description
      "Added inform notification method";
  }
  revision 2025-08-27 {
    description
      "Added LACP State Change trap";
  }
  revision 2025-06-18 {
    description
      "Added CFM traps";
  }
  revision 2025-05-03 {
    description
      "Added apply-groups statement";
  }
  revision 2024-09-13 {
    description
      "Add OSPF traps";
  }
  revision 2024-09-11 {
    description
      "Add SR-TE traps support";
  }
  revision 2023-06-12 {
    description
      "Use leafs for snmp user authentication";
  }
  revision 2023-04-04 {
    description
      "Increased maximum number of communities from 5 to 10";
  }
  revision 2023-01-12 {
    description
      "Add max-throughput support for snmp-trap servers";
  }
  revision 2022-12-12 {
    description
      "Added support for compatibility mode with Cisco for IP address format";
  }
  revision 2022-12-01 {
    description
      "Interface utilization threshold exceed and clear traps ";
  }
  revision 2022-04-12 {
    description
      "Changed the authentication 'key' name to 'secret' ";
  }
  revision 2021-10-24 {
    description
      "Add transceiver RX power alarm and warning CLEAR";
  }
  revision 2021-05-03 {
    description
      "Add in-band management VRF support";
  }
  revision 2021-01-17 {
    description
      "Add IPv6 Support";
  }
  revision 2020-11-05 {
    description
      "Update oid string pattern, Adding ha-manager trap type";
  }
  revision 2020-10-15 {
    description
      "Added DRIVENETS-FRU-MIB and DRIVENETS-HWMON-MIB traps";
  }
  revision 2020-07-09 {
    description
      "Adding VRF support";
  }
  revision 2020-06-22 {
    description
      "Added SNMP maximal packet size";
  }
  revision 2020-05-14 {
    description
      "Adding trap source port";
  }
  revision 2020-03-04 {
    description
      "Added leafs for SNMP counters values";
  }
  revision 2019-12-22 {
    description
      "Update view list configuration";
  }
  revision 2019-02-06 {
    description
      "Add cos and source-interface configuration";
  }
  revision 2018-09-26 {
    description
      "Update snmp-server to mandatory, change to trap-servers";
  }
  revision 2017-10-03 {
    description
      "Initial revision";
    reference
      "RFC 7407: A YANG Data Model for SNMP Configuration";
