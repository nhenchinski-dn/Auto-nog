              "The interval between subsequent probes in the test.";
            type uint8 {
              range "1..255";
            }
            units "seconds";
            default "1";
          }
          leaf repeat-interval {
            description
              "The interval between subsequent tests.";
            type uint32 {
              range "1..4294967295";
            }
            units "seconds";
            default "60";
          }
        }
      }
      case time-frame {
        description
          "Test duration is time in minutes (number of probes is derived from the probe-interval).";
        container test-duration-minutes {
          leaf duration {
            description
              "The duration of the test in minutes.";
            type uint32 {
              range "1..4294967295";
            }
            units "minutes";
            default "1";
          }
          leaf probe-interval {
            description
              "The interval between subsequent probes in the test.";
            type uint8 {
              range "1..255";
            }
            units "seconds";
            default "1";
          }
          leaf repeat-interval {
            description
              "The interval between subsequent tests.";
            type uint32 {
              range "1..4294967295";
            }
            units "seconds";
            default "60";
          }
        }
      }
      case non-stop {
        description
          "Test duration is non-stop. Interim results are calculated periodically.";
        container test-duration-nonstop {
          leaf probe-interval {
            description
              "The interval between subsequent probes in the test.";
            type uint8 {
              range "1..255";
            }
            units "seconds";
            default "1";
          }
          leaf computation-interval {
            description
              "Periodic computation interval. Valid for non-stop mode.";
            type uint16 {
              range "1..3600";
            }
            units "seconds";
            default "60";
          }
        }
      }
    }
  }

