  grouping performance-monitoring-top {
    container performance-monitoring {
      description
        "Performance Monitoring.";
      container interfaces {
        description
          "Interfaces to be monitored.";
        list interface {
          key "interface-name";
          description
            "The list of interfaces.";
          leaf interface-name {
            type leafref {
              path "../config-items/interface-name";
            }
            description
              "The name of the interface -- used to address the interface.";
          }
          container config-items {
            description
              "Interface Performance Monitoring configuration items";
            uses performance-monitoring-config;
          }
          container oper-items {
            config false;
            description
              "Interface Performance Monitoring operational items";
            uses performance-monitoring-config;
          }
          uses dn-group:apply-group;
        }
      }
      container stamp-sessions {
        description
          "STAMP Sender Sessions";
        list test-session {
          key "session-name";
          //					unique "source-ip destination-ip destination-vrf";
          description
            "This structure is a container of test session
             managed objects";
          leaf session-name {
            type leafref {
              path "../config-items/session-name";
            }
          }
          /*					leaf source-ip {
          type leafref {
          path "../config-items/source-ip";
          }
          }
          
          leaf sender-udp-port {
          type leafref {
          path "../config-items/sender-udp-port";
          }
          }
          
          leaf destination-ip {
          type leafref {
          path "../config-items/destination-ip";
          }
          }
          
          leaf destination-vrf {
          type leafref {
          path "../config-items/destination-vrf";
          }
          }
          
          leaf reflector-udp-port {
          type leafref {
          path "../config-items/reflector-udp-port";
          }
          } */
          container config-items {
            description
              "Holds configuration data";
            uses stamp-session-sender-instance-config;
            uses stamp-session-parameters;
            // uses stamp-session-percentile;
          }
          container oper-items {
            config false;
            description
              "Holds state data";
            uses stamp-session-sender-instance-config;
            uses stamp-session-parameters;
            uses stamp-session-sender-instance-oper;
            // uses stamp-session-percentile;
          }
          uses dn-group:apply-group;
        }
      }
      container icmp-echo-sessions {
        description
          "ICMP echo IP performance measurement sessions";
        list test-session {
          max-elements 5000;
          key "session-name";
          //					unique "source-ip destination-ip destination-vrf";
          description
            "This structure is a container of test session
             managed objects";
          leaf session-name {
            type leafref {
              path "../config-items/session-name";
            }
          }
          container config-items {
            description
              "Holds configuration data";
            uses icmp-echo-session-sender-instance-config;
          }
          container oper-items {
            config false;
            description
              "Holds state data";
            uses icmp-echo-session-sender-instance-config;
            uses icmp-echo-session-sender-instance-oper;
          }
          uses dn-group:apply-group;
        }
      }
      container cfm-tests {
        description
          "CFM performance monitoring test results";
      }
      container profiles {
        description
          "Performance monitoring profiles";
        container link-delay-measurement-profiles {
          description
            "Contains link delay measurement profiles.";
          list profile {
            description
              "The list of STAMP link-performance profiles that can be attached to a session";
            key "profile-name";
            max-elements 5;
            leaf profile-name {
              type leafref {
                path "../config-items/profile-name";
              }
              description
                "The profile name. The profile is attached to a Simple TWAMP session";
            }
            container config-items {
              description
                "Configuration data for STAMP link-performance profile";
              uses stamp-link-performance-profile-config;
            }
            container oper-items {
              config false;
              description
                "State variables for STAMP link-performance profile";
              uses stamp-link-performance-profile-config;
            }
            uses dn-group:apply-group;
          }
        }
        container endpoint-delay-measurement-profiles {
          description
            "Contains endpoint delay measurement profiles.";
          list profile {
            description
              "The list of STAMP endpoint measurement profiles that can be attached to a session";
            key "profile-name";
            max-elements 5;
            leaf profile-name {
              type leafref {
                path "../config-items/profile-name";
              }
              description
                "The profile name. The profile is attached to a Simple TWAMP session";
            }
            container config-items {
              description
                "Configuration data for STAMP endpoint delay measurement profile";
              uses stamp-endpoint-delay-measurement-profile-config;
            }
            container oper-items {
              config false;
              description
                "State variables for STAMP endpoint delay measurement profile";
              uses stamp-endpoint-delay-measurement-profile-config;
            }
            uses dn-group:apply-group;
          }
        }
        container icmp-echo-ip-performance-measurement-profiles {
          description
            "Contains ICMP echo IP performance measurement profiles";
          list profile {
            description
              "Contains the list of ICMP echo IP perforamnce measurement profiles that can be attached to a session";
            key "profile-name";
            max-elements 5;
            leaf profile-name {
              type leafref {
                path "../config-items/profile-name";
              }
              description
                "The profile name. The profile is attached to a ICMP echo IP performance measurement session";
            }
            container config-items {
              description
                "Configuration data for ICMP echo IP performance measurement profile";
              uses icmp-echo-profile-config;
            }
            container oper-items {
              config false;
              description
                "State variables for ICMP echo IP performance measurement profile";
              uses icmp-echo-profile-config;
            }
            uses dn-group:apply-group;
          }
        }
        container cfm {
          description
            "Contains CFM performance monitoring profiles";
          container two-way-delay-measurement {
            description
              "Contains CFM two-way delay measurement profiles";
            list profile {
              description
                "The list of CFM two-way delay measurement profiles that can be attached to a CFM test";
              key "profile-name";
              max-elements 5;
              leaf profile-name {
                type leafref {
                  path "../config-items/profile-name";
                }
                description
                  "The profile name. The profile is attached to a CFM two-way delay measurement test";
              }
              container config-items {
                description
                  "Configuration data for CFM two-way delay measurement profile";
                uses cfm-two-way-delay-measurement-profile-config;
              }
              container oper-items {
                config false;
                description
                  "State variables for CFM two-way delay measurement profile";
                uses cfm-two-way-delay-measurement-profile-config;
              }
              uses dn-group:apply-group;
            }
          }
          container two-way-synthetic-loss-measurement {
            description
              "Contains CFM two-way synthetic loss measurement profiles";
            list profile {
              description
                "The list of CFM two-way synthetic loss measurement profiles that can be attached to a CFM test";
              key "profile-name";
              max-elements 5;
              leaf profile-name {
                type leafref {
                  path "../config-items/profile-name";
                }
                description
                  "The profile name. The profile is attached to a CFM two-way synthetic loss measurement test";
              }
              container config-items {
                description
                  "Configuration data for CFM two-way synthetic loss measurement profile";
                uses cfm-two-way-synthetic-loss-measurement-profile-config;
              }
              container oper-items {
                config false;
                description
                  "State variables for CFM two-way synthetic loss measurement profile";
                uses cfm-two-way-synthetic-loss-measurement-profile-config;
              }
              uses dn-group:apply-group;
            }
          }
        }
      }
    }
  }

  // augment statements

  augment "/dn-top:drivenets-top/dn-services:services" {
    description
      "Adds performance-monitoring configuration to top model";
    uses performance-monitoring-top;
  }

  augment "/dn-top:drivenets-top/dn-services:services/dn-pm:performance-monitoring/dn-pm:interfaces/"
        + "dn-pm:interface/dn-pm:oper-items/dn-pm:delay-measurement/dn-pm:link-delay-measurement" {
    description
      "Adds STAMP session statistics to dynamic link delay measurement sessions oper items";
    uses link-performance-dynamic-delay-statistics;
  }
}
