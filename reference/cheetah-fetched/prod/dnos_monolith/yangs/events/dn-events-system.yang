  notification OSPFv3_NEIGHBOR_STATE_CHANGE {
    description
      "The OSPF neighbor adjacency state has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "OSPFv3 router {router-id} adjacency status with neighbor {neighbor-address} on interface {if-name} changed to {neighbor-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ospfv3";
    dn-events-extensions:event-group "OSPFv3";
    dn-events-extensions:event-snmp-trap-name "ospfv3NbrStateChange";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.2.1.191.0.2";
    dn-events-extensions:event-snmp-trap-vars "ospfv3RouterId.0 {router-id-for-trap} ; ospfv3NbrState.{neighbor-router-id} {neighbor-state}";
    leaf router-id {
      type string;
      description
        "OSPFv3 Router ID";
    }
    leaf router-id-for-trap {
      type uint32 {
        range "1..4294967295";
      }
      description
        "OSPFv3 Router ID";
    }
    leaf neighbor-address {
      type string;
      description
        "Neighbor peer IP address";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf neighbor-router-id {
      type uint32 {
        range "1..4294967295";
      }
      description
        "The OSPFv3 neighbor Router ID";
    }
    leaf neighbor-state {
      type enumeration {
        enum down {
          value 1;
        }
        enum attempt {
          value 2;
        }
        enum init {
          value 3;
        }
        enum twoway {
          value 4;
        }
        enum exchangestart {
          value 5;
        }
        enum exchange {
          value 6;
        }
        enum loading {
          value 7;
        }
        enum full {
          value 8;
        }
      }
      description
        "The current state of the OSPFv3 neighbor adjacency.";
    }
  }

  notification OSPFv3_INTERFACE_STATE_CHANGE {
    description
      "The OSPF intrerface state has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "OSPFv3 interface {if-name} status changed to {ospf-if-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ospfv3";
    dn-events-extensions:event-group "OSPFv3";
    dn-events-extensions:event-snmp-trap-name "ospfv3IfStateChange";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.2.1.191.0.10";
    dn-events-extensions:event-snmp-trap-vars "ospfv3RouterId.0 {router-id} ; ospfv3IfState.{if-index} {ospf-if-state}";
    leaf router-id {
      type uint32 {
        range "1..4294967295";
      }
      description
        "OSPFv3 Router ID";
    }
    leaf if-name {
      type string;
      description
        "OSPFv3 Interface name";
    }
    leaf if-index {
      type uint32;
      description
        "SNMP Interface index";
    }
    leaf ospf-if-state {
      type enumeration {
        enum down {
          value 1;
        }
        enum loopback {
          value 2;
        }
        enum waiting {
          value 3;
        }
        enum point-to-point {
          value 4;
        }
        enum designated-router {
          value 5;
        }
        enum backup-designated-router {
          value 6;
        }
        enum other-designated-router {
          value 7;
        }
        enum standby {
          value 8;
        }
      }
      description
        "The current state of the OSPFv3 interface.";
    }
  }

  notification OSPFv3_MAXIMUM_REDISTRIBUTED_PREFIXES_LIMIT_REACHED {
