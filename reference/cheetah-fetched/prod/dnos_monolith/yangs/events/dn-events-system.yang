    dn-events-extensions:event-message-string "Number of BGP sessions has crossed the system threshold {threshold}% limit of {limit}, the number of BGP sessions ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of BGP sessions";
    }
    leaf limit {
      type uint16;
      description
        "The accumulated BGP sessions on all VRF instances";
    }
  }

  notification BGP_MAXIMUM_SESSIONS_THRESHOLD_CLEARED {
    description
      "The number of BGP sessions is below the system threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of BGP sessions is below the system threshold {threshold}% of the limit ({limit}), the current number of BGP sessions is ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of BGP neighbors";
    }
    leaf limit {
      type uint16;
      description
        "The accumulated BGP sessions on all VRF instances";
    }
  }

  notification BGP_VRF_IPV4_MAXIMUM_ROUTES_LIMIT_REACHED {
    description
      "The number of BGP routes in a given VRF IPv4 unicast table has reached the configured system limit.";
