  notification L2_MAC_MOBILITY_NON_VOLATILE_STORAGE_FULL {
    description
      "Non-volatile storage space for the MAC-Mobility Table is full";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The non-volatile storage space for the MAC-Mobility Table is full, in case of process restart or NCC failover, information will be lost.";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "RIB";
    dn-events-extensions:event-group "System";
  }

  notification L2_MAC_MOBILITY_NON_VOLATILE_STORAGE_AVAILABLE {
    description
      "Non-volatile storage space forthe MAC-Mobility Table is available";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Non-volatile storage space is now available for moved MAC entries";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "RIB";
    dn-events-extensions:event-group "System";
  }

  notification CLOCK_STATE_CHANGE {
    description
      "The Synchronous Ethernet (SyncE) clock state has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "{node-type} {node-id} reports a SyncE clock state change from {orig-state} to {new-state}.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf orig-state {
      description
        "Operating state of the clock before state change";
      type enumeration {
        enum error;
        enum freerun;
        enum holdover;
        enum fastlock;
        enum acquiring;
        enum locked;
      }
    }
    leaf new-state {
      description
        "Operating state of the clock after state change";
      type enumeration {
        enum error;
        enum freerun;
        enum holdover;
        enum fastlock;
        enum acquiring;
        enum locked;
      }
    }
  }

  notification CLOCK_FAILURE {
    description
      "The Synchronous Ethernet (SyncE) clock has lost frequency synchronization from the reference source.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "{node-type} {node-id} reports that the SyncE clock entered Holdover state.";
    dn-events-extensions:event-corrective-action-string "Verify synchronization has been restored. Replace the failing reference source if you keep losing synchronization.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
  }

  notification CLOCK_SOURCE_SWITCH {
    description
      "The Synchronous Ethernet (SyncE) clock has switched to another reference source.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "{node-type} {node-id} reports that the SyncE source clock changed from {source-interface-name} to {new_source-interface-name}. Reason: {source-switch-reason}.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf source-interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0, smb-10mhz)";
    }
    leaf new-source-interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0, smb-10mhz)";
    }
    leaf source-switch-reason {
      type enumeration {
        enum ql_based;
        enum revertive;
        enum signal_fail;
      }
    }
  }

  notification CLOCK_SYNC_SOURCE_DEGRADED {
    description
      "The Synchronous Ethernet (SyncE) reference source is degraded.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "{node-type} {node-id} reports that the SyncE source {source-interface-name} has degraded to QL: {quality-level}. Reason: {source-degrade-reason}.";
    dn-events-extensions:event-corrective-action-string "Consider replacing the degraded reference source.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf source-interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0, smb-10mhz)";
    }
    leaf quality-level {
      description
        "The quality level as viewed by the G.781 selection process.";
      type enumeration {
        /* option-1 */
        enum ql_prc;
        enum ql_ssu_a;
        enum ql_ssu_b;
        enum ql_sec;
        enum ql_dnu;
        /* option-2 */
        enum ql_prs;
        enum ql_stu;
        enum ql_st2;
        enum ql_tnc;
        enum ql_st3e;
        enum ql_st3;
        enum ql_smc;
        enum ql_prov;
        enum ql_dus;
        /* no quality level */
        enum no_ql;
      }
    }
    leaf source-degrade-reason {
      type enumeration {
        enum QL_degraded;
        enum loss_of_signal;
        enum lockout;
        enum esmc_timeout;
        enum frequency_out_of_range;
        enum link_down;
      }
    }
  }

  notification CLOCK_SYNC_SOURCE_QUALIFIED {
    description
      "The Synchronous Ethernet (SyncE) reference source can be selected as a clock reference source.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "{node-type} {node-id} reports that the SyncE source {source-interface-name} is qualified as clock reference source.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf source-interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0, smb-10mhz)";
    }
  }

  notification CLOCK_CONFIG_CHANGE {
    description
      "The Synchronous Ethernet (SyncE) clock configuration has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "{node-type} {node-id} reports that the SyncE clock configuration has changed. "
                                            + "Original configuration: SyncE enable: {orig-admin-state}, QL-enable: {orig-ql-enable}, Synchoronization option: {orig-sync-option}. "
                                            + "New configuration: SyncE enable: {admin-state}, QL-enable: {ql-enable}, Synchoronization option: {sync-option}. ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf orig-admin-state {
      description
        "Original clock configuration global SyncE enable value";
      type enumeration {
        enum disabled;
        enum enabled;
      }
    }
    leaf admin-state {
      description
        "New clock configuration global SyncE enable value";
      type enumeration {
        enum disabled;
        enum enabled;
      }
    }
    leaf orig-ql-enable {
      description
        "Original clock configuration QL-enable value";
      type enumeration {
        enum disabled;
        enum enabled;
      }
    }
    leaf ql-enable {
      description
        "New clock configuration QL-enable value";
      type enumeration {
        enum disabled;
        enum enabled;
      }
    }
    leaf orig-sync-option {
      description
        "Original clock configuration clock synchronization option value";
      type enumeration {
        enum option-1;
        enum option-2;
      }
    }
    leaf sync-option {
      description
        "New clock configuration clock synchronization option value";
      type enumeration {
        enum option-1;
        enum option-2;
      }
    }
  }

  notification CLOCK_SOURCE_CONFIG_CHANGE {
    description
      "The Synchronous Ethernet (SyncE) clock source configuration has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "{node-type} {node-id} reports that the SyncE source configuration has changed. "
                                            + "Name: {interface-name} "
                                            + "Original configuration: priority: {orig-source-priority}, wtr: {orig-wtr-time}, holdoff {orig-holdoff-time}. "
                                            + "New configuration: priority: {source-priority}, wtr: {wtr-time}, holdoff {holdoff-time}. ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf orig-source-priority {
      description
        "Original clock source priority";
      type uint8 {
        range "0..255";
      }
    }
    leaf source-priority {
      description
        "New clock source priority";
      type uint8 {
        range "0..255";
      }
    }
    leaf interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0, smb-10mhz)";
    }
    leaf orig-wtr-time {
      description
        "Original source interface wait-to-restore time";
      type uint8 {
        range "0..12";
      }
    }
    leaf wtr-time {
      description
        "New source interface wait-to-restore time";
      type uint8 {
        range "0..12";
      }
    }
    leaf orig-holdoff-time {
      description
        "Original source interface holdoff time";
      type uint16 {
        range "300..1800";
      }
    }
    leaf holdoff-time {
      description
        "New source interface holdoff time";
      type uint16 {
        range "300..1800";
      }
    }
  }

  notification SYSTEM_PROFILE_CHANGE {
    description
      "System profile change is required.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "System profile change is required in NCP {ncp-id} from profile {old-profile-name} to profile {new-profile-name}. WB Agent process in NCP {ncp-id} will restart for the change to take effect.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Element Manager";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf old-profile-name {
      type string;
      description
        "The name of the current system profile";
    }
    leaf new-profile-name {
      type string;
      description
        "The name of the candidate system profile";
    }
  }

  notification PTP_CLOCK_CONFIG_CHANGE {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock state has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "{node-type} {node-id} PTP clock state has changed."
                                            + "Profile: {ptp-profile} "
                                            + "Original admin state: {orig-admin-state}, New admin state: {new-admin-state} "
                                            + "Original holdover time: {orig-holdover-time}, New holdover time: {new-holdover-time} ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf ptp-profile {
      type string;
      description
        "PTP profile";
    }
    leaf orig-admin-state {
      description
        "Original PTP admin state";
      type enumeration {
        enum disabled;
        enum enabled;
      }
    }
    leaf new-admin-state {
      description
        "New PTP admin state";
      type enumeration {
        enum disabled;
        enum enabled;
      }
    }
    leaf orig-holdover-time {
      description
        "PTP clock holdover time";
      type uint16;
    }
    leaf new-holdover-time {
      description
        "PTP clock holdover time";
      type uint16;
    }
  }

  notification PTP_PORT_STATE_CHANGE {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock port state has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "{node-type} {node-id} PTP clock port state has changed. "
                                            + "Interface: {interface-name} "
                                            + "Profile: {ptp-profile} "
                                            + "Original state: {orig-port-state} "
                                            + "New state: {new-port-state} ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0)";
    }
    leaf ptp-profile {
      type string;
      description
        "PTP profile";
    }
    leaf orig-port-state {
      description
        "Original PTP port state";
      type enumeration {
        enum unknown;
        enum initializing;
        enum faulty;
        enum disabled;
        enum listening;
        enum pre-master;
        enum master;
        enum passive;
        enum uncalibrated;
        enum slave;
      }
    }
    leaf new-port-state {
      description
        "New PTP port state";
      type enumeration {
        enum unknown;
        enum initializing;
        enum faulty;
        enum disabled;
        enum listening;
        enum pre-master;
        enum master;
        enum passive;
        enum uncalibrated;
        enum slave;
      }
    }
  }

  notification PTP_RECV_MSG_RATE_DROP {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) incomming receive message rate has dropped below 50% of the expected rate on the port.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "{node-type} {node-id} PTP clock port's received message rate has dropped. "
                                            + "Interface: {interface-name} "
                                            + "Message type: {msg-type} "
                                            + "Received in period: {received-in-period} "
                                            + "Expected in period: {expected-in-period} "
                                            + "Time period in seconds: {time-period} ";
    dn-events-extensions:event-corrective-action-string "Check the port connectivity and the clock configuration connected to the port.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0)";
    }
    leaf msg-type {
      description
        "PTP message type";
      type enumeration {
        enum sync {
          value 0;
        }
        enum delay_req {
          value 1;
        }
        enum follow_up {
          value 8;
        }
        enum delay_resp {
          value 9;
        }
        enum announce {
          value 11;
        }
        enum management {
          value 13;
        }
      }
    }
    leaf received-in-period {
      type uint32;
      description
        "Number of messages received during measure period.";
    }
    leaf expected-in-period {
      type uint32;
      description
        "Number of messages expected during measure period.";
    }
    leaf time-period {
      type uint32;
      description
        "Period of time in seconds for message count measurement.";
    }
  }

  notification PTP_CLOCK_PARENT_CHANGE {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock parent has changed.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "{node-type} {node-id} PTP clock parent has changed. "
                                            + "Original parent: interface {orig-interface-name}, Parent clock identity {orig-parent-identity}, GM identity {orig-gm-identity} "
                                            + "New parent: interface {new-interface-name}, Parent clock identity {new-parent-identity}, GM identity {new-gm-identity} ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf orig-interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0)";
    }
    leaf orig-parent-identity {
      type string {
        length "1..32";
      }
      description
        "PTP parent clock identity";
    }
    leaf orig-gm-identity {
      type string {
        length "1..32";
      }
      description
        "PTP GM clock idetity";
    }
    leaf new-interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0)";
    }
    leaf new-parent-identity {
      type string {
        length "1..32";
      }
      description
        "PTP clock identity";
    }
    leaf new-gm-identity {
      type string {
        length "1..32";
      }
      description
        "PTP GM clock idetity";
    }
  }

  notification PTP_PORT_NON_STANDARD_MSG {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) received a non-standard message.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "{node-type} {node-id} PTP clock port received a non-standard message. "
                                            + "Interface: {interface-name} "
                                            + "Receiving port's connected clock identity: {clock-identity} ";
    dn-events-extensions:event-corrective-action-string "Check the clock configuration connected to port.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0)";
    }
    leaf clock-identity {
      type string {
        length "1..32";
      }
      description
        "PTP clock identity of clock connected to the reporting port";
    }
  }

  notification PTP_PORT_LEAP_SECONDS_CHANGE {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock leap59 or leap61 time properties have changed on the port.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "{node-type} {node-id} leap59 or leap61 time properties changed on the PTP clock port. "
                                            + "Interface: {interface-name} "
                                            + "Original Leap59 value: {orig-leap59}, New Leap59 value: {new-leap59} "
                                            + "Original Leap61 value: {orig-leap61}, New Leap61 value: {new-leap61} ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0)";
    }
    leaf orig-leap59 {
      description
        "PTP clock previous Leap59 flag value. Set to true if the last minute of the current UTC day
         contains 59 seconds. Otherwise, it is false";
      type string;
    }
    leaf new-leap59 {
      description
        "PTP clock new Leap59 flag value. Set to true if the last minute of the current UTC day
         contains 59 seconds. Otherwise, it is false";
      type string;
    }
    leaf orig-leap61 {
      description
        "PTP clock previous Leap61 flag value. Set to true if the last minute of the current UTC day
         contains 61 seconds. Otherwise, it is false";
      type string;
    }
    leaf new-leap61 {
      description
        "PTP clock new Leap61 flag value. Set to true if the last minute of the current UTC day
         contains 61 seconds. Otherwise, it is false";
      type string;
    }
  }

  notification PTP_CLOCK_UTC_OFFSET_CHANGE {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock time UTC offset properties have changed.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "{node-type} {node-id} UTC offset time property has changed. "
                                            + "Original: UTC offset {orig-utc-offset}, UTC offset valid flag {orig-utc-offset-valid} "
                                            + "New: UTC offset {new-utc-offset}, UTC offset valid flag {new-utc-offset-valid} ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf orig-utc-offset {
      type int32;
      description
        "Offset between TAI and UTC in seconds";
    }
    leaf new-utc-offset {
      type int32;
      description
        "Offset between TAI and UTC in seconds";
    }
    leaf orig-utc-offset-valid {
      type string;
      description
        "Flag set to True when UTC offset is known to be correct.";
    }
    leaf new-utc-offset-valid {
      type string;
      description
        "Flag set to True when UTC offset is known to be correct.";
    }
  }

  notification PTP_PORT_STEPS_REMOVED_VIOLATION {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock received an announce message that exceeded the local steps-removed value.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "{node-type} {node-id} PTP clock received an announce message with steps-removed value exceeding local steps-removed limit. "
                                            + "Message received on interface: {interface-name} "
                                            + "Message origin clock identity: {clock-identity} "
                                            + "Announce message steps-removed: {announce-steps-removed} "
                                            + "Configured local steps-removed limit: {local-max-steps-removed} ";
    dn-events-extensions:event-corrective-action-string "Check the local max-steps-removed configuration and network connectivity scheme.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0)";
    }
    leaf clock-identity {
      type string {
        length "1..32";
      }
      description
        "PTP clock idetity of clock connected to the reporting port";
    }
    leaf announce-steps-removed {
      type uint8;
      description
        "Announce message steps-removed attribute";
    }
    leaf local-max-steps-removed {
      type uint8;
      description
        "Announce message steps-removed qualification limit";
    }
  }

  notification PTP_PORT_DISQUALIFIED {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock previously qualified port has been disqualified from taking part in the BMCA.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "{node-type} {node-id} port stream has been disqualified from taking part in the BMCA. "
                                            + "Interface: {interface-name} ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0)";
    }
  }

  notification PTP_PORT_CONFIG_CHANGE {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock port configuration has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "{node-type} {node-id} PTP clock port configuration has changed. "
                                            + "Interface: {interface-name} "
                                            + "Profile: {ptp-profile} "
                                            + "Master-only: {new-master-only} "
                                            + "Local priority: {new-local-priority} "
                                            + "Announce receipt timeout: {new-announce-receipt-timeout} "
                                            + "Multicast address: {new-multicast-addr} "
                                            + "Port delay: {new-port-delay} ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf interface-name {
      type string;
      description
        "Source interface name (e.g. ge400-0/0/0)";
    }
    leaf ptp-profile {
      type string;
      description
        "PTP profile";
    }
    leaf new-master-only {
      description
        "PTP port Master-only flag value";
      type string;
    }
    leaf new-local-priority {
      description
        "PTP port Local priority value";
      type uint8;
    }
    leaf new-announce-receipt-timeout {
      description
        "PTP port Announce message receipt timeout value";
      type uint8;
    }
    leaf new-multicast-addr {
      description
        "PTP port Announce message receipt timeout value";
      type enumeration {
        enum non-forwardable;
        enum forwardable;
      }
    }
    leaf new-port-delay {
      description
        "PTP port delay value";
      type int32;
    }
  }

  notification PTP_PTSF_EVENT {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock Packet Timing Signal Fail (PTSF) flag has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "{node-type} {node-id} Packet Timing Signal Fail (PTSF) event has occured. "
                                            + "PTSF event type: {ptsf-type} ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf ptsf-type {
      description
        "PTP packet timing signal fail event type";
      type enumeration {
        enum misc_user;
        enum misc_ql_too_low;
        enum misc_los_from_phy;
        enum misc_wait_to_restore_active;
        enum contract_retry_attempts_fail;
        enum contract_announce_rejected;
        enum contract_sync_rejected;
        enum contract_delay_resp_rejected;
        enum contract_peer_delay_resp_rejected;
        enum contract_announce_rate_too_low;
        enum contract_sync_rate_too_low;
        enum contract_delay_resp_rate_too_low;
        enum contract_peer_delay_resp_rate_too_low;
        enum timeout_loss_announce;
        enum timeout_loss_sync;
        enum timeout_loss_follow_up;
        enum timeout_loss_sync_or_follow_up;
        enum timeout_loss_delay_resp;
        enum timeout_loss_peer_delay_resp;
        enum timeout_loss_peer_delay_folow_up;
        enum unusable_packet_reject_reset;
        enum unusable_loss_timestamps;
        enum unusable_local_time_inacc_exceeded;
        enum unusable_network_time_inacc_exceeded;
        enum freq_pull_in_range_oor;
        enum freq_pdv_freq_metric_fail;
        enum freq_freq_var_too_high;
        enum freq_no_freq_lock;
        enum phase_pdv_phase_metric_fail;
        enum phase_phase_var_too_high;
        enum phase_no_phase_lock;
        enum misc;
        enum contract;
        enum timeout;
        enum unusable;
        enum frequency;
        enum phase;
        enum main;
        enum as_capable_peer_delay_multi_resp;
        enum as_capable_peer_delay_above_threshold;
        enum as_capable_peer_delay_allowed_lost_response;
        enum as_capable;
        enum as_capable_peer_delay_ratio_invalid;
        enum unknown;
      }
    }
  }

  notification PTP_DEFAULT_DATASET_CONFIG_CHANGE {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock default dataset configuration has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "{node-type} {node-id} PTP default dataset configuration has changed "
                                            + "Profile: {ptp-profile} "
                                            + "New configuration: clock type: {new-clock-type}, priority2: {new-priority2}, local priority: {new-local-priority}, max-steps-removed {new-max-steps}, id {new-id}. ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf ptp-profile {
      type string;
      description
        "PTP profile";
    }
    leaf new-clock-type {
      description
        "PTP clock type";
      type enumeration {
        enum t-gm {
          value 1;
        }
        enum t-bc {
          value 2;
        }
        enum t-tsc {
          value 3;
        }
      }
    }
    leaf new-priority2 {
      description
        "PTP clock priority2 value";
      type uint8;
    }
    leaf new-local-priority {
      description
        "PTP clock local priority value";
      type uint8;
    }
    leaf new-max-steps {
      description
        "PTP clock max steps removed value";
      type uint8;
    }
    leaf new-id {
      type string {
        length "1..32";
      }
      description
        "PTP clock identity";
    }
  }

  notification PTP_GNSS_CONFIG_CHANGE {
    description
      "Precision Time Protocol (PTP / IEEE. 1588v2) clock GNSS configuration has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "NCP {ncp-id} reports that the PTP clock GNSS configuration has changed. "
                                            + "Previous state: {state}, New state {new-state} "
                                            + "New constellations: : GPS {new-gps}, SBAS {new-sbas}, GALILEO {new-galileo}, BEIDOU {new-beidou}, IMES {new-imes}, QZSS {new-qzss}, GLONASS {new-glonass} "
                                            + "Min. Satellite {min-satellites}, New Min. Satellite {new-min-satellites} "
                                            + "CNO {cno}, New CNO {new-cno} ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf ncp-id {
      type uint8;
      description
        "NCP id";
    }
    leaf state {
      type string;
      description
        "GNSS SMA input port state";
    }
    leaf new-state {
      type string;
      description
        "GNSS SMA input port new state";
    }
    leaf new-gps {
      type enumeration {
        enum disabled;
        enum enabled;
      }
      description
        "Enable or disable the Global Positioning System constellation";
    }
    leaf new-sbas {
      type enumeration {
        enum disabled;
        enum enabled;
      }
      description
        "Enable or disable the Satellite-based Augmentation Systems";
    }
    leaf new-galileo {
      type enumeration {
        enum disabled;
        enum enabled;
      }
      description
        "Enable or disable the Galileo (EU) constellation";
    }
    leaf new-beidou {
      type enumeration {
        enum disabled;
        enum enabled;
      }
      description
        "Enable or disable the BeiDou constellation";
    }
    leaf new-imes {
      type enumeration {
        enum disabled;
        enum enabled;
      }
      description
        "Enable or disable Indoor Messaging System";
    }
    leaf new-qzss {
      description
        "Enable or disable the Quasi-Zenith Satellite System (Japan) constellation";
      type enumeration {
        enum disabled;
        enum enabled;
      }
    }
    leaf new-glonass {
      type enumeration {
        enum disabled;
        enum enabled;
      }
      description
        "Enable or disable the Global Navigation Satellite System (Russia) constellation";
    }
    leaf min-satellites {
      type uint8;
      description
        "GNSS navigation minimal number of satellites";
    }
    leaf new-min-satellites {
      type uint8;
      description
        "GNSS navigation minimal number of satellites";
    }
    leaf cno {
      type uint16;
      description
        "GNSS CNO - ratio of the carrier power C to the noise power density N0, expressed in dB-Hz";
    }
    leaf new-cno {
      type uint16;
      description
        "GNSS CNO - ratio of the carrier power C to the noise power density N0, expressed in dB-Hz";
    }
  }

  notification PTP_EXTERNAL_TOD_LOCK_STATE_CHANGE {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock external Time of Day source port lock state has changed.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "{node-type} {node-id} external ToD {port-type} port lock state: {lock-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf port-type {
      type enumeration {
        enum rj45;
        enum gnss;
      }
      description
        "External ToD port type";
    }
    leaf lock-state {
      type enumeration {
        enum locked;
        enum unlocked;
      }
      description
        "External ToD port lock state";
    }
  }

  notification PTP_EXTERNAL_TOD_SOURCE_FAILURE {
    description
      "The Precision Time Protocol (PTP / IEEE. 1588v2) clock external Time of Day source port failure reported.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "{node-type} {node-id} external ToD {port-type} port failure type: {failure-type}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "clock";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf port-type {
      type enumeration {
        enum rj45;
        enum gnss;
      }
      description
        "External ToD port type";
    }
    leaf failure-type {
      type enumeration {
        enum crc_error {
          value 2;
        }
        enum crc_overflow {
          value 5;
        }
      }
      description
        "External ToD port faliure type";
    }
  }

  notification OSPF_ADVERTISE_MAX_METRIC_ON {
    description
      "OSPF has set the max metric on some metric(s) (IGP/TE/delay). This means other routers will consider the router to be least preferred in some path calculations.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "OSPF instance {instance} advertise max-metric was set to on, period: {period}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ospf";
    dn-events-extensions:event-group "OSPF";
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
    leaf period {
      type string;
      description
        "The period for which max-metric is set";
    }
  }

  notification OSPF_ADVERTISE_MAX_METRIC_OFF {
    description
      "OSPF has turned off the max metric.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "OSPF instance {instance} advertise max-metric was set to off";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ospf";
    dn-events-extensions:event-group "OSPF";
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
  }

  // Access-lists events

  notification ACCESS_LIST_LOG {
    description
      "The packet matched an access-list rule on the indicated interface.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "A packet from {source-address-and-port}, to {destination-address-and-port} on protocol {protocol} was received on interface {ingress-interface} of VRF {vrf-name} and {forwarding-action}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "ACL";
    leaf source-address-and-port {
      type string;
      description
        "The source IP address and port of the received packet";
    }
    leaf destination-address-and-port {
      type string;
      description
        "The destination IP address and port  of the received packet";
    }
    leaf protocol {
      type string;
      description
        "The protocol of the received packet";
    }
    leaf vrf-name {
      type string;
      description
        "The vrf name the packet was received on";
    }
    leaf forwarding-action {
      type enumeration {
        enum allowed;
        enum denied;
        enum sent-to-cpu;
      }
      description
        "Action being taken on the received packet";
    }
    leaf ingress-interface {
      type string;
      description
        "The ingress interface name the packet was received on";
    }
  }

  notification NCC_REPOSITORY_SYNC_FAILED {
    description
      "The NCCs' repository has failed to be synced.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "NCC {node-id} reports that the NCC {remote-node-id} has failed to sync its repository.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Cluster Manager";
    dn-events-extensions:event-group "System";
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf remote-node-id {
      type string;
      description
        "Remote Node ID";
    }
  }

  notification NCC_REPOSITORY_SYNC_SUCCEEDED {
    description
      "The Synchronous Ethernet (SyncE) reference source can be selected as a clock reference source.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "NCC {node-id} reports that the NCC {remote-node-id} has completed to sync its repository.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Cluster Manager";
    dn-events-extensions:event-group "System";
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf remote-node-id {
      type string;
      description
        "Remote Node ID";
    }
  }
}
