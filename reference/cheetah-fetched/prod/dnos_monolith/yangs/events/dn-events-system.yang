  notification IF_LINK_STATE_DELAY {
    description
      "The link state changed state. The notification of this link state change was delayed due to the configured carrier delay.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Link state on interface {if-name} changed from {old-state} to {new-state} was delayed by carrier-delay for {delay} ms";
    dn-events-extensions:event-corrective-action-string
      "<p>If the link state change was expected, for example due to planned maintenance, no corrective action is required. If the link state changed unexpectedly:</p>
       <ol>
       <li>Check that the cable and transceiver is properly inserted at both ends.</li>
       <li>Check if the interface configuration on either side of the connection has changed. If it has changed, make sure that the interface is properly configured. See show config interfaces in the CLI configuration guide.</li>
       <li>If the problem persists, contact Customer Support.</li>
       </ol>";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Interfaces";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf new-state {
      type string;
      description
        "Link state after change";
    }
    leaf old-state {
      type string;
      description
        "Link state before change";
    }
    leaf delay {
      type uint16;
      description
        "Delay value configured for carrier-delay at the interface";
    }
  }

  notification IF_LINK_STATE_SUPPRESSED {
    description
      "Any additional link state changes have been suppressed due to interface dampening.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Link state changes on interface {if-name} have been suppressed";
    dn-events-extensions:event-corrective-action-string "No corrective action is required.";
    dn-events-extensions:event-trigger-component-string "Interface Dampening";
    dn-events-extensions:event-group "Interfaces";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
  }

  notification IF_LINK_STATE_SUPPRESS_ENDED {
    description
      "Link state change suppression has ended because either the interface dampening penalty decay is below the reuse threshold, the maximum suppression timer has expired, or the penalty was manually cleared.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Link state change suppression ended on interface {if-name} due to {suppression-end-reason}";
    dn-events-extensions:event-corrective-action-string "No corrective action is required.";
    dn-events-extensions:event-trigger-component-string "Interface Dampening";
    dn-events-extensions:event-group "Interfaces";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf suppression-end-reason {
      type enumeration {
        enum penalty-decayed-below-reuse-threshold {
          value 0;
        }
        enum max-suppress-timer-expired {
          value 1;
        }
        enum penalty-cleared-manually {
          value 2;
        }
      }
      description
        "Interface link state suppress end reasons";
    }
  }

  notification IF_LINK_LOCAL_FAULT_DETECTED {
    description
      "Local fault detected on the interface Reconciliation Sublayer. The interface had stopped sending packets and Remote Fault Indication sent to the peer router.";
