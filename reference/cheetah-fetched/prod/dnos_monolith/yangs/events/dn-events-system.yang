  notification OSPFv3_GRACEFUL_RESTART_STATUS_CHANGE {
    description
      "The OSPFv3 Graceful Restart state has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "OSPFv3 router {router-id} process restarted. Graceful Restart state {gr-state} {gr-sub-state}. Graceful Restart grace period {grace-period} seconds";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ospfv3";
    dn-events-extensions:event-group "OSPFv3";
    leaf router-id {
      type string;
      description
        "OSPF Router ID";
    }
    leaf gr-state {
      type enumeration {
        enum not-restarting {
          value 1;
        }
        enum planned-restart {
          value 2;
        }
        enum unplanned-restart {
          value 3;
        }
      }
      description
        "Current status of OSPF graceful restart.";
    }
    leaf grace-period {
      type uint16 {
        range "60..1800";
      }
      description
        "Configured OSPF graceful restart timeout interval.";
    }
    leaf gr-sub-state {
      type enumeration {
        enum none {
          value 1;
        }
        enum in-progress {
          value 2;
        }
        enum completed {
          value 3;
        }
        enum time-out {
          value 4;
        }
        enum topology-changed {
          value 5;
        }
      }
      description
        "Describes the outcome of the last attempt at a
         graceful restart.  If the value is 'none', no restart
         has yet been attempted.  If the value is 'inProgress',
         a restart attempt is currently underway.";
    }
  }

