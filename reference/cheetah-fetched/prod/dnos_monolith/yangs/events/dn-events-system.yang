  notification BGP_UPDATE_EXCEED_MAX_SIZE {
    description
      "The size of a locally generated update message exceeds the maximum BGP message size of 4096 bytes.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: An expected adj-out update for {afi-safi} exceed bgp message maximum. Update message expected size {msg-total-size}, nlri value {value} and size {nlri-size}, attributes size {attr-size}";
    dn-events-extensions:event-corrective-action-string "Check if the prefix attributes exceed the maximum size.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf afi-safi {
      type string;
      description
        "nlri <address-family>-<sub-address-family>";
    }
    leaf msg-total-size {
      type uint32;
      description
        "bgp msg size in bytes";
    }
    leaf value {
      type string;
      description
        "nlri value";
    }
    leaf nlri-size {
      type uint32;
      description
        "nlri size in bytes";
    }
    leaf attr-size {
      type uint32;
      description
        "attributes size in bytes";
    }
  }

  notification BGP_ATTRIBUTE_EXCEED_MAX_SIZE {
    description
      "The size of an attribute update exceeds the maximum BGP attribute list size.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: An expected adj-out update for {afi-safi} has attribute {attribute-name} that exceed attribute size. Attributes size {attr-size}";
    dn-events-extensions:event-corrective-action-string "Check for routing loops where attributes may infinitely increase.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf afi-safi {
      type string;
      description
        "nlri <address-family>-<sub-address-family>";
    }
    leaf attribute-name {
      type string;
      description
        "nlri attribute name";
    }
    leaf attr-size {
      type uint32;
      description
        "attributes size in bytes";
    }
  }

  notification BGP_MALFORM_UPDATE {
    description
      "This event indicates that an UPDATE message contains one or more malformed NLRI or attributes was received. The action taken depends on the severity of the error.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "Malformed update {malform-type} {malformed-field} was received from neighbor {neighbor-address} on vrf {vrf-name}. Action taken {action-description}. {error-description}";
    dn-events-extensions:event-corrective-action-string "Check BGP neighbor configuration and message compatibility.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf malform-type {
      type enumeration {
        enum nlri {
          description
            "Malformed NLRI";
        }
        enum attribute {
          description
            "Malformed attribute";
        }
      }
      description
        "The type of malformed data: nlri or attribute";
    }
    leaf malformed-field {
      type string;
      description
        "The malformed attribute or NLRI field name";
    }
    leaf neighbor-address {
      type string;
      description
        "The BGP neighbor address";
    }
    leaf vrf-name {
      type string;
      description
        "The VRF name";
    }
    leaf action-description {
      type string;
      description
        "Action taken following the receipt of the malformed update, e.g. treat as withdraw, attr discard, etc.";
    }
    leaf error-description {
      type string;
      description
        "Optional error description";
    }
  }

  notification BGP_INTERNAL_ERROR {
    description
      "The BGP process has failed due to an internal error.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "BGP process has encountered an error: {error-type}, {error-message}";
    dn-events-extensions:event-corrective-action-string "Copy the error message and contact Customer Support.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf error-type {
      type string;
      description
        "Error group type";
    }
    leaf error-message {
      type string;
      description
        "Error description";
    }
  }

  notification BGP_SR_RECEIVED_INVALID_PREFIX_SID {
    description
      "BGP best path for a learned route include invalid prefix-sid attribute";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: received invalid SR Prefix-SID from neighbor {neighbor-address} for route {ip-prefix}. Invalid reason: {reason}";
    dn-events-extensions:event-corrective-action-string "Check configuration on advertising route origin";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf neighbor-address {
      type string;
      description
        "The BGP neighbor address";
    }
    leaf ip-prefix {
      type string;
      description
        "BGP learned route";
    }
    leaf reason {
      description
        "Reason string describing problem with received prefix-sid attribute";
      type string;
    }
  }

  notification BGP_SR_CONFLICTING_PREFIX_SID_SAME_PREFIX {
    description
      "BGP recevied different prefix-sid of same prefix on different paths. Label allocation will be per best path";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: received conflicting Prefix-SID attribute for prefix {ip-prefix} on different paths. Best-path attribute: {attribute}. Label allocation will be according to best-path";
    dn-events-extensions:event-corrective-action-string "Check configuration on advertising route origin";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf ip-prefix {
      type string;
      description
        "BGP learned route";
    }
    leaf attribute {
      description
        "Prefix SID attribute information, including index and originator srgb";
      type string;
    }
  }

  notification BGP_SR_CONFCLITING_PREFIX_SAME_LABEL_INDEX {
    description
      "BGP best path for a learned route is in conflicting prefix-sid situation, preventing label allocation per segment-routing logic";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: Allocated dynamic labeled-unicast label for {ip-prefix} instead of Prefix-SID label due to conflicting Label-Index. Conflicted SID index {index-value}. ";
    dn-events-extensions:event-corrective-action-string "Check configuration on advertising route origin";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf ip-prefix {
      type string;
      description
        "the prefix for which dynamic labeled-unicast label is allocated instead of Prefix-SID label";
    }
    leaf index-value {
      description
        "The SID index value which was learned for different prefixes thus resulting in conflicting state";
      type uint32;
    }
  }

  // BGP NSR events

  notification BGP_NSR_CONFIG {
    description
      "The BGP NSR (Non-Stop Routing) admin-state configuration was changed by the user listed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} has changed BGP NSR admin-state configuration to {new-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "bgp";
    dn-events-extensions:event-group "BGP";
    leaf user-name {
      type string;
      description
        "Username";
    }
    leaf new-state {
      type enumeration {
        enum enabled;
        enum disabled;
      }
      description
        "BGP NSR admin-state";
    }
  }

  notification BGP_NSR_RECOVERED {
    description
      "The system has performed a BGP Non-Stop Routing recovery due to a restart of the bgpd process.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "BGP Non-Stop Routing recovery was performed due to a restart of the bgpd process";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "bgp";
    dn-events-extensions:event-group "BGP";
  }

  notification BGP_NSR_RECOVERY_FAILED {
    description
      "The BGP process failed to recover in Non-Stop Routing mode.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "BGP process failed to recover in Non-Stop Routing mode";
    dn-events-extensions:event-corrective-action-string "Verify NSR readiness prior to the failure event.";
    dn-events-extensions:event-trigger-component-string "bgp";
    dn-events-extensions:event-group "BGP";
  }

  notification BGP_NSR_DB_NOT_SYNC {
    description
      "The standby NCC BGP NSR database is not synchronized. BGP will not recover in Non-Stop Routing mode if a system switchover occurs.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Standby NCC BGP NSR database is not synchronized. BGP will not recover in Non-Stop Routing mode if a system switchover occurs";
    dn-events-extensions:event-corrective-action-string "Verify connectivity to the standby NCC.";
    dn-events-extensions:event-trigger-component-string "bgp";
    dn-events-extensions:event-group "BGP";
  }

  notification BGP_NSR_DB_SYNC {
    description
      "The standby NCC BGP NSR database is synchronized.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Standby NCC BGP NSR database is synchronized";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "bgp";
    dn-events-extensions:event-group "BGP";
