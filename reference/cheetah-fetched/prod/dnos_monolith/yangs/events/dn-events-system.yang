  notification NCF_DYNAMIC_FABRIC_STATE_INITIALIZED {
    description
      "Fabric connectivity state has been initialized successfully on the listed NCF node as part of system initialization flow when dynamic fabric connectivity is enabled.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Fabric connectivity state has been initialized successfully on NCF {ncf-id} interface {if-name}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Cluster Manager";
    dn-events-extensions:event-group "System";
    leaf ncf-id {
      type uint16;
      description
        "NCF ID";
    }
    leaf if-name {
      type string;
      description
        "NCF fabric interface";
    }
  }

  notification NCF_FABRIC_CONNECTIVITY_CHANGED {
    description
      "Fabric connectivity configuration has been changed on the listed NCF node.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Fabric connectivity configuration changed for NCF {ncf-id} interface {if-name} connected to NCP {ncp-id} interface {if-name-dest}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Cluster Manager";
