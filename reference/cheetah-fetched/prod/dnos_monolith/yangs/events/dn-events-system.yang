      "The list of key exchange algorithms configured to be used by SSH and NETCONF servers have been updated.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "List of configured key exchange algorithms used by SSH and Netconf servers was updated";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "Management";
    dn-events-extensions:event-group "Management";
