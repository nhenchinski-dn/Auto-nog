  notification IF_LINK_SPEED_RX_THRESHOLD_EXCEEDED {
    description
      "The interface link rx speed has crossed the threshold.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Link rx speed of interface {if-name} is above utilization threshold ({threshold}%), current rx utilization rate is: {interface-input-utilization}% of max interface speed {interface-speed}Gbps";
    dn-events-extensions:event-corrective-action-string "No corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Interfaces";
    dn-events-extensions:event-snmp-trap-name "dnRsIfLinkRxThresholdExceeded";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.4.1.49739.2.8.0.5";
    dn-events-extensions:event-snmp-trap-vars "dnRsIfLinkUtilThreshold.{if-index} {threshold} ; dnRsIfLinkInputUtilization.{if-index} {interface-input-utilization}";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf if-index {
      type uint32;
      description
        "SNMP Interface index";
    }
    leaf threshold {
      type uint16;
      description
        "Threshold in percent";
    }
    leaf interface-input-utilization {
      type uint8;
      units "percent";
      description
        "Interface input utilization rate in percent";
    }
    leaf interface-speed {
      type uint32;
      description
        "Physical interface max bandwidth";
    }
  }

