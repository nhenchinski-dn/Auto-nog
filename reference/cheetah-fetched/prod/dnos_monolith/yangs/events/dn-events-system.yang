    }
    leaf ip-move-threshold {
      type uint8 {
        range "2..30";
      }
      description
        "Number of allowed Moves within the Loop Detection Window Period";
    }
  }

  notification IP_MOBILITY_IP_ADDRESS_PERMANENTLY_SUPPRESSED {
    description
      "An IP address has exceeded the number of allowed move events and has been permanently suppressed";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The IP {ip-address} received in service {service-name} has been permanently suppressed, having crossed the restore-cycles {restore-cycles} limit.";
    dn-events-extensions:event-corrective-action-string "Check configuration, check for layer-3 network loops";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "L2VPN";
    leaf ip-address {
      type string;
      description
        "IP address that has been permanently suppressed.";
    }
