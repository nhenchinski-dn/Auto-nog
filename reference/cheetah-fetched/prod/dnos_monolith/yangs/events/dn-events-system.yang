  notification BGP_SESSION_MINIMUM_HOLD_TIME_VIOLATION {
    description
      "BGP session is rejected due to unacceptable hold time by local or remote side";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: Neighbor {neighbor-address} adjacency was rejected due to minimum hold-time violation."
                                            + "Received hold-time {neighbor-hold-time}, local hold-time {local-hold-time}, local minimum-hold-time {local-minimum-hold-time}";
    dn-events-extensions:event-corrective-action-string "Update hold-time settings either locally or remotely";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf neighbor-address {
      type string;
      description
        "The BGP neighbor";
    }
    leaf neighbor-hold-time {
      description
        "Neighbor hold time as received in open message";
      type uint16;
    }
    leaf local-hold-time {
      description
        "Local hold time as sent in open message";
      type uint16;
    }
    leaf local-minimum-hold-time {
      description
        "Local minimum hold-time value";
      type uint16;
    }
  }

  notification BGP_NEIGHBOR_MAXIMUM_PREFIX_LIMIT_REACHED {
    description
      "The maximum number of prefixes learned via BGP for each BGP neighbor address family has been reached. This will cause an exceed action to be triggered, either a warning only or the session is restarted.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: Exceeded maximum prefix learned from BGP neighbor {neighbor-address} for address family {address-family}. Resulting in an exceed action {exceed-action}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf neighbor-address {
      type string;
      description
        "The BGP neighbor address";
    }
    leaf address-family {
      type string;
      description
        "BGP afi-safi type";
    }
    leaf exceed-action {
      type enumeration {
        enum Warning-Only;
        enum Restart-session;
        enum Excess-discard;
      }
    }
  }

  notification BGP_NEIGHBOR_MAXIMUM_PREFIX_LIMIT_CLEARED {
    description
      "The maximum number of prefixes learned via BGP for each BGP neighbor address family has been reached. This will cause an exceed action to be triggered, either a warning only or the session is restarted.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: Total number of prefixes is below maximum prefix allowed from BGP neighbor {neighbor-address} for address family {address-family}.";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf neighbor-address {
      type string;
      description
        "The BGP neighbor address";
    }
    leaf address-family {
      type string;
      description
        "BGP afi-safi type";
    }
  }

  notification BGP_NEIGHBOR_MAXIMUM_PREFIX_LIMIT_EXCESS_DISCARD_RECOVER_REQUIRED {
    description
      "The number of prefixes learned from the BGP neighbor address family is below the configured limit. The system cannot automatically recover the discarded routes, and user intervention is needed.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: Total number of prefixes is below maximum prefix allowed from BGP neighbor {neighbor-address} for address family {address-family}, discarded paths cannot be recovered, consider resetting the neighbor session to retrieve all required paths.";
    dn-events-extensions:event-corrective-action-string "Reset the BGP peering session for the neighbor routes to be relearned.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf neighbor-address {
      type string;
      description
        "The BGP neighbor address";
    }
    leaf address-family {
      type string;
      description
        "BGP afi-safi type";
    }
  }

  notification BGP_NEIGHBOR_MAXIMUM_PREFIX_THRESHOLD_EXCEEDED {
    description
      "The number of prefixes learned via BGP has crossed the configured threshold for the IPv4 or IPv6 address family.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: Exceeded configured maximum prefix {max-prefix} threshold of {threshold}%. {num-of-prefix} prefixes learned from BGP neighbor {neighbor-address} for address family {address-family}.";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    dn-events-extensions:event-snmp-trap-name "dnBgpNeighborMaximumPrefixThresholdExceeded";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.4.0.3";
    dn-events-extensions:event-snmp-trap-vars
      "dnPeerLocalAddrType.0 {address-type} ; dnPeerLocalAddr.0  CONVERT inetAddr({address-type}) {local-address} ;
       dnPeerRemoteAddrType.0 {address-type}; dnPeerRemoteAddr.0  CONVERT inetAddr({address-type}) {neighbor-address} ;
       dnPeerAfi.0 {afi}; dnPeerSafi.0 {sub-address-family};
       dnPeerAfiSafiMaxPrefix.0 {max-prefix} ; dnPeerAfiSafiThreshold.0 {threshold};
       dnPeerAfiSafiMaxReceivedPrefix.0 {num-of-prefix}";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf max-prefix {
      type uint32;
      description
        "Configured maximum-prefix";
    }
    leaf threshold {
      type uint8;
      description
        "Configured maximum-prefix threshold";
    }
    leaf num-of-prefix {
      type uint32;
      description
        "Number of prefixes learned";
    }
    leaf neighbor-address {
      type string;
      description
        "The BGP neighbor address";
    }
    leaf address-family {
      type string;
      description
        "BGP afi-safi type";
    }
    leaf address-type {
      description
        "This object specifies the IP address type of the source IP
         address of this BFD session.  The value of unknown(0) is
         allowed only when the session is singleHop(1) and the
         source IP address of this BFD session is derived from
         the outgoing interface, or when the BFD session is not
         associated with a specific interface.  If any other
         unsupported values are attempted in a set operation, the
         agent MUST return an inconsistentValue error.";
      type enumeration {
        enum unknown {
          value 0;
        }
        enum ipv4 {
          value 1;
        }
        enum ipv6 {
          value 2;
        }
        enum dns {
          value 16;
        }
      }
    }
    leaf local-address {
      type string;
      description
        "The BGP local session address";
    }
    leaf afi {
      description
        "This object specifies the address-family type with bgp neighbor";
      type enumeration {
        enum unknown {
          value 0;
        }
        enum ipv4 {
          value 1;
        }
        enum ipv6 {
          value 2;
        }
        enum dns {
          value 16;
        }
        enum l2vpn {
          value 25;
        }
        enum link-state {
          value 16388;
        }
      }
    }
    leaf sub-address-family {
      description
        "This object specifies the sub-address-family type with bgp neighbor";
      type enumeration {
        enum unicast {
          value 1;
        }
        enum multicast {
          value 2;
        }
        enum unicastAndMulticast {
          value 3;
        }
        enum labeledUnicast {
          value 4;
        }
        enum vpls {
          value 65;
        }
        enum evpn {
          value 70;
        }
        enum link-state {
          value 71;
        }
        enum vpn {
          value 128;
        }
        enum rt-constrains {
          value 132;
        }
        enum flowspec {
          value 133;
        }
        enum flowspecVpn {
          value 134;
        }
      }
    }
  }

  notification BGP_NEIGHBOR_MAXIMUM_PREFIX_THRESHOLD_CLEARED {
    description
      "The number of prefixes learned via BGP is below the configured threshold for the IPv4 or IPv6 address family.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: Total number of prefixes is below the threshold of {threshold}%. {num-of-prefix} prefixes learned from BGP neighbor {neighbor-address} for address family {address-family}.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    dn-events-extensions:event-snmp-trap-name "dnBgpNeighborMaximumPrefixThresholdCleared";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.4.0.4";
    dn-events-extensions:event-snmp-trap-vars
      "dnPeerLocalAddrType.0 {address-type} ; dnPeerLocalAddr.0  CONVERT inetAddr({address-type}) {local-address} ;
       dnPeerRemoteAddrType.0 {address-type}; dnPeerRemoteAddr.0  CONVERT inetAddr({address-type}) {neighbor-address} ;
       dnPeerAfi.0 {afi}; dnPeerSafi.0 {sub-address-family};
       dnPeerAfiSafiThreshold.0 {threshold};
       dnPeerAfiSafiMaxReceivedPrefix.0 {num-of-prefix}";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf max-prefix {
      type uint32;
      description
        "Configured maximum-prefix";
    }
    leaf threshold {
      type uint8;
      description
        "Configured maximum-prefix threshold";
    }
    leaf num-of-prefix {
      type uint32;
      description
        "Number of prefixes learned";
    }
    leaf neighbor-address {
      type string;
      description
        "The BGP neighbor address";
    }
    leaf address-family {
      type string;
      description
        "BGP afi-safi type";
    }
    leaf address-type {
      description
        "This object specifies the IP address type of the source IP
         address of this BFD session.  The value of unknown(0) is
         allowed only when the session is singleHop(1) and the
         source IP address of this BFD session is derived from
         the outgoing interface, or when the BFD session is not
         associated with a specific interface.  If any other
         unsupported values are attempted in a set operation, the
         agent MUST return an inconsistentValue error.";
      type enumeration {
        enum unknown {
          value 0;
        }
        enum ipv4 {
          value 1;
        }
        enum ipv6 {
          value 2;
        }
        enum dns {
          value 16;
        }
      }
    }
    leaf local-address {
      type string;
      description
        "The BGP local session address";
    }
    leaf afi {
      description
        "This object specifies the address-family type with bgp neighbor";
      type enumeration {
        enum unknown {
          value 0;
        }
        enum ipv4 {
          value 1;
        }
        enum ipv6 {
          value 2;
        }
        enum dns {
          value 16;
        }
        enum l2vpn {
          value 25;
        }
        enum link-state {
          value 16388;
        }
      }
    }
    leaf sub-address-family {
      description
        "This object specifies the sub-address-family type with bgp neighbor";
      type enumeration {
        enum unicast {
          value 1;
        }
        enum multicast {
          value 2;
        }
        enum unicastAndMulticast {
          value 3;
        }
        enum labeledUnicast {
          value 4;
        }
        enum vpls {
          value 65;
        }
        enum evpn {
          value 70;
        }
        enum link-state {
          value 71;
        }
        enum vpn {
          value 128;
        }
        enum rt-constrains {
          value 132;
        }
        enum flowspec {
          value 133;
        }
        enum flowspecVpn {
          value 134;
        }
      }
    }
  }

  notification BGP_MAXIMUM_SESSIONS_LIMIT_REACHED {
    description
      "The number of BGP sessions has reached the configured system limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of BGP sessions has reached system limit of {limit}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf limit {
      type uint16;
      description
        "The accumulated BGP sessions on all vrf instances";
    }
  }

  notification BGP_MAXIMUM_SESSIONS_LIMIT_CLEARED {
    description
      "BGP sessions have been removed, the number of BGP sessions is below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of BGP sessions is below the system limit of {limit} adjacencies";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    leaf limit {
      type uint16;
      description
        "The accumulated BGP sessions on all VRF instances";
    }
  }

  notification BGP_MAXIMUM_SESSIONS_THRESHOLD_EXCEEDED {
    description
      "The number of BGP sessions has crossed the system threshold.";
