  notification SRV6_CSID_BLOCK_DYNAMIC_RANGE_THRESHOLD_CLEAR {
    description
      "The threshold of SRv6 CSID allocation for dynamic-function block was cleared.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "SRv6 CSID allocation for dynamic-function block {block_name} is below the threshold (85%) of the limit ({limit}), the current number of allocations is ({current_allocations}).";
