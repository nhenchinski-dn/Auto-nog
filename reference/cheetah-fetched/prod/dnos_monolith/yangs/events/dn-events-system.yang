      description
        "Port of the SZTP bootstrap server";
    }
  }

  notification SZTP_RESTORE_START {
    description
      "Initiates a restoration process for SZTP to revert system configurations and os version to pre-SZTP flow settings, after an interrupted or failed SZTP flow.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Restoring to initial state after interrupted or failed SZTP Flow from onboarding information recieved from {server-address}:{port}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "SZTP Client";
    dn-events-extensions:event-group "Management";
    leaf server-address {
      type string;
      description
        "Address of the SZTP bootstrap server";
    }
    leaf port {
      type uint16;
      description
        "Port of the SZTP bootstrap server ";
    }
  }

  notification SZTP_RESTORE_FAILED {
    description
      "The SZTP restoration process encountered a failure, which may require manual investigation and intervention.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "SZTP restoration operation failed after interrupted or failed SZTP Flow from onboarding information recieved from {server-address}:{port}. error:{error}";
    dn-events-extensions:event-corrective-action-string "Investigate the cause of the restoration failure and execute necessary troubleshooting steps.";
    dn-events-extensions:event-trigger-component-string "SZTP Client";
    dn-events-extensions:event-group "Management";
    leaf server-address {
      type string;
      description
        "Address of the SZTP bootstrap server";
    }
    leaf port {
      type uint16;
      description
        "Port of the SZTP bootstrap server ";
    }
    leaf error {
      type string;
      description
        "Error message of the restoration process failure.";
    }
  }

  notification SZTP_RESTORE_COMPLETED {
    description
      "Indicates the successful completion of the SZTP restoration process, confirming that the system's configurations and state are reverted to the initial state before SZTP flow.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "SZTP restoration operation completed successfully after interrupted or failed SZTP Flow from onboarding information recieved from {server-address}:{port}.";
    dn-events-extensions:event-corrective-action-string "No further action is required.";
    dn-events-extensions:event-trigger-component-string "SZTP Client";
    dn-events-extensions:event-group "Management";
