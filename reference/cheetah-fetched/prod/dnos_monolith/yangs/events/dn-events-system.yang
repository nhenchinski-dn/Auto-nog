  // SZTP events

  notification SZTP_NO_SERVERS_FOUND {
    description
      "Secure Zero Touch Provisioning did not find any configured servers.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "No SZTP servers could be found for provisioning.";
    dn-events-extensions:event-corrective-action-string "Verify SZTP server configuration";
    dn-events-extensions:event-trigger-component-string "SZTP Client";
    dn-events-extensions:event-group "Management";
  }

  notification SZTP_ATTEMPT_REQUEST_FAILED {
    description
      "A request to the SZTP bootstrap server has failed, indicating an error in obtaining onboarding information";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Unable to obtain onboarding information from the SZTP bootstrap server at {server-address}:{port}. error: {error-message}";
    dn-events-extensions:event-corrective-action-string "Check the bootstrap server status, verify network connectivity, and examine the provided error message for specific troubleshooting steps";
    dn-events-extensions:event-trigger-component-string "SZTP Client";
    dn-events-extensions:event-group "Management";
    leaf server-address {
      type string;
      description
        "Address of the SZTP bootstrap server";
    }
    leaf port {
      type uint16;
      description
        "Port of the SZTP bootstrap server";
    }
    leaf error-message {
      type string;
      description
        "The error message that describes what is the failure reason";
    }
  }

  notification SZTP_ATTEMPT_REQUEST_SUCCEEDED {
    description
      "A request to the SZTP bootstrap server was successful";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Successfully processed request with SZTP bootstrap server at {server-address}:{port}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required";
    dn-events-extensions:event-trigger-component-string "SZTP Client";
    dn-events-extensions:event-group "Management";
    leaf server-address {
      type string;
      description
        "Address of the SZTP bootstrap server";
    }
    leaf port {
      type uint16;
      description
        "Port of the SZTP bootstrap server";
    }
  }

  notification SZTP_FLOW_START {
    description
      "The SZTP provisioning flow has started. After this notification, the system will attempt to retrieve onboarding information from the list of SZTP bootstrap server.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "System starting SZTP flow";
    dn-events-extensions:event-corrective-action-string "No corrective action required";
    dn-events-extensions:event-trigger-component-string "SZTP Client";
    dn-events-extensions:event-group "Management";
  }

  notification SZTP_ATTEMPT_STATE_CHANGE {
    description
      "The SZTP attempt state has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "SZTP state changed to {new-state} on SZTP attempt on {server-address}:{port}";
    dn-events-extensions:event-corrective-action-string "No corrective action required unless state indicates an error.";
    dn-events-extensions:event-trigger-component-string "SZTP Client";
    dn-events-extensions:event-group "Management";
    leaf new-state {
      type string;
      description
        "The new state of the SZTP provisioning process.";
    }
    leaf server-address {
      type string;
      description
        "Address of the SZTP bootstrap server";
    }
    leaf port {
      type uint16;
      description
        "Port of the SZTP bootstrap server";
    }
  }

  notification SZTP_ATTEMPT_FAILED {
    description
      "The SZTP provisioning flow has failed.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "SZTP flow encountered a failure on SZTP attempt on {server-address}:{port}. error: {error-message}";
    dn-events-extensions:event-corrective-action-string "Check the logs for detailed error information and take remedial actions.";
    dn-events-extensions:event-trigger-component-string "SZTP Client";
    dn-events-extensions:event-group "Management";
    leaf server-address {
      type string;
      description
        "Address of the SZTP bootstrap server";
    }
    leaf port {
      type uint16;
      description
        "Port of the SZTP bootstrap server";
    }
    leaf error-message {
      type string;
      description
        "Error description";
    }
  }

  notification SZTP_FLOW_COMPLETED {
    description
      "The SZTP provisioning flow has completed successfully.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "SZTP flow completed successfully from onboarding information recieved from {server-address}:{port}";
    dn-events-extensions:event-corrective-action-string "No corrective action required.";
