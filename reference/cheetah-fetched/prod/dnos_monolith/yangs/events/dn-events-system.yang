    description
      "The list of restricted users for the Telnet server was configured/updated.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "List of restricted users for Telnet server was configured/updated";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
  }

  notification PLATFORM_I2C_BUS_FAILED {
    description
      "The platform's I2C bus has failed. The system ports cannot be accessed.";
    dn-events-extensions:event-severity-level "Critical";
    dn-events-extensions:event-message-string "System detected I2C bus failure on {node-type} {node-id} port {port-id}. Detailed information: {details}";
    dn-events-extensions:event-corrective-action-string "Resetting i2c bus and isolating affected port. Please remove (replace) the problematic module.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Platform";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf port-id {
      type string;
      description
        "Port ID";
    }
    leaf details {
      type string;
      description
        "Details of specific problematic module";
    }
  }

  notification PLATFORM_I2C_BUS_RECOVERY_PROCEDURE_ACTIVATED {
    description
      "The platform's I2C bus recovery procedure was activated.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "System I2C bus recovery procedure activated on {node-type} {node-id} due to {port-id} I2C bus failure.";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Platform";
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf port-id {
      type string;
      description
        "Port ID";
    }
  }

  notification PLATFORM_THERMAL_SHUTDOWN_AUTO_POWER_UP_MODE_CHANGE_FAILED {
    description
      "The platform's BMC thermal shutdown auto-restart mode change has failed. ";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Failure setting the mode of automatic platform restart after thermal shutdown to {state} on {node-type} {node-id}. Reason: {reason}";
    dn-events-extensions:event-corrective-action-string "Verify that the configuration change is supported by the platform's BMC.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Platform";
    leaf state {
      type enumeration {
        enum disabled;
        enum enabled;
      }
      description
        "Platform's BMC automatic power up after thermal shutdown mode";
    }
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf port-id {
      type string;
      description
        "Port ID";
    }
    leaf reason {
      type string;
      description
        "The reason for failing to set the BMC mode of automatic power up after thermal shutdown";
    }
  }

  // L2VPN events

  notification PSEUDOWIRE_DOWN {
    description
      "The referenced Pseudowire connection changed to a 'down' state and cannot be used to forward traffic.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Pseudowire to address {neighbor-address}, ID {pw-id}, state is {pw-new-state}, reason: {down-reason}. Pseudowire part of {service-type} {service-name}";
    dn-events-extensions:event-corrective-action-string "Verify the configuration settings, AC state, and alignment with the Pseudowire remote-end settings.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf neighbor-address {
      description
        "PW remote-end address";
      type string;
    }
    leaf pw-id {
      description
        "PW configured identifier";
      type uint32;
    }
    leaf pw-new-state {
      description
        "PW new state, either Down or Admin-Down";
      type enumeration {
        enum Down;
        enum Admin-Down;
      }
    }
    leaf down-reason {
      description
        "String reason of why PW change to Down state";
      type string;
    }
    leaf service-type {
      description
        "Type of L2VPN service this PW belongs to";
      type enumeration {
        enum VPWS;
        enum VPLS;
        enum PWHE;
      }
    }
    leaf service-name {
      description
        "Name of L2VPN service this PW belongs to";
      type string;
    }
  }

  notification PSEUDOWIRE_UP {
    description
      "The referenced Pseudowire connection changed to an 'up' state and can be used to forward traffic.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Pseudowire to address {neighbor-address}, ID {pw-id}, state is Up. Pseudowire part of {service-type} {service-name}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf neighbor-address {
      description
        "PW remote-end address";
      type string;
    }
    leaf pw-id {
      description
        "PW configured identifier";
      type uint32;
    }
    leaf service-type {
      description
        "Type of L2VPN service this PW belongs to";
      type enumeration {
        enum VPWS;
        enum VPLS;
        enum PWHE;
      }
    }
    leaf service-name {
      description
        "Name of L2VPN service this PW belongs to";
      type string;
    }
  }

  notification EVPN_VPWS_SERVICE_NOT_ESTABLISHED {
    description
      "The referenced EVPN-VPWS service changed to a 'down' state and cannot be used to forward traffic.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The EVPN-VPWS service {service-name} - Local-ID {local-vpws-service-id}, Remote-ID {remote-vpws-service-id} state is {pw-new-state}.";
    dn-events-extensions:event-corrective-action-string "Verify the configuration settings, AC state, and alignment with the Pseudowire remote-end settings.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf service-name {
      description
        "Name of L2VPN service this PW belongs to";
      type string;
    }
    leaf local-vpws-service-id {
      description
        "PW configured identifier";
      type uint32;
    }
    leaf remote-vpws-service-id {
      description
        "PW configured identifier";
      type uint32;
    }
    leaf pw-new-state {
      description
        "PW new state, either Down or Admin-Down";
      type enumeration {
        enum Down;
        enum Admin-Down;
      }
    }
  }

  notification EVPN_VPWS_SERVICE_ESTABLISHED {
    description
      "The referenced EVPN-VPWS service changed to an 'up' state and can be used to forward traffic.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The EVPN-VPWS service {service-name} - Local-ID {local-vpws-service-id}, Remote-ID {remote-vpws-service-id} state is UP.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf service-name {
      description
        "Name of L2VPN service this PW belongs to";
      type string;
    }
    leaf local-vpws-service-id {
      description
        "PW configured identifier";
      type uint32;
    }
    leaf remote-vpws-service-id {
      description
        "PW configured identifier";
      type uint32;
    }
  }

  // EVPN-VPWS-FXC

  notification EVPN_VPWS_FXC_SUB_SERVICE_NOT_ESTABLISHED {
    description
      "The referenced EVPN-VPWS-FXC sub-service changed to a 'down' state and cannot be used to forward traffic.";
