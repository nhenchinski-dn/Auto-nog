      type string;
      description
        "The commit originator node type";
    }
    leaf remote-node-id {
      type uint16;
      description
        "The commit originator Node ID";
    }
  }

  notification TRANSACTION_REMOTE_AGENT_FAILED {
    description
      "The synced transaction from remote node wasn't successfully applied by the agent.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Remote commit failed to be executed on node {node-type}, id {node-id}, by the following agent {agent-name}, reason: {reason}";
    dn-events-extensions:event-corrective-action-string "In case of failure, check for the agent logs";
    dn-events-extensions:event-trigger-component-string "Operational-infra";
