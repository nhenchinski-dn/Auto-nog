    }
  }

  // Multihoming

  notification MULTIHOMING_ETHERNET_SEGMENT_CONFIGURATION_MISMATCH_DETECTED {
    description
      "The referenced service that is configured with a multihomed AC has detected a configuration mismatch with a Peer PE.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The service {service-name} with multihomed interface {interface-name} has detected a mismatch, mismatch reason: {mismatch-reason} ";
    dn-events-extensions:event-corrective-action-string "Verify the local configuration settings, and align with the Peer PE settings.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
    leaf interface-name {
      type string;
      description
        "Multihomed interface name";
    }
    leaf mismatch-reason {
      description
        "String reason detailing the mismatch";
      type string;
    }
  }

  notification MULTIHOMING_ETHERNET_SEGMENT_CONFIGURATION_MISMATCH_CLEARED {
    description
      "The referenced service has detected the clearance of the configuration mismatch.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The service {service-name} with multihomed interface {interface-name} has cleared the mismatch";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
    leaf interface-name {
      type string;
      description
        "Multihomed interface name";
    }
  }

  notification MULTIHOMING_ETHERNET_SEGMENT_LACP_ESI_CONFLICT_DETECTED {
    description
      "A LACP type ESI conflict has been detected on the referenced multihomed AC bundles - multiple CEs with same system-id+port-key.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The ESI {esi} on multihomed {bundle-1-name} is identical to that on {bundle-2-name} ";
    dn-events-extensions:event-corrective-action-string "Verify the CE LACP configuration, or set the ESI using type arbitrary";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf esi {
      description
        "The ESI value - generated from the received CE system-id and port-key";
      type string;
    }
    leaf bundle-1-name {
      type string;
      description
        "Multihomed bundle name";
    }
    leaf bundle-2-name {
      type string;
      description
        "Multihomed bundle name";
    }
  }

  notification MULTIHOMING_ETHERNET_SEGMENT_LACP_ESI_CONFLICT_CLEARED {
    description
      "The LACP type ESI conflict has been cleared.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "There is no longer a conflict for the bundle {bundle-name}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf bundle-name {
      type string;
      description
        "Multihomed bundle name";
    }
  }

  // Next-Hop Resources events ( FEC, ECMP amd SuperFEC resources events)

  notification NEXT_HOP_THRESHOLD_EXCEEDED {
    description
      "The system threshold for a next-hop resource has been crossed.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "NCP {ncp-id} reports that the number of {resource-name} in use has crossed the system threshold {threshold}% of the limit ({limit}), the current number of elements is ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "fib-manager";
    leaf ncp-id {
      type uint8;
      description
        "NCP id";
    }
    leaf resource-name {
      description
        "Next-Hop Resource";
      type enumeration {
        enum NEIGHBOR;
        enum NEXT_HOP_LEVEL_1_ELEMENTS;
        enum NEXT_HOP_LEVEL_2_ELEMENTS;
        enum NEXT_HOP_LEVEL_3_ELEMENTS;
        enum NEXT_HOP_PROTECTION_ELEMENTS;
        enum ECMP_NEXT_HOP_GROUPS;
        enum DESTINATION_PE;
        enum ASBR_LSP;
      }
    }
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint32;
      description
        "Current number of the next-hop resource that are in use";
    }
    leaf limit {
      type uint32;
      description
        "The allocated number (maximum value) of the next-hop resource";
    }
  }

  notification NEXT_HOP_THRESHOLD_CLEARED {
    description
      "The next-hop resource is now below the threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "NCP {ncp-id} reports that the number of {resource-name} in use is below the threshold {threshold}% of the limit ({limit}), the current number of elements is ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "fib-manager";
    leaf ncp-id {
      type uint8;
      description
        "NCP id";
    }
    leaf resource-name {
      description
        "Next-Hop Resource";
      type enumeration {
        enum NEIGHBOR;
        enum NEXT_HOP_LEVEL_1_ELEMENTS;
        enum NEXT_HOP_LEVEL_2_ELEMENTS;
        enum NEXT_HOP_LEVEL_3_ELEMENTS;
        enum NEXT_HOP_PROTECTION_ELEMENTS;
        enum ECMP_NEXT_HOP_GROUPS;
        enum DESTINATION_PE;
        enum ASBR_LSP;
      }
    }
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint32;
      description
        "Current number of the next-hop resource that are in use";
    }
    leaf limit {
      type uint32;
      description
        "The allocated number (maximum value) of the next-hop resource";
    }
  }

  // MAC Table events ( MAC_Table Threshold Exceeded and Total MAC Table Threshold exceeded )

  notification MAC_TABLE_THRESHOLD_EXCEEDED {
    description
      "The MAC Table Limit Threshold has been crossed.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "The number of MAC Table entries in use for the Service {name} has crossed the 90% threshold of the limit ({limit}), the current number of entries is ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf name {
      type string;
      description
        "The name of the service instance";
    }
    leaf limit {
      type uint32;
      description
        "The configured MAC Table limit";
    }
    leaf numeric-value {
      type uint32;
      description
        "Current number of entries in the MAC Table of this service instance";
    }
  }

  notification MAC_TABLE_THRESHOLD_CLEARED {
    description
      "The number of MAC Table Entries is below the Threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The number of MAC Table entries in use by the Service {name} has dropped below the 85% threshold of the limit ({limit}), the current number of entries is ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf name {
      type string;
      description
        "The name of the service instance";
    }
    leaf limit {
      type uint32;
      description
        "The configured MAC Table limit";
    }
    leaf numeric-value {
      type uint32;
      description
        "Current number of entries in the MAC Table of this service instance";
    }
  }

  notification TOTAL_MAC_TABLE_THRESHOLD_EXCEEDED {
    description
      "The MAC Table Limit Threshold has been crossed.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "The total number of MAC Table entries in use for all Services has crossed the 90% threshold of the limit ({limit}), the current number of entries is ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf limit {
      type uint32;
      description
        "The Total MAC Table limit";
    }
    leaf numeric-value {
      type uint32;
      description
        "Current number of MAC Table entries";
    }
  }

  notification TOTAL_MAC_TABLE_THRESHOLD_CLEARED {
    description
      "The number of MAC Table Entries is below the Threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The total number of MAC Table entries in use by all the Services has dropped below the 85% threshold of the limit ({limit}), the current number of entries is ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf limit {
      type uint32;
      description
        "The configured MAC Table limit";
    }
    leaf numeric-value {
      type uint32;
      description
        "Current number of MAC Table entries";
    }
  }

  notification L2_MAC_MOBILITY_STICKY_MAC_COLLISION {
    description
      "A collision has occurred on a sticky MAC address.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "A collision has occurred on sticky MAC {mac-address} associated with service {service-name}.";
    dn-events-extensions:event-corrective-action-string "Check configuration, check for layer-2 network loops, check BGP show for this MAC address";
    dn-events-extensions:event-trigger-component-string "RIB-manager";
    dn-events-extensions:event-group "L2VPN";
    leaf mac-address {
      type string;
      description
        "Sticky MAC address that has the collision.";
    }
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
  }

  notification IP_MOBILITY_STICKY_MAC_COLLISION {
    description
      "A collision has occurred for an IP address on two different sticky MAC addresses.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "A collision has occurred for IP address {ip-address} on local sticky MAC {local-mac-address} associated with service {service-name}.";
    dn-events-extensions:event-corrective-action-string "Check configuration";
    dn-events-extensions:event-trigger-component-string "Routing";
    dn-events-extensions:event-group "L2VPN";
    leaf ip-address {
      type string;
      description
        "IP address that has the collision.";
    }
    leaf local-mac-address {
      type string;
      description
        "Local sticky MAC address that is associated to IP address.";
    }
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
  }

  notification IP_MOBILITY_STICKY_MAC_COLLISION_WITH_NON_STICKY_LOCAL {
    description
      "A collision has occurred for an IP address on sticky MAC address and local non-sticky MAC address.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "A collision has occurred for IP address {ip-address} on both sticky MAC-1 {local-mac-address} and associated with service {service-name}.";
    dn-events-extensions:event-corrective-action-string "Check configuration";
    dn-events-extensions:event-trigger-component-string "Routing";
    dn-events-extensions:event-group "L2VPN";
    leaf ip-address {
      type string;
      description
        "IP address that has the collision.";
    }
    leaf local-mac-address {
      type string;
      description
        "Local non-sticky MAC address that is associated to IP address.";
    }
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
  }

  notification L2_REMOTE_DEFAULT_GATEWAY_LOCAL_STICKY_MAC_COLLISION {
    description
      "A collision has occurred on a MAC address - remote received with default gateway ext community while local configured as sticky";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "A collision has occurred on a local sticky MAC {mac-address} while remote received with default-gateway extended community associated with service {service-name}.";
    dn-events-extensions:event-corrective-action-string "Check configuration, check for layer-2 network loops, check BGP show for this MAC address";
    dn-events-extensions:event-trigger-component-string "RIB-manager";
    dn-events-extensions:event-group "L2VPN";
    leaf mac-address {
      type string;
      description
        "Sticky local MAC address while remote is default-gateway that has the collision.";
    }
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
  }

  notification L2_MAC_MOBILITY_MAC_ADDRESS_SUPPRESSED {
    description
      "A MAC address has exceeded the number of allowed move events and has been suppressed";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The MAC {mac-address} received in service {service-name} has been suppressed, having moved {mac-move-threshold} times in {loop-detection-window-period} seconds period.";
    dn-events-extensions:event-corrective-action-string "Check configuration, check for layer-2 network loops";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "L2VPN";
    leaf mac-address {
      type string;
      description
        "MAC address that has been suppressed.";
    }
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
    leaf loop-detection-window-period {
      type uint16 {
        range "1..600";
      }
      description
        "Loop Detection Window Period.";
    }
    leaf mac-move-threshold {
      type uint8 {
        range "2..30";
      }
      description
        "Number of allowed Moves within the Loop Detection Window Period";
    }
  }

  notification L2_MAC_MOBILITY_MAC_ADDRESS_PERMANENTLY_SUPPRESSED {
    description
      "A MAC address has exceeded the number of allowed move events and has been permanently suppressed";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The MAC {mac-address} received in service {service-name} has been permanently suppressed, having crossed the restore-cycles {restore-cycles} limit.";
    dn-events-extensions:event-corrective-action-string "Check configuration, check for layer-2 network loops";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "L2VPN";
    leaf mac-address {
      type string;
      description
        "MAC address that has been permanently suppressed.";
    }
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
    leaf restore-cycles {
      type uint8 {
        range "1..10";
      }
      description
        "The number of restore-cycles allowed before permanantly suppressing the MAC address.";
    }
  }

  notification L2_MAC_MOBILITY_MAC_ADDRESS_RELEASED {
    description
      "A MAC address that was suppressed has now been released";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The MAC {mac-address} received in service {service-name} that was suppressed, has been released due to {release-reason}.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "L2VPN";
    leaf mac-address {
      type string;
      description
        "MAC address that was suppressed.";
    }
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
    leaf release-reason {
      type string;
      description
        "Release Reason";
    }
  }

  notification IP_MOBILITY_IP_ADDRESS_SUPPRESSED {
    description
      "An IP address has exceeded the number of allowed move events and has been suppressed";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The IP {ip-address} received in service {service-name} has been suppressed, having moved {ip-move-threshold} times in {ip-loop-detection-window-period} seconds period.";
