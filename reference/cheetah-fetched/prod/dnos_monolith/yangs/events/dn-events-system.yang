  notification NCP_ID_ASSIGNED {
    description
      "The Element Manager released its ID from LLDP and assigned an ID to the NCP node.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "NCP {ncp-id} serial number {node-serial-number} ID is assigned. Identified neighbor interfaces: {first-neighbor-interface-name}, {second-neighbor-interface-name}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Element Manager";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf node-serial-number {
      type string;
      description
        "NCP node serial number";
    }
    leaf first-neighbor-interface-name {
      type string;
      description
        "NCM interface name";
    }
    leaf second-neighbor-interface-name {
      type string;
      description
        "NCM interface name";
    }
  }

  notification NCP_ID_COLLISION_STOP {
    description
      "During startup the Element Manager could not determine which ID to assign due to a conflict. This NCP node has stopped at the state, initializing.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "NCP serial number {node-serial-number} has stopped initializing due to connection conflict. Identified neighbor interfaces: {first-neighbor-interface-name}, {second-neighbor-interface-name}";
    dn-events-extensions:event-corrective-action-string "Fix NCP to NCM physical connectivity according the connectivity matrix.";
    dn-events-extensions:event-trigger-component-string "Element Manager";
    dn-events-extensions:event-group "System";
    leaf node-serial-number {
      type string;
      description
        "NCP node serial number";
    }
    leaf first-neighbor-interface-name {
      type string;
      description
        "NCM interface name";
    }
    leaf second-neighbor-interface-name {
      type string;
      description
        "NCM interface name";
    }
  }

  notification NCP_ID_COLLISION_RESET {
    description
      "After the Element Manager has assigned an ID to an NCP node a user connected the control interfaces causing an ID conflict. This will cause the node to reset.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "NCP ID {ncp-id} serial number {node-serial-number} will reset due to connectivity change. Identified neighbor interfaces: {first-neighbor-interface-name}, {second-neighbor-interface-name}";
    dn-events-extensions:event-corrective-action-string "Fix NCP to NCM physical connectivity according the connectivity matrix.";
    dn-events-extensions:event-trigger-component-string "Element Manager";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID before conflict";
    }
    leaf node-serial-number {
      type string;
      description
        "NCP node serial number";
    }
    leaf first-neighbor-interface-name {
      type string;
      description
        "NCM interface name";
    }
    leaf second-neighbor-interface-name {
      type string;
      description
        "NCM interface name";
    }
  }

  notification NCF_STATE_CHANGE {
    description
      "The NCF has changed its state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "NCF {ncf-id} state has changed from {old-state} to {new-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "System";
    dn-events-extensions:event-snmp-trap-name "dnNcfOperStatusChange";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.4.1.49739.2.6.0.5";
    dn-events-extensions:event-snmp-trap-vars "dnNcfOperStatus.CONVERTIDX(ncfID,{ncf-id}) CONVERT ncfOpStC {new-state}; dnNcfOperStatusLastChangeTime.CONVERTIDX(ncfID,{ncf-id}) {sys-uptime}";
    leaf old-state {
      type string;
      description
        "NCF old state";
    }
    leaf new-state {
      type string;
      description
        "NCF new state";
    }
    leaf ncf-id {
      type uint16;
      description
        "NCF ID";
    }
    leaf sys-uptime {
      type uint32;
      description
        "sysUpTime value at the moment of the state change";
    }
  }

  notification NCF_UPGRADE_STATE_CHANGE {
    description
      "The NCF is currently in baseos/firmware upgrade and it has changed its state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "NCF with serial number {ncf-serial-number} has changed it upgrade state from {old-state} to {new-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "System";
    leaf old-state {
      type string;
