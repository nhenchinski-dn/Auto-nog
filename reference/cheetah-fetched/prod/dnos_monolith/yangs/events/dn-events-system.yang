    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "EEM";
    dn-events-extensions:event-group "Management";
    leaf policy-name {
      type string;
      description
        "The name of the policy.";
    }
    leaf policy-type {
      type string;
      description
        "The type of the policy.";
    }
    leaf reason {
      type string;
      description
        "The reason why policy inactive
         (e.g. policy infrastructure not ready, memory limit reached, other)";
    }
  }

