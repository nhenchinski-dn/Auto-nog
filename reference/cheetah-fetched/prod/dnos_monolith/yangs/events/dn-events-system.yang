  // System diagnostics events

  notification SYSTEM_DIAG_PUNT_DATAPATH_THRESHOLD_REACHED {
    description
      "System diagnostics test failed, number of executed tests passed the failure threshold.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Test failed on NCP {ncp-id}, failure threshold {failure-threshold} was exceeded";
    dn-events-extensions:event-corrective-action-string "check the logs for PUNT_DATAPATH keyword.";
    dn-events-extensions:event-trigger-component-string "Diagnostics-manager";
    dn-events-extensions:event-group "Diagnostics";
    leaf ncp-id {
      type uint8;
      description
        "NCP id";
    }
    leaf failure-threshold {
      type uint8;
      description
        "The number of times a test can fail consecutively and it won't be considered as test failure";
    }
  }

  notification SYSTEM_DIAG_PUNT_DATAPATH_THRESHOLD_CLEARED {
    description
      "System diagnostics test now is successfully running.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of lost diagnostics packets is below the consecutive threshold {failure-threshold} on NCP {ncp-id}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Diagnostics-manager";
    dn-events-extensions:event-group "Diagnostics";
    leaf ncp-id {
      type uint8;
      description
        "NCP id";
    }
    leaf failure-threshold {
      type uint8;
      description
        "threshold number of consecutive failed packets for which system events will be generated";
    }
  }

