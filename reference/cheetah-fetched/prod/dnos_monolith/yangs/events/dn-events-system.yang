      "<p>Terminate active FTP sessions to the system:</p>
       <ol>
       <li>Run command 'show system ftp sessions' to view the existing FTP sessions.</li>
       <li>Select a session-id for the connection you want to terminate.</li>
       <li>Run the command 'clear ftp session [session-id]'.</li>
       </ol>";
    dn-events-extensions:event-trigger-component-string "Management";
    dn-events-extensions:event-group "Management";
    leaf max-sessions {
      type uint8;
