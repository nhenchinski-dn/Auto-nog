      type uint16;
      description
        "Current number of RSVP tunnels";
    }
    leaf limit {
      type uint16;
      description
        "The accumulated tunnel scale limit (head + transit + tail)";
    }
  }

  notification RSVP_MAXIMUM_TUNNELS_THRESHOLD_CLEARED {
    description
      "The number of concurrent RSVP tunnels is below the configured maximum threshold of LSP tunnels.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of RSVP tunnels is below the threshold {threshold}% of the limit ({limit}), the number of LSP tunnels are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "RSVP";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of RSVP tunnels";
    }
    leaf limit {
      type uint16;
      description
        "The accumulated tunnel scale limit (head + transit + tail)";
    }
  }

  notification RSVP_MAXIMUM_HEAD_TUNNELS_LIMIT_REACHED {
    description
      "The number of concurrent RSVP head tunnels has reached the maximum number of tunnels.";
