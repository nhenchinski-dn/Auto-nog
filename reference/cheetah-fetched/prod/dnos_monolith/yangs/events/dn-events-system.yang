  //Telnet events

  notification TELNET_SESSION_LOGIN_DENIED {
    description
      "Telnet has rejected a new session to the system due to client-list configuration.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Telnet login attempt from remote host {remote-host} has been rejected due to client-list configuration";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
  }

  notification TELNET_SESSION_LIMIT_CLEARED {
    description
      "The number of concurrent Telnet sessions to the system is below the configured maximum number of connections.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of Telnet sessions is below the configured maximum ({max-sessions})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf max-sessions {
      type uint8;
      description
        "Maximum number of sessions";
    }
  }

  notification TELNET_SESSION_LIMIT_REACHED {
    description
      "The number of concurrent Telnet sessions to the system has reached the maximum number of sessions. No new Telnet sessions can be established.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of Telnet sessions has reached the configured maximum ({max-sessions})";
    dn-events-extensions:event-corrective-action-string
      "<p>Terminate active Telnet sessions to the system:</p>
       <ol>
       <li>Run command 'show system telnet sessions' to view the existing Telnet sessions.</li>
       <li>Select a session-id for the connection you want to terminate.</li>
       <li>Run the command 'clear telnet session [session-id]'.</li>
       </ol>";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf max-sessions {
      type uint8;
      description
        "Maximum number of sessions";
    }
  }

  notification TELNET_SESSION_CLOSED {
    description
      "The user indicated closed the Telnet session via the remote host.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "user {user-name} closed the Telnet session {session-id} (remote host {remote-host})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
    leaf session-id {
      type uint16;
      description
        "Session id";
    }
  }

  notification TELNET_SESSION_LOGIN {
    description
      "The user and remote host indicated has logged into the system using Telnet.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "user {user-name} has logged in using Telnet (remote host {remote-host})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
  }

  notification TELNET_SESSION_TERMINATED {
    description
      "The Telnet session to system was terminated by the user indicated using the command 'clear telnet session'.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Telnet session {session-id} (remote host {remote-host}) terminated by user {user-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
    leaf session-id {
      type uint16;
      description
        "Session id";
    }
  }

  notification TELNET_SESSION_TIMEOUT {
    description
      "The Telnet session to system was terminated by the system due to session inactivity.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Telnet session {session-id} (remote host {remote-host}) was terminated due to timeout";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
    leaf session-id {
      type uint16;
      description
        "Session id";
    }
  }

  notification TELNET_MAXIMUM_SESSION_LIMIT_REJECT {
    description
      "A new Telnet session to the system was rejected since the number of concurrent Telnet sessions has reached the configured limit.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "A new Telnet session of user {user-name} from remote host {remote-host} has been rejected since the number of concurrent active Telnet sessions has reached the configured limit of {max-sessions}";
    dn-events-extensions:event-corrective-action-string
      "<p>Terminate some active Telnet sessions to the system:</p>
       <ol>
       <li>Run command 'show system telnet sessions' to view the existing telnet sessions.</li>
       <li>Select a session-id for the connection you want to terminate.</li>
       <li>Run the command 'clear telnet session [session-id]'.</li>
       </ol>";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf max-sessions {
      type uint8;
      description
        "Maximum number of sessions";
    }
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
  }

  notification TELNET_SESSION_LOGIN_LOCKED {
    description
      "A new Telnet session by the user indicated was rejected due to maximum number of login attempts. The user must wait for the holdoff period.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Maximum number of login attempts ({login-attempts}) was reached by user {user-name}";
    dn-events-extensions:event-corrective-action-string "Wait for holdoff time defined by 'system login session-holdoff'.";
