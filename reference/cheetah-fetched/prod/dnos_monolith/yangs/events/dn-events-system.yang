// validate-yangs ignore-lib
module dn-events-system {
  namespace "http://drivenets.com/ns/yang/dn-events-system";
  prefix dn-events-system;

  import dn-events-extensions {
    prefix dn-events-extensions;
  }

  organization
    "DRIVENETS LTD";
  contact
    "DRIVENETS Customer Service <mailto:support@drivenets.com>";
  description
    "This module contains a collection of YANG definitions for
     managing DRIVENETS Interface events";

  revision 2018-06-20 {
    description
      "Initial revision";
  }

  typedef ieeefloat32 {
    type binary {
      length "4";
    }
    description
      "An IEEE 32-bit floating point number. The format of this number is of the form:
       1-bit  sign
       8-bit  exponent
       23-bit fraction
       The floating point value is calculated using:
       (-1)**S * 2**(Exponent-127) * (1+Fraction)";
  }

  // NCE events

  notification NCP_STATE_CHANGE {
    description
      "The NCP has changed its state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "NCP {ncp-id} state has changed from {old-state} to {new-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Cluster Manager";
    dn-events-extensions:event-group "System";
    dn-events-extensions:event-snmp-trap-name "dnNcpOperStatusChange";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.4.1.49739.2.6.0.4";
    dn-events-extensions:event-snmp-trap-vars "dnNcpOperStatus.CONVERTIDX(ncpID,{ncp-id}) CONVERT ncpOpStC {new-state}; dnNcpOperStatusLastChangeTime.CONVERTIDX(ncpID,{ncp-id}) {sys-uptime}";
    leaf old-state {
      type string;
      description
        "NCP old state";
    }
    leaf new-state {
      type string;
      description
        "NCP new state";
    }
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf sys-uptime {
      type uint32;
      description
        "sysUpTime value at the moment of the state change";
    }
  }

  notification NCP_UPGRADE_STATE_CHANGE {
    description
      "The NCP is currently in baseos/firmware upgrade and it has changed its state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "NCP with serial number {ncp-serial-number} has changed it upgrade state from {old-state} to {new-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Cluster Manager";
    dn-events-extensions:event-group "System";
    leaf old-state {
      type string;
      description
        "NCP old state and sub-state";
    }
    leaf new-state {
      type string;
      description
        "NCP new state and sub-state";
    }
    leaf ncp-serial-number {
      type string;
      description
        "NCP serial nunmber";
    }
  }

  notification NCP_CONFIG {
    description
      "A user has updated the NCP configuration.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} has {action} NCP {ncp-id} model {model} configuration";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "System";
    leaf action {
      type string;
      description
        "NCP configuration action (added/removed)";
    }
    leaf model {
      type string;
      description
        "NCP configured model";
    }
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf user-name {
      type string;
      description
        "System user-name";
    }
  }

  notification NCP_STATE_CHANGE_FAILED {
    description
      "The NCP failed due to an internal error, misconfiguration, or the NCP was reset.";
    dn-events-extensions:event-severity-level "Critical";
    dn-events-extensions:event-message-string "NCP {ncp-id} state has changed from {old-state} to {new-state}";
    dn-events-extensions:event-corrective-action-string "Contact Customer Support.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "System";
    dn-events-extensions:event-snmp-trap-name "dnNcpOperStatusChange";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.4.1.49739.2.6.0.4";
    dn-events-extensions:event-snmp-trap-vars "dnNcpOperStatus.CONVERTIDX(ncpID,{ncp-id}) CONVERT ncpOpStC {new-state}; dnNcpOperStatusLastChangeTime.CONVERTIDX(ncpID,{ncp-id}) {sys-uptime}";
    leaf old-state {
      type string;
      description
        "NCP old state";
    }
    leaf new-state {
      type string;
      description
        "NCP new state";
    }
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf sys-uptime {
      type uint32;
      description
        "sysUpTime value at the moment of the state change";
    }
  }

  notification NCP_STATE_CHANGE_DISCONNECTED {
    description
      "The NCP is disconnected.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "NCP {ncp-id} state has changed from {old-state} to {new-state}";
    dn-events-extensions:event-corrective-action-string "Contact Customer Support.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "System";
    dn-events-extensions:event-snmp-trap-name "dnNcpOperStatusChange";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.4.1.49739.2.6.0.4";
    dn-events-extensions:event-snmp-trap-vars "dnNcpOperStatus.CONVERTIDX(ncpID,{ncp-id}) CONVERT ncpOpStC {new-state}; dnNcpOperStatusLastChangeTime.CONVERTIDX(ncpID,{ncp-id}) {sys-uptime}";
    leaf old-state {
      type string;
      description
        "NCP old state";
    }
    leaf new-state {
      type string;
      description
        "NCP new state";
    }
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf sys-uptime {
      type uint32;
      description
        "sysUpTime value at the moment of the state change";
    }
  }

  notification NCP_ADMIN_STATE_CONFIG {
