  // Multicast Events

  notification MULTICAST_MAXIMUM_NCP_SG_REPLICATIONS_LIMIT_REACHED {
    description
      "The number of multicast (S,G) replications has reached the configured system limit per NCP.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of multicast (S,G) replications on NCP {ncp-id} has reached the system limit of {limit} replications per NCP";
    dn-events-extensions:event-corrective-action-string "Review the multicast configuration in the network.";
