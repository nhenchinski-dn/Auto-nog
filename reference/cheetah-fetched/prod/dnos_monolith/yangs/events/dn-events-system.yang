    }
    leaf node-id {
      type string;
      description
        "Node ID (0-191)";
    }
  }

  // Flowspec events

  notification BGP_FLOWSPEC_UNSUPPORTED_RULE {
    description
      "Indication that a given flowspec rule cannot be installed";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "BGP flowspec {address-family} rule cannot be applied due to {reason}. Rule NLRI: {nlri}, Actions: {actions}";
    dn-events-extensions:event-corrective-action-string "Verify rule attributes and overall flowspec scale";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "BGP";
    leaf address-family {
      type string;
      description
        "flowspec address family, either ipv4 or ipv6";
    }
    leaf reason {
      type string;
      description
        "reason rule cannot be supported";
    }
    leaf nlri {
      type string;
      description
        "full flowspec rule nlri";
    }
    leaf actions {
      type string;
      description
        "string of flowspec rule action communities, can have more than a single action";
    }
  }

  // Flowspec Local events

  notification FLOWSPEC_LOCAL_UNSUPPORTED_RULE {
    description
      "Indication that a given flowspec local rule cannot be installed";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Flowspec Local {address-family} rule cannot be applied due to {reason}. Rule NLRI: {nlri}, Actions: {actions}";
    dn-events-extensions:event-corrective-action-string "Verify rule attributes and overall flowspec scale";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "System";
    leaf address-family {
      type string;
      description
        "flowspec local address family, either ipv4 or ipv6";
    }
    leaf reason {
      type string;
      description
        "reason rule cannot be supported";
    }
    leaf nlri {
      type string;
      description
        "full flowspec rule nlri";
    }
    leaf actions {
      type string;
      description
        "string of flowspec local rule action communities, can have more than a single action";
    }
  }

  // BGP redistribute connected and imported to vrf events

  notification BGP_REDISTRIBUTE_CONNECTED_AND_IMPORT_TO_VRF_ROUTE_NOT_INSTALLED {
    description
      "A BGP route learned from an Access Connection interface cannot be redistributed  and imported into a VRF due to a lack of resources.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Route(s) cannot be redistributed and imported into VRF {vrf-name} in ncp {ncp-id} due to lack of resources.";
    dn-events-extensions:event-corrective-action-string "Verify that the BGP redistribute connected rules and VRFs are correct.";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "System";
    leaf vrf-name {
      type string;
      description
        "Name of the VRF";
    }
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
  }

  notification BGP_REDISTRIBUTE_CONNECTED_AND_IMPORT_TO_VRF_ROUTE_NOT_INSTALLED_CLEARED {
    description
      "The routes that BGP learns from Access Connection interfaces and redistributes to the listed VRF can now be installed as resources have been freed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Resources freed - Route(s) can be redistributed and imported into VRF {vrf-name} in ncp {ncp-id}.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "System";
    leaf vrf-name {
      type string;
      description
        "Name of the VRF";
    }
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
  }

  // ospf notifications

  notification OSPF_NEIGHBOR_STATE_CHANGE {
    description
      "The OSPF neighbor adjacency state has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "OSPF instance {instance} router {router-id} adjacency status with neighbor {neighbor-address} on interface {if-name} changed to {neighbor-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ospf";
    dn-events-extensions:event-group "OSPF";
    dn-events-extensions:event-snmp-trap-name "ospfNbrStateChange";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.2.1.14.16.2.2";
    dn-events-extensions:event-snmp-trap-vars "ospfRouterId.0 {router-id} ; ospfNbrIpAddr.0 {neighbor-address} ; ospfNbrAddressLessIndex.0 {if-index} ; ospfNbrRtrId.0 {neighbor-router-id} ; ospfNbrState.0 {neighbor-state}";
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
    leaf router-id {
      type string;
      description
        "OSPF Router ID";
    }
    leaf neighbor-address {
      type string;
      description
        "Neighbor peer IP address";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf if-index {
      type uint32 {
        range "1..2147483647";
      }
      description
        "The identifier of this interface relevant to this notification";
    }
    leaf neighbor-router-id {
      type string;
      description
        "The OSPF neighbor Router ID";
    }
    leaf neighbor-state {
      type enumeration {
        enum down {
          value 1;
        }
        enum attempt {
          value 2;
        }
        enum init {
          value 3;
        }
        enum twoway {
          value 4;
        }
        enum exchangestart {
          value 5;
        }
        enum exchange {
          value 6;
        }
        enum loading {
          value 7;
        }
        enum full {
          value 8;
        }
      }
      description
        "The current state of the OSPF neighbor adjacency.";
    }
  }

  notification OSPF_INTERFACE_STATE_CHANGE {
    description
      "The OSPF intrerface state has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "OSPF instance {instance} interface {if-name} status changed to {ospf-if-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ospf";
    dn-events-extensions:event-group "OSPF";
    dn-events-extensions:event-snmp-trap-name "ospfIfStateChange";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.2.1.14.16.2.16";
    dn-events-extensions:event-snmp-trap-vars "ospfRouterId.0 {router-id} ; ospfIfIpAddress.0 {if-ip-address} ; ospfAddressLessIf.0 {if-index} ; ospfIfState.0 {ospf-if-state}";
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
    leaf router-id {
      type string;
      description
        "OSPF Router ID";
    }
    leaf if-ip-address {
      type string;
      description
        "OSPF Interface IP address";
    }
    leaf if-name {
      type string;
      description
        "OSPF Interface name";
    }
    leaf if-index {
      type uint32 {
        range "1..2147483647";
      }
      description
        "The identifier of this interface relevant to this notification";
    }
    leaf ospf-if-state {
      type enumeration {
        enum down {
          value 1;
        }
        enum loopback {
          value 2;
        }
        enum waiting {
          value 3;
        }
        enum point-to-point {
          value 4;
        }
        enum designated-router {
          value 5;
        }
        enum backup-designated-router {
          value 6;
        }
        enum other-designated-router {
          value 7;
        }
      }
      description
        "The current state of the OSPF interface.";
    }
  }

  notification OSPF_AUTHENTICATION_FAILED {
    description
      "OSPF failed to validate a received OSPF packet, either due to key mismatch or an authentication type conflict. The packet was dropped.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "OSPF instance {instance} received {ospf-packet-type} packet on interface {interface-name} from source {packet-src}. {ospf-packet-type} authentication failed due to {auth-failure-type}. Packet was dropped.";
    dn-events-extensions:event-corrective-action-string "Check that the password configuration is the same on both the local and remote system.";
    dn-events-extensions:event-trigger-component-string "OSPF";
    dn-events-extensions:event-group "OSPF";
    dn-events-extensions:event-snmp-trap-name "ospfIfAuthFailure";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.14.16.2.6";
    dn-events-extensions:event-snmp-trap-vars "ospfRouterId.0 {router-id} ; ospfIfIpAddress.0 {ospf-if-address} ; ospfAddressLessIf.0 {ospf-address-less-if} ; ospfPacketSrc.0 {packet-src} ; ospfConfigErrorType.0 {auth-failure-type} ; ospfPacketType.0 {ospf-packet-type}";
    leaf router-id {
      type string;
      description
        "The originator of the trap";
    }
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
    leaf ospf-packet-type {
      type enumeration {
        enum hello {
          value 1;
        }
        enum dbDescript {
          value 2;
        }
        enum lsReq {
          value 3;
        }
        enum lsUpdate {
          value 4;
        }
        enum lsAck {
          value 5;
        }
        enum nullPacket {
          value 6;
        }
      }
      description
        "OSPF packet type";
    }
    leaf interface-name {
      type string;
      description
        "local interface name";
    }
    leaf ospf-if-address {
      type string;
      description
        "The local ip address of this OSPF interface.";
    }
    leaf ospf-address-less-if {
      type uint32;
      description
        "For the purpose of easing the instancing of
         addressed and addressless interfaces; this
         variable takes the value 0 on interfaces with
         IP addresses and the corresponding value of
         ifIndex for interfaces having no IP address.";
    }
    leaf packet-src {
      description
        "The IP address of an inbound packet that cannot
         be identified by a neighbor instance";
      type string;
    }
    leaf auth-failure-type {
      type enumeration {
        enum authTypeMismatch {
          value 5;
        }
        enum authFailure {
          value 6;
        }
      }
      description
        "Potential types of authentication conflicts.";
    }
  }

  notification OSPF_MAX_AGE_LSA {
    description
      "One of the  link-state advertisements (LSA) in the router's link state database has aged to MaxAge.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "OSPF instance {instance} LS type {ls-type} with ID {ls-id} received from area {area-id} with Router-ID {org-router-id} has aged to MaxAge";
    dn-events-extensions:event-corrective-action-string "Check that originating router is operational.";
    dn-events-extensions:event-trigger-component-string "OSPF";
    dn-events-extensions:event-group "OSPF";
    dn-events-extensions:event-snmp-trap-name "ospfMaxAgeLsa";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.14.16.2.13";
    dn-events-extensions:event-snmp-trap-vars "ospfRouterId.0 {router-id} ; ospfLsdbAreaId.0 {area-id} ; ospfLsdbType.0 {ls-type} ; ospfLsdbLsid.0 {ls-id} ; ospfLsdbRouterId.0 {org-router-id}";
    leaf router-id {
      type string;
      description
        "The originator of the trap";
    }
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
    leaf ls-type {
      type enumeration {
        enum router-link {
          value 1;
        }
        enum network-link {
          value 2;
        }
        enum summary-link {
          value 3;
        }
        enum as-summary-link {
          value 4;
        }
        enum as-external-link {
          value 5;
        }
        enum multicast-link {
          value 6;
        }
        enum nssa-external-link {
          value 7;
        }
        enum area-opaque-link {
          value 10;
        }
      }
      description
        "The type of the link state advertisement.
         Each link state type has a separate advertisement
         format.
         Note: External link state advertisements are permitted
         for backward compatibility, but should be displayed
         in the ospfAsLsdbTable rather than here.";
    }
    leaf ls-id {
      type string;
      description
        "The Link State ID is an LS Type Specific field
         containing either a Router ID or an IP address;
         it identifies the piece of the routing domain
         that is being described by the advertisement.";
    }
    leaf area-id {
      type string;
      description
        "The 32-bit identifier of the area from which the LSA was received, 0.0.0.0 for AS Externals ";
    }
    leaf org-router-id {
      type string;
      description
        "The IP address that uniquely identifies the
         originating router in the Autonomous System.";
    }
  }

  notification OSPF_INVALID_RECEIVED_PACKET {
    description
      "A packet has been received on a non-virtual interface from a router whose configuration parameters conflict with this router's configuration parameters.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "OSPF instance {instance} received invalid {ospf-packet-type} packet on interface {interface-name} from source {packet-src}. Error type: {ospf-error-type}";
    dn-events-extensions:event-corrective-action-string "Check OSPF configuration on source system matches configuration on local system";
    dn-events-extensions:event-trigger-component-string "OSPF";
    dn-events-extensions:event-group "OSPF";
    dn-events-extensions:event-snmp-trap-name "ospfIfConfigError";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.14.16.2.4";
    dn-events-extensions:event-snmp-trap-vars "ospfRouterId.0 {router-id} ; ospfIfIpAddress.0 {ospf-if-address} ; ospfAddressLessIf.0 {ospf-address-less-if} ; ospfPacketSrc.0 {packet-src} ; ospfConfigErrorType.0 {ospf-error-type} ; ospfPacketType.0 {ospf-packet-type}";
    leaf router-id {
      type string;
      description
        "The originator of the trap";
    }
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
    leaf ospf-packet-type {
      type enumeration {
        enum hello {
          value 1;
        }
        enum dbDescript {
          value 2;
        }
        enum lsReq {
          value 3;
        }
        enum lsUpdate {
          value 4;
        }
        enum lsAck {
          value 5;
        }
        enum nullPacket {
          value 6;
        }
      }
      description
        "OSPF packet type";
    }
    leaf interface-name {
      type string;
      description
        "local interface name";
    }
    leaf ospf-if-address {
      type string;
      description
        "The local ip address of this OSPF interface.";
    }
    leaf ospf-address-less-if {
      type uint32;
      description
        "For the purpose of easing the instancing of
         addressed and addressless interfaces; this
         variable takes the value 0 on interfaces with
         IP addresses and the corresponding value of
         ifIndex for interfaces having no IP address.";
    }
    leaf packet-src {
      description
        "The IP address of an inbound packet that cannot
         be identified by a neighbor instance";
      type string;
    }
    leaf ospf-error-type {
      type enumeration {
        enum badVersion {
          value 1;
        }
        enum areaMismatch {
          value 2;
        }
        enum unknownNbmaNbr {
          value 3;
        }
        enum unknownVirtualNbr {
          value 4;
        }
        enum authTypeMismatch {
          value 5;
        }
        enum authFailure {
          value 6;
        }
        enum netMaskMismatch {
          value 7;
        }
        enum helloIntervalMismatch {
          value 8;
        }
        enum deadIntervalMismatch {
          value 9;
        }
        enum optionMismatch {
          value 10;
        }
        enum mtuMismatch {
          value 11;
        }
        enum duplicateRouterId {
          value 12;
        }
        enum noError {
          value 13;
        }
      }
      description
        "Potential types of configuration conflicts.";
    }
  }

  notification OSPF_TX_RETRANSMIT {
    description
      "An OSPF packet has been retransmitted on a non-virtual interface. All packets that may be retransmitted are associated with an LSDB entry.";
    dn-events-extensions:event-severity-level "Debug";
    dn-events-extensions:event-message-string "OSPF instance {instance} retransmitted an {ospf-packet-type} packet on interface {interface-name} to neighbor {neighbor-router-id}. Update includes LSA type {ls-type} with ID {ls-id} of originating router {org-router-id}";
    dn-events-extensions:event-corrective-action-string "Check the egress interface congestion state.";
    dn-events-extensions:event-trigger-component-string "OSPF";
    dn-events-extensions:event-group "OSPF";
    dn-events-extensions:event-snmp-trap-name "ospfTxReTransmit";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.14.16.2.10";
    dn-events-extensions:event-snmp-trap-vars "ospfRouterId.0 {router-id} ; ospfIfIpAddress.0 {ospf-if-address} ; ospfAddressLessIf.0 {ospf-address-less-if}; ospfNbrRtrId.0 {neighbor-router-id}; ospfPacketType.0 {ospf-packet-type} ; ospfLsdbType.0 {ls-type}; ospfLsdbLsid.0 {ls-id} ; ospfLsdbRouterId.0 {org-router-id}";
    leaf router-id {
      type string;
      description
        "The originator of the trap";
    }
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
    leaf ospf-packet-type {
      type enumeration {
        enum lsUpdate {
          value 4;
        }
      }
      description
        "OSPF packet type";
    }
    leaf interface-name {
      type string;
      description
        "local interface name";
    }
    leaf ospf-if-address {
      type string;
      description
        "The local ip address of this OSPF interface.";
    }
    leaf ospf-address-less-if {
      type uint32;
      description
        "For the purpose of easing the instancing of
         addressed and addressless interfaces; this
         variable takes the value 0 on interfaces with
         IP addresses and the corresponding value of
         ifIndex for interfaces having no IP address.";
    }
    leaf neighbor-router-id {
      type string;
      description
        "Neighbor router-id to whom LS update required to be sent";
    }
    leaf ls-type {
      type enumeration {
        enum router-link {
          value 1;
        }
        enum network-link {
          value 2;
        }
        enum summary-link {
          value 3;
        }
        enum as-summary-link {
          value 4;
        }
        enum as-external-link {
          value 5;
        }
        enum multicast-link {
          value 6;
        }
        enum nssa-external-link {
          value 7;
        }
        enum area-opaque-link {
          value 10;
        }
      }
      description
        "The type of the link state advertisement.
         Each link state type has a separate advertisement
         format.
         Note: External link state advertisements are permitted
         for backward compatibility, but should be displayed
         in the ospfAsLsdbTable rather than here.";
    }
    leaf ls-id {
      type string;
      description
        "The Link State ID is an LS Type Specific field
         containing either a Router ID or an IP address;
         it identifies the piece of the routing domain
         that is being described by the advertisement.";
    }
    leaf org-router-id {
      type string;
      description
        "The IP address that uniquely identifies the
         originating router in the Autonomous System.";
    }
  }

  notification OSPF_MAXIMUM_ADJACENCIES_LIMIT_REACHED {
    description
      "The number of OSPF adjacencies has reached the configured system limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of OSPF adjacencies has reached system limit of {limit}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ospf";
    dn-events-extensions:event-group "OSPF";
    leaf limit {
      type uint16;
      description
        "The accumulated OSPF adjacencies scale.";
    }
  }

  notification OSPF_MAXIMUM_ADJACENCIES_LIMIT_CLEARED {
    description
      "OSPF adjacencies have been removed, the number of OSPF adjacencies is below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of OSPF adjacencies is below the system limit of {limit}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ospf";
    dn-events-extensions:event-group "OSPF";
    leaf limit {
      type uint16;
      description
        "The accumulated OSPF adjacencies scale.";
    }
  }

  notification OSPF_MAXIMUM_ADJACENCIES_THRESHOLD_EXCEEDED {
    description
      "The number of OSPF adjacencies has crossed the system threshold.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Number of OSPF adjacencies has crossed the system threshold {threshold}% limit of {limit}, the number of OSPF adjacencies are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ospf";
    dn-events-extensions:event-group "OSPF";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of OSPF adjacencies";
    }
    leaf limit {
      type uint16;
      description
        "The accumulated OSPF adjacencies scale";
    }
  }

  notification OSPF_MAXIMUM_ADJACENCIES_THRESHOLD_CLEARED {
    description
      "The number of OSPF adjacencies is below the system threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of OSPF adjacencies is below the system threshold {threshold}% of the limit ({limit}), the current number of OSPF adjacencies are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ospf";
    dn-events-extensions:event-group "OSPF";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of OSPF adjacencies";
    }
    leaf limit {
      type uint16;
      description
        "The accumulated OSPF adjacencies scale.";
    }
  }

