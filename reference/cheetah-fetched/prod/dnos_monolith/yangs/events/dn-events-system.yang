        enum enabled;
        enum disabled;
      }
      description
        "Diffserv-te new admin-state";
    }
  }

  notification PCEP_SERVER_CONFIG {
    description
      "The PCEP server configuration has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} has {action} PCEP server {server-address} configuration";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
