    }
  }

  notification EVPN_MAC_IP_TABLE_THRESHOLD_CLEARED {
    description
      "MAC-IP Table entries have been removed, the number of MAC-IP entries is below the 85% threshold of the configured limit for this service instance.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The number of MAC-IP entries for this service instance {service-name} has dropped below the 85% threshold of the configured limit {limit}, the current number of entries is {numeric-value}.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf service-name {
      type string;
      description
        "The name of the service instance";
    }
    leaf limit {
      type uint32;
      description
        "The configured MAC-IP Table limit";
    }
    leaf numeric-value {
      type uint32;
      description
        "Current number of entries in the MAC-IP Table of this service instance";
    }
  }

  notification TOTAL_EVPN_MAC_IP_TABLE_THRESHOLD_EXCEEDED {
    description
      "The total number of entries in the MAC-IP Table, for all services, has crossed the 90% threshold of the limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The total number of MAC-IP entries, for all services, has crossed the 90% threshold of the limit {limit}, the current number of entries is {numeric-value}.";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
