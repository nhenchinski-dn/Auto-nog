  notification PCE_DELEGATION_STATE_CHANGE {
    description
      "The PCE server delegation state has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "PCE server {server-address} with priority {priority} delegation state change from {old-state} to {new-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "PCEP";
    leaf server-address {
      type string;
      description
        "The PCE server address";
    }
    leaf priority {
      type uint8;
      description
        "The PCE server priority";
    }
    leaf old-state {
      type enumeration {
        enum yes;
        enum no;
      }
      description
        "Old delegation state";
    }
    leaf new-state {
      type enumeration {
        enum yes;
        enum no;
      }
      description
        "New delegation state";
    }
  }

  notification SRTE_PCE_INIT_LSP_MAXIMUM_LIMIT_REACHED {
    description
      "The maximum number of PCE-initiated paths was reached.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The limit of maximum PCE-initiated paths ({limit}) was reached";
    dn-events-extensions:event-corrective-action-string "Verify the PCE settings for the expected PCE initiated LSPs, and if required, increase the local PCEP maximum-initiated-policies configuration.";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
    dn-events-extensions:event-group "Segment-Routing";
    leaf limit {
      type uint16;
      description
        "The configured PCE-initiated paths limit";
    }
  }

  notification SRTE_PCE_INIT_LSP_MAXIMUM_LIMIT_CLEARED {
    description
      "The number of PCE-initiated paths is below the configured maximum limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The number of PCE-initiated is below the allowed maximum {limit}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
    dn-events-extensions:event-group "Segment-Routing";
    leaf limit {
      type uint16;
      description
        "The configured PCE-initiated paths limit";
    }
  }

  notification SRTE_PCE_INIT_LSP_MAXIMUM_THRESHOLD_EXCEEDED {
    description
      "The threshold of PCE-initiated paths was reached.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The threshold limit ({threshold}%) of PCE-initiated paths ({limit}) was reached, current number of PCE-initiated paths is {numeric-value}";
    dn-events-extensions:event-corrective-action-string "Verify the PCE settings for the expected PCE initiated LSPs, and if required, increase the local PCEP maximum-initiated-policies configuration.";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
    dn-events-extensions:event-group "Segment-Routing";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of PCE-initiated paths";
    }
    leaf limit {
      type uint16;
      description
        "The configured PCE-initiated paths limit";
    }
  }

  notification SRTE_PCE_INIT_LSP_MAXIMUM_THRESHOLD_CLEARED {
    description
      "The threshold of PCE-initiated paths was cleared.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The current number of PCE-initiated paths ({numeric-value}) is below the threshold limit ({threshold}%) of PCE-initiated paths ({limit}) ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
    dn-events-extensions:event-group "Segment-Routing";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of PCE-initiated paths";
    }
    leaf limit {
      type uint16;
      description
        "The configured PCE-initiated paths limit";
    }
  }

  // BGP events

  notification BGP_IPV4_NEIGHBOR_ADJACENCY_DOWN {
    description
      "The state of the BGP neighbor has changed, the neighbor has moved from an 'up' state to a 'down' state.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: Neighbor {neighbor-address} adjacency is {bgp-peer-state}, due to {reason}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    dn-events-extensions:event-snmp-trap-name "bgpBackwardTransNotification";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.15.0.2";
    dn-events-extensions:event-snmp-trap-vars "bgpPeerRemoteAddr.{neighbor-address} {neighbor-address} ; bgpPeerLastError.{neighbor-address} {bgp-peer-last-error} ; bgpPeerState.{neighbor-address} {bgp-peer-state}";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf neighbor-address {
      type string;
      description
        "The BGP neighbor";
    }
    leaf reason {
      type string;
      description
        "The last error seen by this peer on this connection";
    }
    leaf bgp-peer-last-error {
      type binary {
        length "2";
      }
      description
        "SNMP: The last error code and subcode seen by this
         peer on this connection.  If no error has
         occurred, this field is zero.  Otherwise, the
         first byte of this two byte OCTET STRING
         contains the error code, and the second byte
         contains the subcode.
         view: https://www.iana.org/assignments/bgp-parameters/bgp-parameters.xhtml#bgp-parameters-3";
    }
    leaf bgp-peer-state {
      type enumeration {
        enum idle {
          value 1;
        }
        enum connect {
          value 2;
        }
        enum active {
          value 3;
        }
        enum opensent {
          value 4;
        }
        enum openconfirm {
          value 5;
        }
        enum established {
          value 6;
        }
      }
