    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "OSPF instance {instance}: Number of OSPF redistributed prefixes is below the system threshold {threshold}% of the limit ({limit}), the current number of redistributed prefixes are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ospf";
    dn-events-extensions:event-group "OSPF";
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
