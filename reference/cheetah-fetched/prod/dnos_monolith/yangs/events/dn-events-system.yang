    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "RIB VRF instance {vrf-name} is below the threshold {threshold}% of the limit ({limit}) for IPv6 routes, the current number of IPv6 routes are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "RIB";
    dn-events-extensions:event-group "RIB";
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint32;
      description
        "Current number of routes in routing tables";
    }
    leaf limit {
      type uint32;
      description
        "The accumulated IPv6 routes scale";
    }
  }

