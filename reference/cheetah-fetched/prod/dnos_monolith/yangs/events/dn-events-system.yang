  ///****** Routing Protocols Events *****///
  // ISIS events

  notification ISIS_NEIGHBOR_ADJACENCY_UP {
    description
      "The ISIS neighbor adjacency has moved to an 'up' state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "ISIS instance {instance} neighbor {neighbor-system-id} level {level} adjacency moved to an UP state, on interface {if-name}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    dn-events-extensions:event-snmp-trap-name "isisAdjacencyChange";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.138.0.17";
    dn-events-extensions:event-snmp-trap-vars "isisNotificationSysLevelIndex.0 {level} ; isisNotificationCircIfIndex.0 {if-index} ; isisPduLspId.0 {link-state-pdu-id} ; isisAdjState.0 {state}";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf neighbor-system-id {
      type string;
      description
        "Neighbor system ID";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf if-index {
      type uint32 {
        range "1..2147483647";
      }
      description
        "The identifier of this circuit (interface) relevant to
         this notification";
    }
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
        enum level1and2 {
          value 3;
        }
      }
      description
        "The system level for this notification";
    }
    leaf link-state-pdu-id {
      type binary {
        length "8";
      }
      description
        "A Binary String that uniquely identifies
         a Link State PDU.
         SNMP: The 8-byte Link State PDU (LSP) ID,
         consisting of the 6-byte SystemID of the
         originating IS; a one-byte PseudoNode ID,
         which is 0 unless the LSP represents the
         topology of a LAN; and a one-byte LSP
         fragment number that is issued in sequence,
         starting with 0.  Non-zero PseudoNode IDs
         need to be unique to the IS but need not
         match the IfIndex.";
    }
    leaf state {
      type enumeration {
        enum up {
          value 3;
        }
      }
      description
        "The current state of an adjacency. Expected to be up(3)";
    }
  }

  notification ISIS_NEIGHBOR_ADJACENCY_DOWN {
    description
      "ISIS neighbor adjacency moved from 'up' state to a 'down' or 'init' state. This is because of either a network error to the neighbor or the neighbor stopped responding.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "ISIS instance {instance} neighbor {neighbor-system-id} level {level} adjacency moved to a {state} state, on interface {if-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    dn-events-extensions:event-snmp-trap-name "isisAdjacencyChange";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.138.0.17";
    dn-events-extensions:event-snmp-trap-vars "isisNotificationSysLevelIndex.0 {level} ; isisNotificationCircIfIndex.0 {if-index} ; isisPduLspId.0 {link-state-pdu-id} ; isisAdjState.0 {state}";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf neighbor-system-id {
      type string;
      description
        "Neighbor system ID";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf if-index {
      type uint32 {
        range "1..2147483647";
      }
      description
        "The identifier of this circuit (interface) relevant to
         this notification";
    }
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
        enum level1and2 {
          value 3;
        }
      }
      description
        "The system level for this notification";
    }
    leaf link-state-pdu-id {
      type binary {
        length "8";
      }
      description
        "A Binary String that uniquely identifies
         a Link State PDU.
         SNMP: The 8-byte Link State PDU (LSP) ID,
         consisting of the 6-byte SystemID of the
         originating IS; a one-byte PseudoNode ID,
         which is 0 unless the LSP represents the
         topology of a LAN; and a one-byte LSP
         fragment number that is issued in sequence,
         starting with 0.  Non-zero PseudoNode IDs
         need to be unique to the IS but need not
         match the IfIndex.";
    }
    leaf state {
      type enumeration {
        enum down {
          value 1;
        }
        enum initializing {
          value 2;
        }
        enum failed {
          value 4;
        }
      }
      description
        "The current state of an adjacency. Expected to be not up(4)";
    }
  }

  notification ISIS_NEIGHBOR_ADJACENCY_REJECTED {
    description
      "The ISIS neighbor adjacency was rejected due to an invalid hello packet.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "ISIS instance {instance} neighbor {neighbor-system-id} level {level} on interface {if-name} adjacency was rejected due to an invalid hello";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    dn-events-extensions:event-snmp-trap-name "isisRejectedAdjacency";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.138.0.13";
    dn-events-extensions:event-snmp-trap-vars "isisNotificationSysLevelIndex.0 {level} ; isisNotificationCircIfIndex.0 {if-index} ; isisPduFragment.0 {pdu-fragment} ";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf neighbor-system-id {
      type string;
      description
        "Neighbor system ID";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf if-index {
      type uint32 {
        range "1..2147483647";
      }
      description
        "The identifier of this circuit (interface) relevant to
         this notification";
    }
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
        enum level1and2 {
          value 3;
        }
      }
      description
        "The system level for this notification";
    }
    leaf pdu-fragment {
      type binary {
        length "1..64";
      }
      description
        "SNMP: Holds up to 64 initial bytes of a PDU that
         triggered the notification";
    }
  }

  notification ISIS_LSP_CHECKSUM_FAILED {
    description
      "The ISIS LSP packet checksum validates whether the packet has become corrupt. The packet failed validation due to the packet being corrupt and has been has dropped.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "ISIS instance {instance} level {level} received LSP packet on interface {if-name}. Packet failed checksum validation";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf level {
      type string;
      description
        "ISIS level";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
  }

  notification ISIS_AUTHENTICATION_FAILED {
    description
      "ISIS failed to validate the LSP/SNP/HELLO packet received, the packet was dropped.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "ISIS instance {instance} received {level} {pdu} with system ID {system-id} on interface {if-name}. {pdu} authentication failed. Packet was dropped.";
    dn-events-extensions:event-corrective-action-string "Check that the password configuration is the same on both the local and remote system.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    dn-events-extensions:event-snmp-trap-name "isisAuthenticationFailure";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.138.0.10";
    dn-events-extensions:event-snmp-trap-vars "isisNotificationSysLevelIndex.0 {level} ; isisNotificationCircIfIndex.0 {if-index} ; isisPduFragment.0 {pdu-fragment} ";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf pdu {
      type enumeration {
        enum LSP;
        enum CSNP;
        enum PSNP;
        enum HELLO;
      }
      description
        "ISIS packet type";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf system-id {
      description
        "ISIS neighbor system ID";
      type string;
    }
    leaf if-index {
      type uint32 {
        range "1..2147483647";
      }
      description
        "The identifier of this circuit (interface) relevant to
         this notification";
    }
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
        enum level1and2 {
          value 3;
        }
      }
      description
        "The system level for this notification";
    }
    leaf pdu-fragment {
      type binary {
        length "1..64";
      }
      description
        "SNMP: Holds up to 64 initial bytes of a PDU that
         triggered the notification";
    }
  }

  notification ISIS_AUTHENTICATION_TYPE_FAILED {
    description
      "ISIS received a PDU with an authentication type that does not match the local authentication settings, the packet was dropped.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "ISIS instance {instance} level {level} received {pdu} on interface {if-name}. {pdu} authentication type does not match authentication settings. Packet was dropped";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    dn-events-extensions:event-snmp-trap-name "isisAuthenticationTypeFailure";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.138.0.9";
    dn-events-extensions:event-snmp-trap-vars "isisNotificationSysLevelIndex.0 {level} ; isisNotificationCircIfIndex.0 {if-index} ; isisPduFragment.0 {pdu-fragment} ";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf pdu {
      description
        "ISIS packet types";
      type enumeration {
        enum LSP;
        enum CSNP;
        enum PSNP;
        enum HELLO;
      }
    }
    leaf if-index {
      type uint32 {
        range "1..2147483647";
      }
      description
        "The identifier of this circuit (interface) relevant to
         this notification";
    }
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
        enum level1and2 {
          value 3;
        }
      }
      description
        "The system level for this notification";
    }
    leaf pdu-fragment {
      type binary {
        length "1..64";
      }
      description
        "SNMP: Holds up to 64 initial bytes of a PDU that
         triggered the notification";
    }
  }

  notification ISIS_OVERLOAD_BIT_ON {
    description
      "ISIS has set the overload bit to 'on'. This means other routers will not include the router in SPF path calculation and will not route traffic through the router.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "ISIS instance {instance} level {level} overload-bit was set to on, period: {period}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    dn-events-extensions:event-snmp-trap-name "isisDatabaseOverload";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.138.0.1";
    dn-events-extensions:event-snmp-trap-vars "isisNotificationSysLevelIndex.0 {level} ; isisSysLevelState.0 {system-level} ";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
        enum level1and2 {
          value 3;
        }
      }
      description
        "The system level for this notification";
    }
    leaf system-level {
      type enumeration {
        enum off {
          value 1;
        }
        enum on {
          value 2;
        }
        enum waiting {
          value 3;
        }
        enum overloaded {
          value 4;
        }
      }
      description
        "SNMP: The state of the database at this level.
         The value 'off' indicates that IS-IS is not active at
         this level.
         The value 'on' indicates that IS-IS is active at this
         level and is not overloaded.
         The value 'waiting' indicates a database that is low on
         an essential resource, such as memory.
         The administrator may force the state to 'overloaded'
         by setting the object isisSysLevelSetOverload.
         If the state is 'waiting' or 'overloaded', we
         originate LSPs with the overload bit set";
    }
    leaf period {
      type string;
      description
        "The period for which OL-bit is set";
    }
  }

  notification ISIS_OVERLOAD_BIT_OFF {
    description
      "ISIS has set the overload bit to 'off'. This means other routers can route traffic through the router.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "ISIS instance {instance} level {level} overload-bit was set to off";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    dn-events-extensions:event-snmp-trap-name "isisDatabaseOverload";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.138.0.1";
    dn-events-extensions:event-snmp-trap-vars "isisNotificationSysLevelIndex.0 {level} ; isisSysLevelState.0 {system-level} ";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
        enum level1and2 {
          value 3;
        }
      }
      description
        "The system level for this notification";
    }
    leaf system-level {
      type enumeration {
        enum off {
          value 1;
        }
        enum on {
          value 2;
        }
        enum waiting {
          value 3;
        }
        enum overloaded {
          value 4;
        }
      }
      description
        "SNMP: The state of the database at this level.
         The value 'off' indicates that IS-IS is not active at
         this level.
         The value 'on' indicates that IS-IS is active at this
         level and is not overloaded.
         The value 'waiting' indicates a database that is low on
         an essential resource, such as memory.
         The administrator may force the state to 'overloaded'
         by setting the object isisSysLevelSetOverload.
         If the state is 'waiting' or 'overloaded', we
         originate LSPs with the overload bit set";
    }
  }

  notification ISIS_ADVERTISE_MAX_METRIC_ON {
    description
      "ISIS has set the max metric on all interfaces. This means other routers will consider the router to be least preferred in SPF path calculation.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "ISIS instance {instance} level {level} advertise max-metric was set to on, period: {period}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "isis";
    dn-events-extensions:event-group "ISIS";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
        enum level1and2 {
          value 3;
        }
      }
      description
        "The system level for this notification";
    }
    leaf period {
      type string;
      description
        "The period for which max-metric is set";
    }
  }

  notification ISIS_ADVERTISE_MAX_METRIC_OFF {
    description
      "ISIS has turned off the max metric on all interfaces.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "ISIS instance {instance} level {level} advertise max-metric was set to off";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "isis";
    dn-events-extensions:event-group "ISIS";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
        enum level1and2 {
          value 3;
        }
      }
      description
        "The system level for this notification";
    }
  }

  notification ISIS_DUPLICATE_SYSTEM_ID {
    description
      "ISIS has detected a remote node with a duplicate system-id that is the same as the local system-id.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "ISIS instance {instance} level {level} has detected a possible remote system with a duplicate system-id that is the same as the local system-id. System-id {system-id}. Local system info: hostname {local-hostname}, fingerprint {local-fingerprint}. Received LSP info: hostname {remote-hostname}, fingerprint {remote-fingerprint}";
    dn-events-extensions:event-corrective-action-string "Update the configured system-id in either system.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
      }
      description
        "The system level for this notification";
    }
    leaf system-id {
      type string;
      description
        "ISIS system-id. 6byte in format ssss.ssss.ssss ";
    }
    leaf local-hostname {
      type string;
      description
        "Local IS-IS hostname, 'N/A' if unknown";
    }
    leaf local-fingerprint {
      type string;
      description
        "Local IS-IS fingerprint per RFC8196, 'N/A' if unknown";
    }
    leaf remote-hostname {
      type string;
      description
        "Remote IS-IS hostname, 'N/A' if unknown";
    }
    leaf remote-fingerprint {
      type string;
      description
        "Remote IS-IS fingerprint per RFC8196, 'N/A' if unknown";
    }
  }

  notification ISIS_PURGE_EVENT {
    description
      "ISIS received an LSP purge.";
    dn-events-extensions:event-severity-level "Debug";
    dn-events-extensions:event-message-string "ISIS instance {instance} level {level} detected purge event for LSP {lsp-id} Sequence {lsp-seq} . Purge Originator Identification: {poi}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf instance {
      type string;
      description
        "ISIS instance name";
    }
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
      }
      description
        "ISIS level";
    }
    leaf lsp-id {
      type string;
      description
        "The LSP identification";
    }
    leaf lsp-seq {
      type string;
      description
        "The LSP sequence number";
    }
    leaf poi {
      type string;
      description
        "The Purge Originator Identification information";
    }
  }

  notification ISIS_MAXIMUM_INSTANCES_LIMIT_REACHED {
    description
      "The number of ISIS instances has reached the configured system limit.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Number of ISIS instances has reached system limit of {limit}";
    dn-events-extensions:event-corrective-action-string "To configure a new ISIS instance, an existing instance must be removed.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf limit {
      description
        "Session number limit";
      type enumeration {
        enum 5;
      }
    }
  }

  notification ISIS_MAXIMUM_INSTANCES_LIMIT_CLEARED {
    description
      "The number of ISIS instances is below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of ISIS instances is below the system limit of {limit}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf limit {
      description
        "Session number limit";
      type enumeration {
        enum 5;
      }
    }
  }

  notification ISIS_MAXIMUM_ADJACENCIES_LIMIT_REACHED {
    description
      "The number of ISIS adjacencies has reached the configured system limit.";
    dn-events-extensions:event-severity-level "Warning";
