  notification SRV6_CSID_BLOCK_DYNAMIC_RANGE_LIMIT_REACH {
    description
      "The SRv6 CSID allocations from the dynamic-function block have reached the limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "SRv6 CSID allocation for dynamic-function block {block_name} reached the system limit ({limit}), the current number of allocations is ({current_allocations}).";
    dn-events-extensions:event-corrective-action-string "Reduce the SRv6 services over locators in this block or increase the dynamic-function block size.";
