  // RSVP events

  notification RSVP_TUNNEL_UP {
    description
      "The RSVP tunnel moved to an 'up' state and can be used to forward traffic.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "RSVP tunnel {tunnel-name} from {source-address} to {destination-address}, tunnel ID {tunnel-id}, LSP ID {lsp-id}, switched to an up state";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "RSVP";
    dn-events-extensions:event-snmp-trap-name "mplsTunnelUp";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.10.166.3.0.1";
    dn-events-extensions:event-snmp-trap-vars "mplsTunnelAdminStatus.{tunnel-id}.{lsp-id}.{ingress-lsr-id}.{egress-lsr-id} {admin-status} ; mplsTunnelOperStatus.{tunnel-id}.{lsp-id}.{ingress-lsr-id}.{egress-lsr-id} {oper-status} ";
    leaf tunnel-name {
      type string;
      description
        "Tunnel name";
    }
    leaf source-address {
      type string;
      description
        "Tunnel source IPv4 address";
    }
    leaf destination-address {
      type string;
      description
        "Tunnel destination IPv4 address";
    }
    leaf tunnel-id {
      description
        "Tunnel local ID";
      type uint32 {
        range "0..65535";
      }
    }
    leaf lsp-id {
      description
        "LSP ID";
      type uint32;
    }
    leaf admin-status {
      type enumeration {
        enum up {
          value 1;
        }
        enum down {
          value 2;
        }
        enum testing {
          value 3;
        }
      }
      description
        "Indicates the desired operational status of this
         tunnel";
    }
    leaf oper-status {
      type enumeration {
        enum up {
          value 1;
        }
        enum down {
          value 2;
        }
        enum testing {
          value 3;
        }
        enum unknown {
          value 4;
        }
        enum dormant {
          value 5;
        }
        enum notPresent {
          value 6;
        }
        enum lowerLayerDown {
          value 7;
        }
      }
      description
        "Indicates the actual operational status of this
         tunnel, which is typically but not limited to, a
         function of the state of individual segments of
         this tunnel";
    }
    leaf ingress-lsr-id {
      description
        "uint32 value of the tunnel source-address
         SNMP: Identity of the ingress LSR associated with this
         tunnel instance. When the MPLS signalling protocol
         is rsvp(2) this value SHOULD be equal to the Tunnel
         Sender Address in the Sender Template object and MAY
         be equal to the Extended Tunnel Id field in the
         SESSION object. When the MPLS signalling protocol is
         crldp(3) this value SHOULD be equal to the Ingress
         LSR Router ID field in the LSPID TLV object.";
      type uint32;
    }
    leaf egress-lsr-id {
      description
        "uint32 value of the tunnel destination address
         SNMP: Identity of the egress LSR associated with this
         tunnel instance.";
      type uint32;
    }
  }

  notification RSVP_TUNNEL_DOWN {
    description
      "The RSVP tunnel moved to a 'down' state and so cannot be used to forward traffic.";
    dn-events-extensions:event-severity-level "Critical";
    dn-events-extensions:event-message-string "RSVP tunnel {tunnel-name} from {source-address} to {destination-address}, tunnel ID {tunnel-id}, LSP ID {lsp-id}, switched to a down state due to {reason}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "RSVP";
    dn-events-extensions:event-snmp-trap-name "mplsTunnelDown";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.10.166.3.0.2";
    dn-events-extensions:event-snmp-trap-vars "mplsTunnelAdminStatus.{tunnel-id}.{lsp-id}.{ingress-lsr-id}.{egress-lsr-id} {admin-status} ; mplsTunnelOperStatus.{tunnel-id}.{lsp-id}.{ingress-lsr-id}.{egress-lsr-id} {oper-status} ";
    leaf tunnel-name {
      type string;
      description
        "Tunnel name";
    }
    leaf source-address {
      type string;
      description
        "Tunnel source IPv4 address";
    }
    leaf destination-address {
      type string;
      description
        "Tunnel destination IPv4 address";
    }
    leaf tunnel-id {
      description
        "Tunnel local ID";
      type uint32 {
        range "0..65535";
      }
    }
    leaf lsp-id {
      description
        "LSP ID";
      type uint32;
    }
    leaf reason {
      description
        "Reason for tunnel going down";
      type string;
    }
    leaf admin-status {
      type enumeration {
        enum up {
          value 1;
        }
        enum down {
          value 2;
        }
        enum testing {
          value 3;
        }
      }
      description
        "Indicates the desired operational status of this
         tunnel";
    }
    leaf oper-status {
      type enumeration {
        enum up {
          value 1;
        }
        enum down {
          value 2;
        }
        enum testing {
          value 3;
        }
        enum unknown {
          value 4;
        }
        enum dormant {
          value 5;
        }
        enum notPresent {
          value 6;
        }
        enum lowerLayerDown {
          value 7;
        }
      }
      description
        "Indicates the actual operational status of this
         tunnel, which is typically but not limited to, a
         function of the state of individual segments of
         this tunnel";
    }
    leaf ingress-lsr-id {
      description
        "uint32 value of the tunnel source-address
         SNMP: Identity of the ingress LSR associated with this
         tunnel instance. When the MPLS signalling protocol
         is rsvp(2) this value SHOULD be equal to the Tunnel
         Sender Address in the Sender Template object and MAY
         be equal to the Extended Tunnel Id field in the
         SESSION object. When the MPLS signalling protocol is
         crldp(3) this value SHOULD be equal to the Ingress
         LSR Router ID field in the LSPID TLV object.";
      type uint32;
    }
    leaf egress-lsr-id {
      description
        "uint32 value of the tunnel destination address
         SNMP: Identity of the egress LSR associated with this
         tunnel instance.";
      type uint32;
    }
  }

  notification RSVP_LSP_EVENT {
    description
      "There is an error with the Label Switched Path (LSP) for the RSVP tunnel, and is moving to a 'down' state.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "RSVP tunnel {tunnel-name} from {source-address} to {destination-address}, tunnel ID {tunnel-id}, LSP ID {lsp-id}, has encountered {event} event. LSP bandwidth {bandwidth} kbps, originated from {originator}";
