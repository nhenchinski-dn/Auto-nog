    }
  }

  notification MULTICAST_MAXIMUM_NCP_SG_REPLICATIONS_LIMIT_CLEARED {
    description
      "The number of multicast (S,G) replications has moved below the system limit per NCP.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of multicast (S,G) replications on NCP {ncp-id} has moved below the system limit of {limit} replications per NCP";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Multicast";
    leaf limit {
      type uint32;
      description
        "The maximum limit of multicast (S,G) replications";
    }
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
  }

  notification MULTICAST_MAXIMUM_NCP_SG_REPLICATIONS_THRESHOLD_EXCEEDED {
    description
      "The number of multicast (S,G) replications had crossed the system threshold per NCP.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Number of multicast (S,G) replications on NCP {ncp-id} has crossed the {threshold}% system threshold of the maximum limit of {limit} replications per NCP. The current number of multicast (S,G) replications is {current-sg-replications}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Multicast";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf limit {
      type uint32;
      description
        "The limit of multicast (S,G) replications";
    }
    leaf current-sg-replications {
      type uint32;
      description
        "The current multicast (S,G) replications";
    }
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
  }

  notification MULTICAST_MAXIMUM_NCP_SG_REPLICATIONS_THRESHOLD_CLEARED {
    description
      "The number of multicast (S,G) replications has moved below the system threshold per NCP.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of multicast (S,G) replications on NCP {ncp-id} has moved below the {threshold}% system threshold of the maximum limit of {limit} replications per NCP. The current number of multicast (S,G) replications is {current-sg-replications}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Multicast";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf limit {
      type uint32;
      description
        "The limit of multicast (S,G) replications.";
    }
    leaf current-sg-replications {
      type uint32;
      description
        "The current multicast (S,G) replications.";
    }
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
  }

  // PIM Events

  notification PIM_NEIGHBOR_UP {
    description
      "The PIM neighbor adjacency has moved to an 'up' state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "PIM neighbor {neighbor-ip-address} moved to an up state, on interface {if-name}. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    dn-events-extensions:event-snmp-trap-name "dnPimNeighborUp";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.5.0.1";
    dn-events-extensions:event-snmp-trap-vars "dnPimNeighborAddress.0 CONVERT inetAddr({address-type}) {neighbor-ip-address}";
    leaf address-type {
      type enumeration {
        enum unknown {
          value 0;
        }
        enum ipv4 {
          value 1;
        }
        enum ipv6 {
          value 2;
        }
      }
      description
        "A value that represents a type of internet address.
         SYNTAX INTEGER  unknown(0), ipv4(1), ipv6(2), ipv4z(3), ipv6z(4), dns(16)";
    }
    leaf neighbor-ip-address {
      type string;
      description
        "Neighbor IP address";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification PIM_NEIGHBOR_DOWN {
    description
      "The PIM neighbor adjacency moved to a 'down' state. This notification is generated when the neighbor hold-timer expires.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "PIM neighbor {neighbor-ip-address} adjacency lost on interface {if-name} due to {reason}. Uptime {neighbor-uptime}. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    dn-events-extensions:event-snmp-trap-name "pimNeighborLoss";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.157.0.1";
    dn-events-extensions:event-snmp-trap-vars "pimNeighborUpTime {neighbor-uptime-snmp} ; dnPimInterfaceName.0 {if-name} ; dnPimNeighborAddress.0 CONVERT inetAddr(1) {neighbor-ip-address}";
    leaf neighbor-ip-address {
      type string;
      description
        "Neighbor IPv4 address";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf reason {
      type string;
      description
        "The reason the PIM neighbor connection was lost. The reasons which should interest the user:
         (1) Hold-time expired (2) Invalid state";
    }
    leaf neighbor-uptime-snmp {
      type uint32;
      description
        "The uptime when neighbor connectivity lost in TimeTicks";
    }
    leaf neighbor-uptime {
      type string;
      description
        "The uptime when neighbor connectivity lost";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification PIM_INTERFACE_UP {
    description
      "The indicated PIM enabled interface is 'up'.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "PIM enabled interface {if-name} is up. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    dn-events-extensions:event-snmp-trap-name "dnPimInterfaceUp";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.5.0.2";
    dn-events-extensions:event-snmp-trap-vars "dnPimInterfaceName.0 {if-name}";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification PIM_INTERFACE_DOWN {
    description
      "The indicated PIM enabled interface is 'down'.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "PIM enabled interface {if-name} is down. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    dn-events-extensions:event-snmp-trap-name "dnPimInterfaceDown";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.5.0.3";
    dn-events-extensions:event-snmp-trap-vars "dnPimInterfaceName.0 {if-name}";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification PIM_INVALID_REGISTER {
    description
      "An invalid PIM register message was received because the register destination does not match the rendezvous point (RP) of the group address or the group address is using an SSM (Source Specific Multicast ) address range but the PIM register message considers it to be using an ASM (Any Source Multicast) address range.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Invalid PIM register message received on interface {if-name} from {origin-ip-address} for group address {group} to RP address {rp-address}. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    dn-events-extensions:event-snmp-trap-name "pimInvalidRegister";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.157.0.2";
    dn-events-extensions:event-snmp-trap-vars "pimGroupMappingPimMode.0 {pim-mode} ; pimInvalidRegisterAddressType.0 {address-type} ; pimInvalidRegisterOrigin.0 CONVERT inetAddr({address-type}) {origin-ip-address} ; pimInvalidRegisterGroup.0 CONVERT inetAddr({address-type}) {group} ; pimInvalidRegisterRp.0 CONVERT inetAddr({address-type}) {rp-address}";
    leaf pim-mode {
      type enumeration {
        enum none {
          value 1;
        }
        enum ssm {
          value 2;
        }
        enum asm {
          value 3;
        }
        enum bidir {
          value 4;
        }
        enum dm {
          value 5;
        }
        enum other {
          value 6;
        }
      }
      description
        "The PIM mode in which a group is operating
         SYNTAX INTEGER none(1), ssm(2), asm(3), bidir(4), dm(5), other(6)";
    }
    leaf address-type {
      type enumeration {
        enum unknown {
          value 0;
        }
        enum ipv4 {
          value 1;
        }
        enum ipv6 {
          value 2;
        }
      }
      description
        "A value that represents a type of internet address.
         SYNTAX INTEGER  unknown(0), ipv4(1), ipv6(2), ipv4z(3), ipv6z(4), dns(16)";
    }
    leaf if-name {
      type string;
      description
        "PIM register message ingress interface name";
    }
    leaf origin-ip-address {
      type string;
      description
        "The source address of the invalid register message
         received by this device";
    }
    leaf group {
      type string;
      description
        "The IP multicast group address to which the invalid
         register message received by this device was addressed";
    }
    leaf rp-address {
      type string;
      description
        "The RP address to which the invalid register message
         received by this device was delivered";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification PIM_INVALID_JOIN_PRUNE {
    description
      "An invalid PIM JoinPrune message was received because the PIM register destination does not match the rendezvous point (RP) of the group address or the group address is using an SSM (Source Specific Multicast ) address range but the JoinPrune of the (*,G) or (S,G,rpt) states considers it to be using an ASM (Any Source Multicast) address range.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Invalid PIM JoinPrune message received on interface {if-name} from PIM peer {origin-ip-address} for group address {group} group type {pim-mode}. RP address {rp-address}. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    dn-events-extensions:event-snmp-trap-name "pimInvalidJoinPrune";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.157.0.3";
    dn-events-extensions:event-snmp-trap-vars "pimGroupMappingPimMode.0 {pim-mode} ; pimInvalidJoinPruneAddressType.0 {address-type} ; pimInvalidJoinPruneOrigin.0 CONVERT inetAddr({address-type}) {origin-ip-address} ; pimInvalidJoinPruneGroup.0 CONVERT inetAddr({address-type}) {group} ; pimInvalidJoinPruneRp.0 CONVERT inetAddr({address-type}) {rp-address} ; pimNeighborUpTime {neighbor-uptime-snmp}";
    leaf pim-mode {
      type enumeration {
        enum none {
          value 1;
        }
        enum ssm {
          value 2;
        }
        enum asm {
          value 3;
        }
        enum bidir {
          value 4;
        }
        enum dm {
          value 5;
        }
        enum other {
          value 6;
        }
      }
      description
        "The PIM mode in which a group is operating
         SYNTAX INTEGER none(1), ssm(2), asm(3), bidir(4), dm(5), other(6)";
    }
    leaf address-type {
      type enumeration {
        enum unknown {
          value 0;
        }
        enum ipv4 {
          value 1;
        }
        enum ipv6 {
          value 2;
        }
      }
      description
        "A value that represents a type of internet address
         SYNTAX INTEGER  unknown(0), ipv4(1), ipv6(2), ipv4z(3), ipv6z(4), dns(16)";
    }
    leaf if-name {
      type string;
      description
        "PIM Register message ingress interface name";
    }
    leaf origin-ip-address {
      type string;
      description
        "The source address of the invalid JoinPrune message
         received by this device";
    }
    leaf group {
      type string;
      description
        "The IP multicast group address to which the invalid
         PIM JoinPrune message received by this device was addressed";
    }
    leaf rp-address {
      type string;
      description
        "The RP address to which the invalid JoinPrune message
         received by this device was delivered";
    }
    leaf neighbor-uptime-snmp {
      type uint32;
      description
        "The uptime when neighbor connectivity lost in TimeTicks";
    }
    leaf neighbor-uptime {
      type string;
      description
        "The uptime when neighbor connectivity lost";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification PIM_RP_MAPPING_CHANGED {
    description
      "The active RP mapping on this device has changed.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "PIM RP {rp-address} mapping changed. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    dn-events-extensions:event-snmp-trap-name "pimRPMappingChange";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.157.0.4";
    dn-events-extensions:event-snmp-trap-vars "pimGroupMappingPimMode.0 {pim-mode} ; pimGroupMappingPrecedence.0 {group-mapping-precedence}";
    leaf pim-mode {
      type enumeration {
        enum none {
          value 1;
        }
        enum ssm {
          value 2;
        }
        enum asm {
          value 3;
        }
        enum bidir {
          value 4;
        }
        enum dm {
          value 5;
        }
        enum other {
          value 6;
        }
      }
      description
        "The PIM mode in which a group is operating
         SYNTAX INTEGER none(1), ssm(2), asm(3), bidir(4), dm(5), other(6)";
    }
    leaf rp-address {
      type string;
      description
        "The IP address of the RP for which the group mapping was changed";
    }
    leaf group-mapping-precedence {
      type uint32;
      description
        "The precedence of this row, used in the algorithm that
         determines which row applies to a given group address
         (described above).  Numerically higher values for this
         object indicate a lower precedence, with the value zero
         denoting the highest precedence.

         The absolute values of this object have a significance only
         on the local router and do not need to be coordinated with
         other routers.";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification PIM_INTERNAL_ERROR {
    description
      "A PIM has failed due to an internal error.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "PIM internal error: {error-type}, {error-message}. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "Copy the error message and contact Customer Support.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    leaf error-type {
      type string;
      description
        "The PIM internal error type";
    }
    leaf error-message {
      type string;
      description
        "The PIM error message";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification PIM_MAXIMUM_MFIB_ROUTES_LIMIT_REACHED {
    description
      "The maximum number of concurrent MFIB routes installed by PIM has reached the configured system limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The system limit of {limit} MFIB routes installed by PIM has been reached. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "Review the PIM configuration in the network.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    leaf limit {
      type uint32;
      description
        "The PIM MFIB routes maximum limit";
    }
    leaf vrf-name {
      type string;
      description
        "VRF name";
      default "all";
    }
  }

  notification PIM_MAXIMUM_MFIB_ROUTES_LIMIT_CLEARED {
    description
      "The number of concurrent MFIB routes installed by PIM has dropped below the configured maximum limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The number of MFIB routes installed by PIM has dropped below the system limit of {limit}. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    leaf limit {
      type uint32;
      description
        "The PIM MFIB routes maximum limit";
    }
    leaf vrf-name {
      type string;
      description
        "VRF name";
      default "all";
    }
  }

  notification PIM_MAXIMUM_MFIB_ROUTES_THRESHOLD_EXCEEDED {
    description
      "The number of concurrent MFIB routes installed by PIM has crossed the system threshold.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "The number of MFIB routes installed by PIM has crossed the system threshold {threshold}% of the system limit of {limit}, the current number of MFIB routes is {actual-pim-mfib-entries}. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf limit {
      type uint32;
      description
        "The PIM MFIB routes maximum limit";
    }
    leaf actual-pim-mfib-entries {
      type uint32;
      description
        "The current number of PIM MFIB routes";
    }
    leaf vrf-name {
      type string;
      description
        "VRF name";
      default "all";
    }
  }

  notification PIM_MAXIMUM_MFIB_ROUTES_THRESHOLD_CLEARED {
    description
      "The number of concurrent MFIB routes installed by PIM has dropped below the configured system threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The number of MFIB routes installd by PIM has dropped below the system threshold {threshold}% of the system limit of {limit}, the current number of MFIB routes is {actual-pim-mfib-entries}. VRF instance {vrf-name}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf limit {
      type uint32;
      description
        "The PIM MFIB routes maximum limit";
    }
    leaf actual-pim-mfib-entries {
      type uint32;
      description
        "The current number of PIM MFIB routes";
    }
    leaf vrf-name {
      type string;
      description
        "VRF name";
      default "all";
    }
  }

  notification PIM_NSR_CONFIG {
    description
      "The PIM NSR (Non-Stop Routing) admin-state configuration was changed by the user listed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} has changed PIM NSR admin-state configuration to {new-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    leaf user-name {
      type string;
      description
        "Username";
    }
    leaf new-state {
      type enumeration {
        enum enabled;
        enum disabled;
      }
      description
        "PIM NSR admin-state";
    }
  }

  notification PIM_NSR_RECOVERY_START {
    description
      "The system has started PIM Non-Stop Routing recovery due to a restart of the pimd process.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "pimd process is starting a Non-Stop Routing recovery attempt due to process restart";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
  }

  notification PIM_NSR_RECOVERED {
    description
      "The system performed a PIM Non-Stop Routing recovery due to a restart of the pimd process.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "PIM Non-Stop Routing recovery was performed successfully due to a restart of the pimd process";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
  }

  notification PIM_NSR_RECOVERY_FAILED {
    description
      "The PIM process failed to recover in Non-Stop Routing mode.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "pimd process failed to recover in Non-Stop Routing mode";
    dn-events-extensions:event-corrective-action-string "Verify NSR readiness prior to the failure event. If the database was synchronized prior to the failure event, contact Customer Support.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
  }

  notification PIM_GRACEFUL_RESTART_STATUS_CHANGE {
    description
      "The PIM Graceful Restart status has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "PIM Graceful Restart {status}. Grace period {grace-period} seconds";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "PIM";
    leaf status {
      type enumeration {
        enum started {
          value 1;
          description
            "Graceful restart has been initiated";
        }
        enum completed {
          value 2;
          description
            "Graceful restart completed successfully";
        }
        enum failed {
          value 3;
          description
            "Graceful restart failed or timed out";
        }
      }
      description
        "Current status of PIM graceful restart operation.";
    }
    leaf grace-period {
      type uint16 {
        range "30..3600";
      }
      description
        "Configured PIM graceful restart timeout interval.";
    }
  }

  notification MULTICAST_ONLY_FRR_SWITCHOVER {
    description
      "MoFRR switchover event took place.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "An MoFRR protected (S,G) entry with source IP address {source-ip-address} and group address {group-ip-address} switched over to incoming interface {in-interface-name} in VRF {vrf-name}.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "PIM";
    dn-events-extensions:event-group "Multicast";
    leaf source-ip-address {
      type string;
      description
        "Neighbor IP address";
    }
    leaf group-ip-address {
      type string;
      description
        "Group IP address";
    }
    leaf in-interface-name {
      type string;
      description
        "New incoming interface name";
    }
    leaf vrf-name {
      type string;
      description
        "Vrf name";
    }
  }

  // MSDP Events

  notification MSDP_PEER_UP {
    description
      "The MSDP peer connectivity is 'up'. This can occur when the peer connectivity is first established or when connectivity is restored.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "MSDP peer connectivity with peer {peer-ip-address} is up";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "MSDP";
    dn-events-extensions:event-group "MSDP";
    leaf peer-ip-address {
      type string;
      description
        "MSDP peer IP address";
    }
  }

  notification MSDP_PEER_DOWN {
    description
      "The MSDP peer connectivity has been lost with the indicated peer.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "MSDP peer connectivity lost with peer {peer-ip-address}. Connectivity loss reason: {reason}. Uptime: {uptime}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "MSDP";
    dn-events-extensions:event-group "MSDP";
    leaf peer-ip-address {
      type string;
      description
        "MSDP peer IPv4 address";
    }
    leaf reason {
      type string;
      description
        "The reason of losing the MSDP peer connection. The interesting reasons for the user are:
         (1) Hold-timer expired. (2) Session cleared by user (3) TCP session reset by peer";
    }
    leaf uptime {
      type string;
      description
        "The connectivity uptime when MSDP peer connectivity lost";
    }
  }

  notification MSDP_INTERNAL_ERROR {
    description
      "MSDP has encountered an internal error.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "MSDP has encountered an error: {error-type}, {error-message}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "MSDP";
    dn-events-extensions:event-group "MSDP";
    leaf error-type {
      type string;
      description
        "The MSDP internal error type";
    }
    leaf error-message {
      type string;
      description
        "The MSDP internal error message";
    }
  }

  notification MSDP_MAXIMUM_SA_STATES_LIMIT_REACHED {
    description
      "The number of MSDP SA states has reached the configured system limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of MSDP SA states has reached system limit of {limit}";
    dn-events-extensions:event-corrective-action-string "Review the MSDP configuration in the network.";
    dn-events-extensions:event-trigger-component-string "MSDP";
    dn-events-extensions:event-group "MSDP";
    leaf limit {
      type uint32;
      description
        "The MSDP SA states limit number";
    }
  }

  notification MSDP_MAXIMUM_SA_STATES_LIMIT_CLEARED {
    description
      "MSDP SA states number have moved below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of MSDP SA states is below the system limit of {limit}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "MSDP";
    dn-events-extensions:event-group "MSDP";
    leaf limit {
      type uint32;
      description
        "The MSDP SA states limit";
    }
  }

  notification MSDP_MAXIMUM_SA_STATES_THRESHOLD_EXCEEDED {
    description
      "The number of MSDP SA states has crossed the system threshold.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Number of MSDP SA states has crossed the system threshold {threshold}% limit {limit}, the number of MSDP SA states ({actual-msdp-sa-states})";
    dn-events-extensions:event-corrective-action-string "Review the MSDP configuration in the network.";
    dn-events-extensions:event-trigger-component-string "MSDP";
    dn-events-extensions:event-group "MSDP";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf limit {
      type uint32;
      description
        "The MSDP SA states maximum limit";
    }
    leaf actual-msdp-sa-states {
      type uint32;
      description
        "The current MSDP SA states";
    }
  }

  notification MSDP_MAXIMUM_SA_STATES_THRESHOLD_CLEARED {
    description
      "The number of MSDP SA states have moved below the system threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of MSDP SA states is below the system threshold {threshold}% of the limit ({limit}), the current number of MSDP SA states is ({actual-msdp-sa-states})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "MSDP";
    dn-events-extensions:event-group "MSDP";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf limit {
      type uint32;
      description
        "The MSDP SA states threshold";
    }
    leaf actual-msdp-sa-states {
      type uint32;
      description
        "The current MSDP SA states";
    }
  }

  notification MSDP_SA_LOOP_DETECTED {
    description
      "MSDP SA loop was detected.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "MSDP SA loop detected. Originator RP with local address {originator-ip-address} received self originated SA message from peer {peer-ip-address}.";
    dn-events-extensions:event-corrective-action-string "Check the network topology/configuration.";
    dn-events-extensions:event-trigger-component-string "MSDP";
    dn-events-extensions:event-group "MSDP";
    leaf originator-ip-address {
      type string;
      description
        "Originator RP local IP address";
    }
    leaf peer-ip-address {
      type string;
      description
        "MSDP peer IP address";
    }
  }

  notification MSDP_SA_LOOP_CLEARED {
    description
      "MSDP SA loop was cleared.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "MSDP SA loop detected between Originator RP with local address {originator-ip-address} and peer {peer-ip-address} was cleared.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "MSDP";
    dn-events-extensions:event-group "MSDP";
    leaf originator-ip-address {
      type string;
      description
        "Originator RP local IP address";
    }
    leaf peer-ip-address {
      type string;
      description
        "MSDP peer IP address";
    }
  }

  // MPLS Events

  notification MPLS_MAXIMUM_LABELS_ALLOCATION_LIMIT_REACHED {
    description
      "The MPLS maximum label allocation for the listed routing protocol has reached the limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "MPLS maximum label allocation for protocol {protocol} reached the system limit of {limit}";
    dn-events-extensions:event-corrective-action-string "Clear inactive LSPs.";
    dn-events-extensions:event-trigger-component-string "RIB-manager";
    dn-events-extensions:event-group "MPLS";
    leaf protocol {
      type string;
      description
        "MPLS control protocol name";
    }
    leaf limit {
      type uint32;
      description
        "The label space scale, default 20bit space (1048576)";
    }
  }

  notification MPLS_MAXIMUM_LABELS_ALLOCATION_LIMIT_CLEARED {
    description
      "The MPLS maximum label allocation for the listed routing protocol has moved below the system limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "MPLS maximum label allocation for protocol {protocol} is below the system limit {limit}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "RIB-manager";
    dn-events-extensions:event-group "MPLS";
    leaf protocol {
      type string;
      description
        "MPLS control protocol name";
    }
    leaf limit {
      type uint32;
      description
        "The label space scale, default 20bit space (1048576)";
    }
  }

  notification MPLS_MAXIMUM_LABELS_ALLOCATION_THRESHOLD_EXCEEDED {
    description
      "MPLS maximum label allocation for the listed routing protocol has crossed the system threshold.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "MPLS maximum label allocation for protocol {protocol} crossed the system threshold {threshold}% of the limit ({limit}), the current number of MLPS labels are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "Clear inactive LSPs.";
    dn-events-extensions:event-trigger-component-string "RIB-manager";
    dn-events-extensions:event-group "MPLS";
    leaf protocol {
      type string;
      description
        "MPLS control protocol name";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of MPLS labels allocated for the specified protocol";
    }
    leaf limit {
      description
        "Maximum label allocation limit for the specified protocol";
      type uint32;
    }
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
  }

  notification MPLS_MAXIMUM_LABELS_ALLOCATION_THRESHOLD_CLEARED {
    description
      "The MPLS maximum label allocation for the listed routing protocol has moved below the threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "MPLS Maximum label allocation for protocol {protocol} is below the threshold {threshold}% of the limit ({limit}), the current number of MPLS labels are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "RIB-manager";
    dn-events-extensions:event-group "MPLS";
    leaf protocol {
      type string;
      description
        "MPLS control protocol name";
    }
    leaf numeric-value {
      type uint32;
      description
        "Current number of MPLS labels allocated for the specified protocol";
    }
    leaf limit {
      description
        "Maximum label allocation limit for the specified protocol";
      type uint32;
    }
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
  }

  notification MPLS_MAXIMUM_LABEL_COUNTERS_RESOURCE_LIMIT_REACHED {
    description
      "The number of allocated MPLS label counters has reached the resource limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of allocated MPLS label counters has reached the resource limit of {label-counters-resource-limit} counters";
    dn-events-extensions:event-corrective-action-string "Limit the number of LDP or SR routes.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "MPLS";
    leaf label-counters-resource-limit {
      description
        "Maximum label counters resource limit";
      type uint32;
    }
  }

  notification MPLS_MAXIMUM_LABEL_COUNTERS_RESOURCE_LIMIT_CLEARED {
    description
      "The number of allocated MPLS label counters has moved below the resource limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of allocated MPLS label counters is below the limit of {label-counters-resource-limit} counters";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "MPLS";
    leaf label-counters-resource-limit {
      description
        "Maximum label counters resource limit";
      type uint32;
    }
  }

  // Static Route events

  notification STATIC_ROUTE_MAXIMUM_ROUTES_LIMIT_REACHED {
    description
      "The number of static routes has reached the system limit, no additional static routes can be added.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of static routes in VRF {vrf-name} has reached the system limit of {limit}";
    dn-events-extensions:event-corrective-action-string "Remove unrequired static routes.";
    dn-events-extensions:event-trigger-component-string "Static-route";
    dn-events-extensions:event-group "Static-route";
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
    leaf limit {
      type uint16;
      description
        "Maximum number of sessions";
    }
  }

  notification STATIC_ROUTE_MAXIMUM_ROUTES_LIMIT_CLEARED {
    description
      "Static routes have been removed, the number of static routes have moved below the system limit allowing additional routes to be added.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of static routes in VRF {vrf-name} is below the system limit of {limit}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Static-route";
    dn-events-extensions:event-group "Static-route";
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
    leaf limit {
      type uint16;
      description
        "Maximum number of sessions";
    }
  }

  notification STATIC_ROUTE_MAXIMUM_ROUTES_THRESHOLD_EXCEEDED {
    description
      "The number of static routes has crossed the system threshold.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Number of static routes in VRF {vrf-name} has crossed the system threshold {threshold}% of the limit ({limit}), the current number of static routes are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "Remove unrequired static routes.";
    dn-events-extensions:event-trigger-component-string "Static-route";
    dn-events-extensions:event-group "Static-route";
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
    leaf threshold {
      type uint8;
      description
        "Limit percent threshold";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of bfd sessions";
    }
    leaf limit {
      type uint16;
      description
        "Maximum number of sessions";
    }
  }

  notification STATIC_ROUTE_MAXIMUM_ROUTES_THRESHOLD_CLEARED {
    description
      "The number of static routes is below the system threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of static routes in VRF {vrf-name} is below the system threshold {threshold}% of the limit ({limit}), the current number of static routes are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Static-route";
    dn-events-extensions:event-group "Static-route";
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
    leaf threshold {
      type uint8;
      description
        "Limit percent threshold";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of BFD sessions";
    }
    leaf limit {
      type uint16;
      description
        "Maximum number of sessions";
    }
  }

  // TCP events

  notification TCP_AUTHENTICATION_FAILED {
    description
      "Failed to authenticate the TCP session.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Failed to authenticate the TCP session from the local address {local-address-port} to the remote address {remote-address-port}";
    dn-events-extensions:event-corrective-action-string "Verify that the session peer is configured with the correct password.";
    dn-events-extensions:event-trigger-component-string "OS";
    dn-events-extensions:event-group "TCP";
    leaf local-address-port {
      type string;
      description
        "The local IPv4/6 address with port number in format of address::port";
    }
    leaf remote-address-port {
      type string;
      description
        "The remote IPv4/6 address with port number in format of address::port";
    }
  }

  notification TCP_AUTHENTICATION_TYPE_FAILED {
    description
      "TCP authentication settings mismatch between peers.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "TCP authentication settings mismatch between peers for TCP session from the local address {local-address-port} to the remote address {remote-address-port}. Authentication required on {side} system";
    dn-events-extensions:event-corrective-action-string "Verify that the session peer authentication configuration is the same as the local configuration.";
    dn-events-extensions:event-trigger-component-string "OS";
    dn-events-extensions:event-group "TCP";
    leaf local-address-port {
      type string;
      description
        "The local IPv4/6 address with port number in format of address::port";
    }
    leaf remote-address-port {
      type string;
      description
        "The remote IPv4/6 address with port number in format of address::port";
    }
    leaf side {
      description
        "The system on which authentication is required, local or remote";
      type string;
    }
  }

  notification TCP_MAXIMUM_CONNECTION_ATTEMPTS_REACHED {
    description
      "A new control connection attempt, for example, by an SSH session, was ignored because the number of control protocols connection attempts has reached the configured limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "A new {service-type} connection on port {local-address-port} from remote address {remote-address-port} has been ignored since the number of control connection attempts within a time window of {time-window} has reached the configured limit of {max-attempts}";
    dn-events-extensions:event-corrective-action-string "Check control protocols such as SSH and Netconf connection attempt rate.";
    dn-events-extensions:event-trigger-component-string "OS";
    dn-events-extensions:event-group "TCP";
    leaf service-type {
      type enumeration {
        enum ssh;
        enum netconf;
      }
      description
        "Control connection service type";
    }
    leaf local-address-port {
      type string;
      description
        "The local IPv4/6 address with port number in format of address::port";
    }
    leaf remote-address-port {
      type string;
      description
        "The remote IPv4/6 address with port number in format of address::port";
    }
    leaf time-window {
      type uint16;
      description
        "Length in seconds of connection attempts time window";
    }
    leaf max-attempts {
      type uint8;
      description
        "Maximum number of connection attempts";
    }
  }

  notification TCP_MAXIMUM_CONNECTION_ATTEMPTS_CLEARED {
    description
      "A new control connection attempt, for example, by an SSH session, was accepted after rate limit conditions have been cleared.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "A new {service-type} connection on port {local-address-port} from remote address {remote-address-port} was accepted since the number of control connection attempts within a time window of {time-window} is below or equal to the configured limit of {max-attempts}";
    dn-events-extensions:event-corrective-action-string "Check control protocols such as SSH and Netconf connection attempt rate.";
    dn-events-extensions:event-trigger-component-string "OS";
    dn-events-extensions:event-group "TCP";
    leaf service-type {
      type enumeration {
        enum ssh;
        enum netconf;
      }
      description
        "Control connection service type";
    }
    leaf local-address-port {
      type string;
      description
        "The local IPv4/6 address with port number in format of address::port";
    }
    leaf remote-address-port {
      type string;
      description
        "The remote IPv4/6 address with port number in format of address::port";
    }
    leaf time-window {
      type uint16;
      description
        "Length in seconds of connection attempts time window";
    }
    leaf max-attempts {
      type uint8;
      description
        "Maximum number of connection attempts";
    }
  }

  notification MPLS_OAM_PROBE_LOSS_THRESHOLD_REACHED {
    description
      "MPLS OAM probe loss has reached the configured threshold.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "MPLS OAM service {profile-name} for tunnel {tunnel-name} has reached the configured threshold of {threshold}";
    dn-events-extensions:event-corrective-action-string "Verify the tunnel state and try to optimize the tunnel.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "MPLS-OAM";
    leaf profile-name {
      type string;
      description
        "Mpls oam profile name";
    }
    leaf tunnel-name {
      type string;
      description
        "Tunnel name";
    }
    leaf threshold {
      type uint8;
      description
        "Probe loss threshold";
    }
  }

  notification MPLS_OAM_PROBE_LOSS_THRESHOLD_CLEARED {
    description
      "MPLS Operation, Administration, and Maintenance (OAM) probe loss is below the configured threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "MPLS OAM service {profile-name} for tunnel {tunnel-name} is below the configured threshold of {threshold}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "MPLS-OAM";
    leaf profile-name {
      type string;
      description
        "MPLS OAM profile name";
    }
    leaf tunnel-name {
      type string;
      description
        "Tunnel name";
    }
    leaf threshold {
      type uint8;
      description
        "Probe loss threshold";
    }
  }

  notification L2VPN_MPLS_OAM_PROBE_LOSS_THRESHOLD_REACHED {
    description
      "L2VPN MPLS OAM probe loss has reached the configured threshold.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "MPLS OAM service {profile-name} for service {service-name} against target-addrss {target-address} has reached the configured threshold of {threshold}";
    dn-events-extensions:event-corrective-action-string "Verify the service state and try to optimize the service.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "MPLS-OAM";
    leaf profile-name {
      type string;
      description
        "Mpls oam profile name";
    }
    leaf service-name {
      type string;
      description
        "L2VPN service name";
    }
    leaf target-address {
      type string;
      description
        "PW peer IP address";
    }
    leaf threshold {
      type uint8;
      description
        "Probe loss threshold";
    }
  }

  notification L2VPN_MPLS_OAM_PROBE_LOSS_THRESHOLD_CLEARED {
    description
      "MPLS Operation, Administration, and Maintenance (OAM) probe loss is below the configured threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "MPLS OAM service {profile-name} for service {service-name} against target-addrss {target-address} is below the configured threshold of {threshold}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "MPLS-OAM";
    leaf profile-name {
      type string;
      description
        "MPLS OAM profile name";
    }
    leaf service-name {
      type string;
      description
        "Tunnel name";
    }
    leaf target-address {
      type string;
      description
        "PW peer IP address";
    }
    leaf threshold {
      type uint8;
      description
        "Probe loss threshold";
    }
