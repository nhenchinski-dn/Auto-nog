    }
    leaf limit {
      type uint16;
      description
        "The configured SR auto-policies scale limit";
    }
  }

  notification SR_MAXIMUM_AUTO_POLICIES_THRESHOLD_CLEARED {
    description
      "The number of concurrent SR auto-policies has dropped below the configured system threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The number of SR auto-policies has dropped below the system threshold {threshold}% of the system limit of {limit} policies, the number of SR auto-policies is {numeric-value}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
