  notification RSVP_TUNNEL_E2E_PROTECTION_UP {
    description
      "The RSVP tunnel end-to-end protection lsp is Up and installed as alternate path";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "RSVP tunnel {tunnel-name} from {source-address} to {destination-address}, tunnel ID {tunnel-id}, with active lsp {active-lsp-id} is end-to-end protected by alternate lsp {alternate-lsp-id}";
