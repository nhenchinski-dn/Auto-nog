    }
    leaf if-name-dest {
      type string;
      description
        "NCP fabric interface";
    }
  }

  notification MULTI_STAGE_FABRIC_CONNECTIVITY_ERROR {
    description
      "Bad connection detected between two nodes in the multi-stage fabric cluster.";
    dn-events-extensions:event-severity-level "Critical";
    dn-events-extensions:event-message-string "Interface {if-name} connected to {if-name-dest}.";
    dn-events-extensions:event-corrective-action-string "Check the connectivity between the nodes.";
    dn-events-extensions:event-trigger-component-string "Cluster Manager";
    dn-events-extensions:event-group "System";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf if-name-dest {
      type string;
      description
        "Interface name";
    }
