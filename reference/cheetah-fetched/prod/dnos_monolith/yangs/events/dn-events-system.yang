    }
    leaf restore-cycles {
      type uint8 {
        range "1..10";
      }
      description
        "The number of restore-cycles allowed before permanantly suppressing the IP address.";
    }
  }

  notification IP_MOBILITY_IP_ADDRESS_RELEASED {
    description
      "An IP address that was suppressed has now been released";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The IP {ip-address} received in service {service-name} that was suppressed, has been released due to {release-reason}.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "L2VPN";
    leaf ip-address {
      type string;
      description
        "IP address that was suppressed.";
    }
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
    leaf release-reason {
      type string;
      description
        "Release Reason";
    }
  }

  notification L2_MAC_MOBILITY_INTERFACE_SHUTDOWN {
    description
      "An interface has been shut down due to MAC mobility suppression.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "The MAC mobility prevention ac-shutdown action is being applied to the interface {interface-name} associated with EVPN service {service-name}, triggered by MAC Address {mac-address}.";
    dn-events-extensions:event-corrective-action-string "Check the configuration for layer-2 network loops and/or MAC Mobility issues.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
    leaf interface-name {
      type string;
      description
        "Interface name";
    }
    leaf mac-address {
      type string;
      description
        "MAC address that triggered shutdown";
    }
  }

  notification L2_MAC_MOBILITY_INTERFACE_PERMANENTLY_SHUTDOWN {
    description
      "An interface has been permanently shut down due to MAC mobility. Too many MAC move related shutdowns occurred within the allowed time period.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "The MAC mobility prevention permanent ac-shutdown action is being applied to interface {interface-name} associated with EVPN service {service-name}. Last shutdown triggered by MAC {mac-address}.";
    dn-events-extensions:event-corrective-action-string "Check the configuration for layer-2 network loops and/or MAC Mobility issues.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
    leaf interface-name {
      type string;
      description
        "Interface name";
    }
    leaf mac-address {
      type string;
      description
        "MAC address that triggered shutdown.";
    }
  }

  notification L2_MAC_MOBILITY_INTERFACE_RELEASED {
    description
      "The MAC Mobility Prevention mechanism has released an AC interface from shut down.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The MAC Mobility prevention ac-shutdown mechanism applied to Interface {interface-name} associated with EVPN service {service-name}, has been released.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
    leaf interface-name {
      type string;
      description
        "Interface name";
    }
  }

  notification L2_ETREE_ES_INCONSISTENCY {
    description
      "Inconsistent E-TREE designations configuration has been detected for the same ESI between this PE and a neighbor PE.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "The ACs on ES {esi-number} on service {service-name} has been configured inconsistently, as both E-TREE Root and Leaf, between this PE and a neighbor PE.";
    dn-events-extensions:event-corrective-action-string "Check configuration of the ACs of this ESI";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "L2VPN";
    leaf esi-number {
      type string;
      description
        "The ESI for which the E-TREE inconsistency has occurred.";
    }
    leaf service-name {
      description
        "Name of L2VPN service";
      type string;
    }
  }

  // L2 Loop Detection

  notification L2_LOOP_DETECTION_INTERFACE_SHUTDOWN {
    description
      "A layer-2 loop has been detected and one or more interfaces have been shutdown.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The local loop prevention ac-shutdown action is being applied to the interface {interface-name} associated with service {service-type} {service-name}, triggered by MAC {mac-address}";
    dn-events-extensions:event-corrective-action-string "Check configuration, check for layer-2 network loops";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf interface-name {
      type string;
      description
        "Name of Interface that has been shutdown";
    }
    leaf service-type {
      description
        "Layer-2 Service Type";
      type enumeration {
        enum BRIDGE_DOMAIN;
        enum EVPN;
      }
    }
    leaf service-name {
      description
        "Name of Layer-2 service";
      type string;
    }
    leaf mac-address {
      type string;
      description
        "MAC address that caused the interface shutdown.";
    }
  }

  notification L2_LOOP_DETECTION_INTERFACE_RELEASED {
    description
      "The interface shutdown due to layer-2 loop detection has been released from the ac-shutdown action.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The local loop prevention ac-shutdown action applied to the interface {interface-name} associated with service {service-type} {service-name}, has been released";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf interface-name {
      type string;
      description
        "Name of Interface that has been shutdown";
    }
    leaf service-type {
      description
        "Layer-2 Service Type";
      type enumeration {
        enum BRIDGE_DOMAIN;
        enum EVPN;
      }
    }
    leaf service-name {
      description
        "Name of Layer-2 service";
      type string;
    }
  }

  notification L2_LOOP_DETECTION_INTERFACE_PERMANENTLY_SHUTDOWN {
    description
      "An interface has been permanently shutdown, as it has had too many MAC move related shutdowns in the time period";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The local loop prevention permanent ac-shutdown action is being applied to the interface {interface-name} associated with service {service-type} {service-name}, Last shutdown triggered by MAC {mac-address}";
    dn-events-extensions:event-corrective-action-string "Check configuration, check for layer-2 network loops";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf interface-name {
      type string;
      description
        "Name of Interface that has been permanently shutdown";
    }
    leaf service-type {
      description
        "Layer-2 Service Type";
      type enumeration {
        enum BRIDGE_DOMAIN;
        enum EVPN;
      }
    }
    leaf service-name {
      description
        "Name of Layer-2 service";
      type string;
    }
    leaf mac-address {
      type string;
      description
        "MAC address that caused the last interface shutdown.";
    }
  }

  notification EVPN_MAC_IP_TABLE_THRESHOLD_EXCEEDED {
    description
      "The number of entries in the MAC-IP Table has crossed the 90% threshold of the configured limit for this service instance.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The number of MAC-IP entries for this service instance {service-name} has crossed the 90% threshold of the configured limit {limit}, the current number of entries is {numeric-value}.";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf service-name {
      type string;
      description
        "The name of the service instance";
