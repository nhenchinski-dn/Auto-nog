  notification EVENT_MANAGER_EVENT_POLICY_TERMINATED {
    description
      "Event manager stopped event-policy execution.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "event-manager terminated the execution of event-policy {policy-name} which matched system event {event-name} with attribute {attribute-name}, termination reason: {reason}.";
    dn-events-extensions:event-corrective-action-string "Check the reason field for more details.";
    dn-events-extensions:event-trigger-component-string "EEM";
    dn-events-extensions:event-group "Management";
    leaf policy-name {
      type string;
      description
        "The name of the policy.";
    }
    leaf event-name {
      type string;
      description
        "The system event that triggers the policy.";
    }
    leaf attribute-name {
      type string;
      description
        "The attribute name that the script receives.";
    }
    leaf reason {
      type string;
      description
        "Reason for the script termination
         (e.g. script max-runtime exceeded, user request command, configuration change, other)";
    }
  }

  notification EVENT_MANAGER_PERIODIC_POLICY_TERMINATED {
    description
      "Event manager stopped periodic-policy execution.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "event-manager terminated the execution of periodic-policy {policy-name}, termination reason: {reason}.";
