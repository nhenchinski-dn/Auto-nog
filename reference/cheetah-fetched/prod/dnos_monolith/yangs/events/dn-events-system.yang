    dn-events-extensions:event-message-string "Local fault detected on interface {if-name}";
    dn-events-extensions:event-corrective-action-string "<p>No corrective action is required.</p>";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Interfaces";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
  }

  notification IF_LINK_REMOTE_FAULT_DETECTED {
