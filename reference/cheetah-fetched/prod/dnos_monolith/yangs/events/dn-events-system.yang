    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf limit {
      type uint16;
      description
        "The accumulated adjacencies scale on all instances";
    }
  }

  notification ISIS_MAXIMUM_ADJACENCIES_LIMIT_CLEARED {
    description
      "ISIS adjacencies have been removed, the number of ISIS adjacencies is below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of ISIS adjacencies is below the system limit of {limit} adjacencies";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf limit {
      type uint16;
      description
        "The accumulated adjacencies scale on all instances";
    }
  }

  notification ISIS_MAXIMUM_ADJACENCIES_THRESHOLD_EXCEEDED {
    description
      "The number of ISIS adjacencies has crossed the system threshold.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Number of ISIS adjacencies has crossed the system threshold {threshold}% limit of {limit}, the number of ISIS adjacencies are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of ISIS adjacencies";
    }
    leaf limit {
      type uint16;
      description
        "The accumulated adjacencies scale on all instances";
    }
  }

  notification ISIS_MAXIMUM_ADJACENCIES_THRESHOLD_CLEARED {
    description
      "The number of ISIS adjacencies is below the system threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of ISIS adjacencies is below the system threshold {threshold}% of the limit ({limit}), the current number of ISIS adjacencies are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of ISIS adjacencies";
    }
    leaf limit {
      type uint16;
      description
        "The accumulated adjacencies scale on all instances";
    }
  }

  notification ISIS_MAXIMUM_ROUTES_LIMIT_REACHED {
    description
      "The number of ISIS routes has reached the system limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of ISIS routes has reached the system limit of {limit} routes";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf limit {
      type uint16;
      description
        "The accumulated routes scale on all instances and address-families";
    }
  }

  notification ISIS_MAXIMUM_ROUTES_LIMIT_CLEARED {
    description
      "Routes have been removed, the number of ISIS routes is below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of routes is below the system limit of {limit} routes";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf limit {
      type uint16;
      description
        "The accumulated routes scale on all instances and address-families";
    }
  }

  notification ISIS_MAXIMUM_ROUTES_THRESHOLD_EXCEEDED {
    description
      "The number of ISIS routes has crossed the system threshold.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Number of ISIS routes has crossed the system threshold {threshold}% of the limit ({limit}), the current number of routes are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of ISIS routes";
    }
    leaf limit {
      type uint16;
      description
        "The accumulated routes scale on all instances and address-families";
    }
  }

  notification ISIS_MAXIMUM_ROUTES_THRESHOLD_CLEARED {
    description
      "The number of ISIS routes is below the system threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of routes is below the system threshold {threshold}% of the limit ({limit}), the current number of routes are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of ISIS routes";
    }
