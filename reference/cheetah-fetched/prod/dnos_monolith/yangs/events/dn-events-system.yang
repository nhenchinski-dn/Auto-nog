  notification RIB_MAXIMUM_ROUTES_THRESHOLD_EXCEEDED {
    description
      "RIB has crossed the system threshold for the number of supported routes.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "RIB crossed the system threshold {threshold}% of the limit ({limit}), the current number of routes are ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "RIB";
    dn-events-extensions:event-group "RIB";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint32;
      description
        "Current number of routes in routing tables";
    }
    leaf limit {
      type uint32;
      description
        "The accumulated IPv4 & IPv6 routes scale";
    }
  }

  notification RIB_MAXIMUM_ROUTES_THRESHOLD_CLEARED {
    description
      "The RIB has moved below the threshold for the number of supported routes.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "RIB is below the threshold {threshold}% of the limit ({limit}), the current number of routes are ({numeric-value})";
