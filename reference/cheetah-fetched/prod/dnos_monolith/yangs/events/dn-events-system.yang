        "reason for tunnel lsp switchover";
      type string;
    }
    leaf admin-status {
      type enumeration {
        enum up {
          value 1;
        }
        enum down {
          value 2;
        }
        enum testing {
          value 3;
        }
      }
      description
        "Indicates the desired operational status of this
         tunnel";
    }
    leaf oper-status {
