  // 802.3ah EFM OAM events

  notification EFM_OAM_SESSION_UP {
    description
      "The EFM OAM session on the specified interface has moved from a 'down' state to a 'up' state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "EFM OAM session on interface {if-name} with neighbor {neighbor-address} has been established.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "EFM-OAM";
    leaf if-name {
      type string;
      description
        "Local interface name";
    }
    leaf neighbor-address {
      type string;
      description
        "Neighbor peer MAC address";
    }
  }

  notification EFM_OAM_SESSION_DOWN {
    description
      "The EFM OAM session on the specified interface has moved from an 'up' state to a 'down' state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "EFM OAM session on interface {if-name} with neighbor {neighbor-address} has been terminated.";
    dn-events-extensions:event-corrective-action-string "Verify link connectivity, its status and that the protocol is enabled on both sides.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "EFM-OAM";
    leaf if-name {
      type string;
      description
        "Local interface name";
    }
    leaf neighbor-address {
      type string;
      description
        "Neighbor peer MAC address";
    }
  }

  notification EFM_OAM_LINK_EVENT_THRESHOLD_EXCEEDED {
    description
      "An EFM OAM link event has occured on the specified interface, a link performance threshold has been exceeded.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The {location} EFM-OAM {link-event} threshold on interface {if-name} connected to {neighbor-address} has been exceeded. Reported link event details: window-size {window-size}; threshold {link-event-threshold}; errors value within window {errors-value}; total errors {total-errors}; total events sent {total-events}.";
    dn-events-extensions:event-corrective-action-string "Check the optical equipment and cabling.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "EFM-OAM";
    leaf location {
      type enumeration {
        enum local;
        enum remote;
      }
      description
        "Link event origin";
    }
    leaf link-event {
      type enumeration {
        enum errored-symbol-period-event;
        enum errored-frame-event;
        enum errored-frame-period-event;
        enum errored-frame-seconds-summary-event;
      }
      description
        "Measured link performance KPI";
    }
    leaf if-name {
      type string;
      description
        "Local interface name";
    }
    leaf neighbor-address {
      type string;
      description
        "Neighbor peer MAC addres";
    }
    leaf window-size {
      type uint64;
      description
        "The sampling window for the reported link event";
    }
    leaf link-event-threshold {
      type uint16;
      description
        "The configured threshold value for the reported link event";
    }
    leaf errors-value {
      type uint16;
      description
        "The number of errors reported for the link event within the sampling window";
    }
    leaf total-errors {
      type uint64;
      description
        "The total number of errors causing the link event to be sent";
    }
    leaf total-events {
      type uint32;
      description
        "The total number of times that the reported link event was sent";
    }
  }

  notification EFM_OAM_LINK_EVENT_THRESHOLD_CLEARED {
    description
      "An EFM OAM link event on the specified interface has ended, a link performance threshold violation has been cleared.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The {location} EFM-OAM {link-event} threshold violation on interface {if-name} connected to {neighbor-address} has been cleared.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "EFM-OAM";
    leaf location {
      type enumeration {
        enum local;
        enum remote;
      }
      description
        "Link event origin";
    }
    leaf link-event {
      type enumeration {
        enum errored-symbol-period-event;
        enum errored-frame-event;
        enum errored-frame-period-event;
        enum errored-frame-seconds-summary-event;
      }
      description
        "Measured link performance KPI";
    }
    leaf if-name {
      type string;
      description
        "Local interface name";
    }
    leaf neighbor-address {
      type string;
      description
        "Neighbor peer MAC addres";
    }
  }

  notification EFM_OAM_CRITICAL_LINK_EVENT_TRIGGERED {
    description
      "An EFM OAM critical link event on the specified interface has been triggered.";
    dn-events-extensions:event-severity-level "Critical";
    dn-events-extensions:event-message-string "A {location} EFM-OAM {critical-link-event} event has been generated on interface {if-name} with neighbor {neighbor-address}. {action} shall be performed.";
    dn-events-extensions:event-corrective-action-string "Check the optical equipment and cabling.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "EFM-OAM";
    leaf location {
      type enumeration {
        enum local;
        enum remote;
      }
      description
        "Critical link event origin";
    }
    leaf critical-link-event {
      type enumeration {
        enum link-fault;
        enum dying-gasp;
        enum critical-link;
      }
      description
        "Reported critical link event";
    }
    leaf if-name {
      type string;
      description
        "Local interface name";
    }
    leaf neighbor-address {
      type string;
      description
        "Neighbor peer MAC address";
    }
    leaf action {
      type enumeration {
        enum no-action;
        enum disable-interface;
      }
      description
        "Action to be performed following the critical link event reported";
    }
  }

  notification EFM_OAM_CRITICAL_LINK_EVENT_CLEARED {
    description
      "An EFM OAM critical link event on the specified interface has been cleared.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "A {location} EFM-OAM {critical-link-event} event on interface {if-name} with neighbor {neighbor-address} has been cleared.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "EFM-OAM";
    leaf location {
      type enumeration {
        enum local;
        enum remote;
      }
      description
        "Critical link event origin";
    }
    leaf critical-link-event {
      type enumeration {
        enum link-fault;
        enum dying-gasp;
        enum critical-link-event;
      }
      description
        "Reported critical link event";
    }
    leaf if-name {
      type string;
      description
        "Local interface name";
    }
    leaf neighbor-address {
      type string;
      description
        "Neighbor peer MAC addres";
    }
  }

  // 802.1ag CFM OAM events

  notification CFM_DEFECT_CONDITION_DETECTED {
    description
      "A defect condition was detected in a CFM service.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "A {highest-defect} CFM defect was detected in level {md-level} maintenance-domain {maintenance-domain-name} (MD-name {md-name}), maintenance-association {maintenance-association-name} (short-MA-name {short-ma-name}). {action} shall be performed.";
    dn-events-extensions:event-corrective-action-string "Review CFM configuration in the network and cabling.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "CFM-OAM";
    dn-events-extensions:event-snmp-trap-name "dnCfmFaultAlarm";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.15.0.1";
    dn-events-extensions:event-snmp-trap-vars "dnCfmTrapMdLevel.0 {md-level}; dnCfmTrapMdName.0 {maintenance-domain-name}; dnCfmTrapMaName.0 {maintenance-association-name}; dnCfmTrapHighestDefectPri.0 {highest-defect-numeric}";
    leaf highest-defect {
      type enumeration {
        enum DefXconCCM;
        enum DefErrorCCM;
        enum DefRemoteCCM;
        enum DefMACstatus;
        enum DefRDICCM;
      }
      description
        "The highest priority defect detected in the Maintenance Association";
    }
    leaf md-level {
      type uint8 {
        range "0..7";
      }
      description
        "Reported critical link event";
    }
    leaf maintenance-domain-name {
      type string;
      description
        "The name of the Maintenance Domain";
    }
    leaf md-name {
      type string;
      description
        "The Maintenance Domain name";
    }
    leaf maintenance-association-name {
      type string;
      description
        "The name of the Maintenance Association within the MD";
    }
    leaf short-ma-name {
      type string;
      description
        "The Maintenance Association identifier (short-ma-name)";
    }
    leaf action {
      type enumeration {
        enum no-action;
        enum disable-interface;
      }
      description
        "Action to be performed following the defect detection";
    }
    leaf highest-defect-numeric {
      type uint8 {
        range "1..5";
      }
      description
        "The highest priority defect as a numeric value corresponding to IEEE 802.1ag defect priorities";
    }
  }

  notification CFM_DEFECT_CONDITION_CLEARED {
    description
      "All detected defect conditions were cleared in the CFM service.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "All CFM defects detected in level {md-level} maintenance-domain {maintenance-domain-name} (MD-name {md-name}), maintenance-association {maintenance-association-name} (short-MA-name {short-ma-name}) have been cleared.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "CFM-OAM";
    dn-events-extensions:event-snmp-trap-name "dnCfmFaultAlarmCleared";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.15.0.2";
    dn-events-extensions:event-snmp-trap-vars "dnCfmTrapMdLevel.0 {md-level}; dnCfmTrapMdName.0 {maintenance-domain-name}; dnCfmTrapMaName.0 {maintenance-association-name}; dnCfmTrapHighestDefectPri.0 0";
    leaf md-level {
      type uint8 {
        range "0..7";
      }
      description
        "Reported critical link event";
    }
    leaf maintenance-domain-name {
      type string;
      description
        "The name of the Maintenance Domain";
    }
    leaf md-name {
      type string;
      description
        "The Maintenance Domain name";
    }
    leaf maintenance-association-name {
      type string;
      description
        "The name of the Maintenance Association within the MD";
    }
    leaf short-ma-name {
      type string;
      description
        "The Maintenance Association identifier (short-ma-name)";
    }
  }

  notification CFM_MAXIMUM_AUTO_DISCOVERED_RMEPS_LIMIT_REACHED {
    description
      "The number of Connectivity Fault Management (CFM) auto-discovered remote Maintenance association End Points (MEP)s has reached the configured system limit.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The number of CFM auto-discovered remote MEPs has reached the system limit of {limit} dynamically learned remote MEPs";
    dn-events-extensions:event-corrective-action-string "Review the global CFM configuration";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "CFM-OAM";
    leaf limit {
      type uint32;
      description
        "The maximum limit of auto-discovered remote MEPs in the system";
    }
  }

  notification CFM_MAXIMUM_AUTO_DISCOVERED_RMEPS_LIMIT_CLEARED {
    description
      "The number of Connectivity Fault Management (CFM) auto-discovered remote Maintenance association End Points (MEP)s has moved below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The number of CFM auto-discovered remote MEPs has moved below the system limit of {limit} dynamically learned remote MEPs";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "CFM-OAM";
    leaf limit {
      type uint32;
      description
        "The maximum limit of auto-discovered remote MEPs in the system";
    }
  }

  notification CFM_MAXIMUM_AUTO_DISCOVERED_RMEPS_LIMIT_THRESHOLD_EXCEEDED {
    description
      "The number of Connectivity Fault Management (CFM) auto-discovered remote Maintenance association End Points (MEP)s has crossed the system threshold.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "The number of auto-discovered remote MEPs in CFM has exceeded the system threshold of {threshold}%, of the system's maximum limit of {limit} dynamically learned remote MEPs";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "CFM-OAM";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf limit {
      type uint32;
      description
        "The maximum limit of auto-discovered remote MEPs in the system";
    }
  }

  notification CFM_MAXIMUM_AUTO_DISCOVERED_RMEPS_LIMIT_THRESHOLD_CLEARED {
    description
      "The number of Connectivity Fault Management (CFM) auto-discovered remote Maintenance association End Points (MEP)s has moved below the system threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The number of auto-discovered remote MEPs in CFM has moved below the system threshold of {threshold}%, of the system's maximum limit of {limit} dynamically learned remote MEPs";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "CFM-OAM";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf limit {
      type uint32;
      description
        "The maximum limit of auto-discovered remote MEPs in the system";
    }
  }

  notification CFM_PROACTIVE_TEST_FAILURE {
    description
      "The CFM proactive test has failed due to a threshold violation.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "CFM proactive {test-type} test session {session-name} (ID: {session-id}) initiated from MEP {source-mep-id} in MA "
                                            + "{source-ma-name} under MD {source-md-name} in level {source-md-level} has failed due to a violation of the configured {threshold-type-id} threshold "
                                            + "of {threshold-value-and-units}. Recorded value: {calculated-violating-metric-and-units}. Test completed at: {test-end-time}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "CFM-OAM";
    dn-events-extensions:event-snmp-trap-name "dnCfmProactiveTestFailure";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.15.0.3";
    dn-events-extensions:event-snmp-trap-vars "dnCfmTrapMdLevel.0 {source-md-level}; dnCfmTrapMdName.0 {source-md-name}; dnCfmTrapMaName.0 {source-ma-name}; "
                                            + "dnCfmTrapMepId.0 {source-mep-id}; dnCfmTrapSessionType.0 {test-type}; dnCfmTrapSessionId.0 {session-id}; "
                                            + "dnCfmTrapThresholdType.0 {threshold-type-id}; dnCfmTrapMeasuredValue.0 {measured-value-raw}";
    leaf test-type {
      type enumeration {
        enum two-way-delay-measurement {
          value 1;
        }
        enum two-way-synthetic-loss-measurement {
          value 2;
        }
      }
      description
        "Type of proactive test that failed (for syslog text).";
    }
    leaf session-name {
      type string;
      description
        "CFM proactive test session name (for syslog text).";
    }
    leaf session-id {
      type uint16;
      description
        "Internal system-generated CFM proactive test session id.";
    }
    leaf source-mep-id {
      type uint16 {
        range "1..8191";
      }
      description
        "Source MEP ID.";
    }
    leaf source-ma-name {
      type string;
      description
        "Source MA name.";
    }
    leaf source-md-name {
      type string;
      description
        "Source MD name.";
    }
    leaf source-md-level {
      type uint8 {
        range "0..7";
      }
      description
        "MD level.";
    }
    leaf threshold-value-and-units {
      type string;
      description
        "Configured threshold value with units for syslog, e.g. '12000 us' or '9590 hundredths-percent (95.90%)'.";
    }
    leaf calculated-violating-metric-and-units {
      type string;
      description
        "Measured violating value with units for syslog, e.g. '15340 us' or '1200 hundredths-percent (12.00%)'.";
    }
    leaf test-end-time {
      type string;
      description
        "Time the test completed (display-friendly).";
    }
    leaf threshold-type-id {
      type enumeration {
        enum frame-delay-two-way-min {
          value 1;
        }
        enum frame-delay-two-way-avg {
          value 2;
        }
        enum frame-delay-two-way-max {
          value 3;
        }
        enum ifdv-two-way-avg {
          value 4;
        }
        enum ifdv-two-way-max {
          value 5;
        }
        enum successRatePercent {
          value 6;
        }
        enum frame-loss-near-end-percentage {
          value 7;
        }
        enum frame-loss-far-end-percentage {
          value 8;
        }
      }
      description
        "Raw enum for dnCfmTrapThresholdType:
         1=frameDelayTwoWayMin, 2=frameDelayTwoWayAvg, 3=frameDelayTwoWayMax,
         4=ifdvTwoWayAvg, 5=ifdvTwoWayMax, 6=successRatePercent,
         7=frameLossNearEndPercent, 8=frameLossFarEndPercent.";
    }
    leaf measured-value-raw {
      type uint32;
      description
        "Raw value for dnCfmTrapMeasuredValue (no units):
         - If threshold-type-id in {1..5}: microseconds.
         - If threshold-type-id in {6..8}: hundredths of a percent (e.g., 80.30% => 8030).";
    }
  }

  // Flow-monitor (IPFIX/Netflow) system-events

  notification FLOW_MONITORING_CACHE_SIZE_THRESHOLD_EXCEEDED {
    description
      "The number of flows in the flow-cache table for each NCP has exceeded the configured threshold. If the flow-cache table size reaches 100%, the flow entries will be aged out.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Number of flows in the flow-cache table per NCP {ncp-id} has exceeded configured threshold of {threshold} - {num-of-flow-entries}";
    dn-events-extensions:event-corrective-action-string "None";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf threshold {
      type uint8;
      description
        "Threshold percentage";
    }
    leaf num-of-flow-entries {
      type uint8;
      description
        "Number of flow entries in flow-cache table";
    }
  }

  notification FLOW_MONITORING_CACHE_SIZE_THRESHOLD_CLEARED {
    description
      "The number of flows in the flow-cache table for the NCP is below the configured threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of flows in the flow-cache table for NCP {ncp-id} is below the configured system threshold {threshold}% of the limit ({limit}). The number of flows are ({num-of-flow-entries})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf threshold {
      type uint8;
      description
        "Threshold percentage";
    }
    leaf limit {
      type uint8;
      description
        "Maximum number of flow entries in flow-cache table";
    }
    leaf num-of-flow-entries {
      type uint8;
      description
        "Number of flow entries in flow-cache table";
    }
  }

  notification FLOW_MONITORING_CACHE_SIZE_LIMIT_REACHED {
    description
      "The number of flows in the flow-cache table for the NCP has reached the system limit. Adding new flow entries to the flow-cache table will cause the longest idle flow entries to be aggressively timed out.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of flows in the flow-cache table for NCP {ncp-id} has reached the system limit {limit}, the current rate of sampled packets is {packet-rate}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf limit {
      type uint8;
      description
        "Maximum number of flow entries in flow-cache table";
    }
    leaf packet-rate {
      type uint16;
      description
        "Rate of sampled packets at the moment of system-event generations";
    }
  }

  notification FLOW_MONITORING_CACHE_SIZE_LIMIT_CLEARED {
    description
      "The number of flows in the flow-cache table for the NCP is below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of flows in the flow-cache table for NCP {ncp-id} is below the system limit {limit}, the current rate of sampled packets is {packet-rate}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf limit {
      type uint8;
      description
        "Maximum number of flow entries in flow-cache table";
    }
    leaf packet-rate {
      type uint16;
      description
        "Rate of sampled packets at the moment of system-event generations";
    }
  }

  notification FLOW_MONITORING_SAMPLING_RATE_LIMIT_REACHED {
    description
      "The rate of sampled flow packets for the NCP has reached the system limit. Some sampled packets will not be processed.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Rate of sampled flow packets for NCP {ncp-id} has reached the system limit of rate {limit}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf limit {
      type uint8;
      description
        "Rate of sampled packets for flow monitoring";
    }
  }

  notification FLOW_MONITORING_SAMPLING_RATE_LIMIT_CLEARED {
    description
      "The rate of sampled flow packets for the NCP is below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Rate of sampled flow packets for NCP {ncp-id} is below the system limit of rate {limit}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf limit {
      type uint8;
      description
        "Rate of sampled packets for flow monitoring";
    }
  }

  notification FLOW_MONITORING_CACHE_OVERFLOWS_DROPPED {
    description
      "Some flows that were removed from the cache (due to timeout or cache flush) could not be exported since cache-rate-limit was exceeded.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Timeout flows were not exported on NCP {ncp-id} due to cache-rate-limit exceed. The accumulative number of cache overflows on the NCP is {overflow-counter}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf overflow-counter {
      type uint32;
      description
        "Total number of overflows in the cache";
    }
  }

  notification FLOW_MONITORING_CACHE_OVERLOADED_DROPPED {
    description
      "Some flows that were removed from the cache (due to timeout or cache flush) could not be exported due to system overload on the from-us direction.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Timeout flows were not exported on NCP {ncp-id} due to system overload on the from-us direction, the reason is {reason}. The accumulative number of cache overloaded dropped flows on the NCP is {overloaded-drop}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf overloaded-drop {
      type uint32;
      description
        "Total number of dropped exported flows due to overloaded system on the from-us direction";
    }
    leaf reason {
      type string;
      description
        "The reason for system overload on the from-us direction";
    }
  }

  // BFD events

  notification BFD_STATE_UP {
    description
      "The BFD session changed to an 'up' state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "BFD session {local-address} to {remote-address} has changed state from {old-state} to UP. BFD session information: "
                                            + "local discriminator {local-discriminator}, remote-discriminator {remote-discriminator}, "
                                            + "session diagnostic {session-diagnostic}, protecting {clients}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "BFD";
    dn-events-extensions:event-group "BFD";
    dn-events-extensions:event-snmp-trap-name "dnBfdSessionUp";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.3.0.1";
    dn-events-extensions:event-snmp-trap-vars "dnBfdVersion.0 {bfd-version}; dnAddressType.0 {address-type}; dnLocalAddress.0 CONVERT inetAddr({address-type}) {local-address}; dnRemoteAddress.0 CONVERT inetAddr({address-type}) {remote-address}; dnRemotePort.0 {remote-port}; dnLocalDiscriminator.0 {local-discriminator}; dnRemoteDiscriminator.0 {remote-discriminator}; dnClients.0 {clients}; dnSessionDiagnostic.0 {session-diagnostic}";
    leaf old-state {
      description
        "Session old state, Down, Init, Admin-Down";
      type enumeration {
        enum Down;
        enum Init;
        enum Admin-Down;
      }
    }
    leaf clients {
      description
        "All registered clients for the BFD session, e.g BGP, static, interface,...";
      type string;
    }
    leaf bfd-version {
      description
        "BFD protocol version in use";
      type uint32;
    }
    leaf address-type {
      description
        "This object specifies the IP address type of the source IP
         address of this BFD session.  The value of unknown(0) is
         allowed only when the session is singleHop(1) and the
         source IP address of this BFD session is derived from
         the outgoing interface, or when the BFD session is not
         associated with a specific interface.  If any other
         unsupported values are attempted in a set operation, the
         agent MUST return an inconsistentValue error.";
      type enumeration {
        enum unknown {
          value 0;
        }
        enum ipv4 {
          value 1;
        }
        enum ipv6 {
          value 2;
        }
        enum dns {
          value 16;
        }
      }
    }
    leaf local-address {
      description
        "BFD IP address on local system";
      type string;
    }
    leaf remote-address {
      description
        "BFD IP address on remote system";
      type string;
    }
    leaf remote-port {
      description
        "BFD UDP port number on remote system";
      type uint32 {
        range "0..65535";
      }
    }
    leaf local-discriminator {
      description
        "A unique, nonzero discriminator value generated by the transmitting system";
      type uint32;
    }
    leaf remote-discriminator {
      description
        "A unique discriminator value received from remote system, if unknown , set to 0";
      type uint32;
    }
    leaf session-diagnostic {
      description
        "Session diagnostic code from last received bfd msg for dnBfdObjects - should be (0) for bfdSessionDown - should be either (4),(5),(6),(7)";
      type enumeration {
        enum no-diagnostic {
          value 0;
        }
        enum control-detection-time-expired {
          value 1;
        }
        enum echo-function-failed {
          value 2;
        }
        enum neighbor-signaled-session-down {
          value 3;
        }
        enum forwarding-plane-reset {
          value 4;
        }
        enum path-down {
          value 5;
        }
        enum concatenated-path-down {
          value 6;
        }
        enum administratively-down {
          value 7;
        }
        enum reverse-concatenated-path-down {
          value 8;
        }
        enum mis-connectivity-defect {
          value 9;
        }
      }
    }
  }

  notification BFD_STATE_DOWN {
    description
      "The BFD session changed to a 'down' or 'Admin-down' state.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "BFD session {local-address} to {remote-address} has changed state from {old-state} to {new-state}. BFD session information: "
                                            + "local discriminator {local-discriminator}, remote-discriminator {remote-discriminator}, "
                                            + "session diagnostic {session-diagnostic}, protecting {clients}";
    dn-events-extensions:event-corrective-action-string "Check the connectivity to the neighbor.";
    dn-events-extensions:event-trigger-component-string "BFD";
    dn-events-extensions:event-group "BFD";
    dn-events-extensions:event-snmp-trap-name "dnBfdSessionDown";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.3.0.2";
    dn-events-extensions:event-snmp-trap-vars "dnBfdVersion.0 {bfd-version}; dnAddressType.0 {address-type}; dnLocalAddress.0 CONVERT inetAddr({address-type}) {local-address}; dnRemoteAddress.0 CONVERT inetAddr({address-type}) {remote-address}; dnRemotePort.0 {remote-port}; dnLocalDiscriminator.0 {local-discriminator}; dnRemoteDiscriminator.0 {remote-discriminator}; dnClients.0 {clients}; dnSessionDiagnostic.0 {session-diagnostic}";
    leaf old-state {
      description
        "Session old state, Down, Init, Admin-Down, Up";
      type enumeration {
        enum Down;
        enum Init;
        enum Admin-Down;
        enum Up;
      }
    }
    leaf new-state {
      description
        "Session new state, Down or Admin-Down";
      type enumeration {
        enum Down;
        enum Admin-Down;
      }
    }
    leaf clients {
      description
        "All registered clients for the BFD session, e.g BGP, static, interface,...";
      type string;
    }
    leaf bfd-version {
      description
        "BFD protocol version in use.";
      type uint32;
    }
    leaf address-type {
      description
        "This object specifies the IP address type of the source IP
         address of this BFD session.  The value of unknown(0) is
         allowed only when the session is singleHop(1) and the
         source IP address of this BFD session is derived from
         the outgoing interface, or when the BFD session is not
         associated with a specific interface.  If any other
         unsupported values are attempted in a set operation, the
         agent MUST return an inconsistentValue error.";
      type enumeration {
        enum unknown {
          value 0;
        }
        enum ipv4 {
          value 1;
        }
        enum ipv6 {
          value 2;
        }
        enum dns {
          value 16;
        }
      }
    }
    leaf local-address {
      description
        "BFD IP address on local system";
      type string;
    }
    leaf remote-address {
      description
        "BFD IP address on remote system";
      type string;
    }
    leaf remote-port {
      description
        "BFD UDP port number on remote system";
      type uint32 {
        range "0..65535";
      }
    }
    leaf local-discriminator {
      description
        "A unique, nonzero discriminator value generated by the transmitting system";
      type uint32;
    }
    leaf remote-discriminator {
      description
        "A unique discriminator value received from remote system, if unknown , set to 0";
      type uint32;
    }
    leaf session-diagnostic {
      description
        "Session diagnostic code from last received bfd msg for dnBfdObjects - should be (0) for bfdSessionDown - should be either (4),(5),(6),(7)";
      type enumeration {
        enum no-diagnostic {
          value 0;
        }
        enum control-detection-time-expired {
          value 1;
        }
        enum echo-function-failed {
          value 2;
        }
        enum neighbor-signaled-session-down {
          value 3;
        }
        enum forwarding-plane-reset {
          value 4;
        }
        enum path-down {
          value 5;
        }
        enum concatenated-path-down {
          value 6;
        }
        enum administratively-down {
          value 7;
        }
        enum reverse-concatenated-path-down {
          value 8;
        }
        enum mis-connectivity-defect {
          value 9;
        }
      }
    }
  }

  notification BFD_INTERNAL_ERROR {
    description
      "The BFD process failed due to an internal error.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "BFD encountered an error: {error-type}, {error-message}. BFD location {bfd-location}";
    dn-events-extensions:event-corrective-action-string "Copy the error message and contact Customer Support.";
    dn-events-extensions:event-trigger-component-string "BFD";
    dn-events-extensions:event-group "BFD";
    leaf error-type {
      type string;
      description
        "Error group type";
    }
    leaf error-message {
      type string;
      description
        "Error description";
    }
    leaf bfd-location {
      description
        "Which node runs the BFD session. e.g NCP <id>";
      type string;
    }
  }

  notification BFD_MAXIMUM_SESSIONS_LIMIT_REACHED {
    description
      "The number of BFD sessions have reached the maximum system limit of supported sessions.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of BFD sessions has reached system limit of {limit} sessions. The current number of sessions is {session-number}";
    dn-events-extensions:event-corrective-action-string "Remove low priority sessions.";
    dn-events-extensions:event-trigger-component-string "BFD";
    dn-events-extensions:event-group "BFD";
    leaf limit {
      type uint16;
      description
        "Maximum number of sessions";
    }
    leaf session-number {
      type uint16;
      description
        "Current number of BFD sessions";
    }
  }

  notification BFD_MAXIMUM_SESSIONS_LIMIT_CLEARED {
    description
      "The number of BFD sessions have moved below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of BFD sessions is below the system limit of {limit}. The current number of sessions is {session-number}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "bfd";
    dn-events-extensions:event-group "BFD";
    leaf limit {
      type uint16;
      description
        "Maximum number of sessions";
    }
    leaf session-number {
      type uint16;
      description
        "Current number of BFD sessions";
    }
  }

  notification BFD_MAXIMUM_SESSIONS_THRESHOLD_EXCEEDED {
    description
      "The number of BFD sessions have crossed the system threshold for the number of supported sessions.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Number of BFD sessions have crossed the system threshold {threshold}% of the limit ({limit}). The current number of BFD sessions is {session-number}";
    dn-events-extensions:event-corrective-action-string "Remove low priority sessions.";
    dn-events-extensions:event-trigger-component-string "BFD";
    dn-events-extensions:event-group "BFD";
    leaf threshold {
      type uint8;
      description
        "Limit percent threshold";
    }
    leaf limit {
      type uint16;
      description
        "Maximum number of sessions";
    }
    leaf session-number {
      type uint16;
      description
        "Current number of BFD sessions";
    }
  }

  notification BFD_MAXIMUM_SESSIONS_THRESHOLD_CLEARED {
    description
      "The number of BFD sessions have moved below the system threshold of supported sessions.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of BFD sessions is below the system threshold {threshold}% of the limit ({limit}). The number of BFD sessions is {session-number}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "BFD";
    dn-events-extensions:event-group "BFD";
    leaf threshold {
      type uint8;
      description
        "Limit percent threshold";
    }
    leaf limit {
      type uint16;
      description
        "Maximum number of sessions";
    }
    leaf session-number {
      type uint16;
      description
        "Current number of BFD sessions";
    }
  }

  notification BFD_SUPPRESSED {
    description
      "The BFD session have been suppressed due to BFD dampening.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "BFD session {local_address} to {remote_address} have been suppressed. BFD session information: local discriminator {local_discriminator}, remote_discriminator {remote_discriminator}, protecting {clients}";
    dn-events-extensions:event-corrective-action-string "No corrective action is required.";
    dn-events-extensions:event-trigger-component-string "BFD";
    dn-events-extensions:event-group "BFD";
    leaf clients {
      description
        "All registered clients for the BFD session, e.g BGP, static, interface,...";
      type string;
    }
    leaf local-address {
      description
        "BFD IP address on local system";
      type string;
    }
    leaf remote-address {
      description
        "BFD IP address on remote system";
      type string;
    }
    leaf local-discriminator {
      description
        "A unique, nonzero discriminator value generated by the transmitting system";
      type uint32;
    }
    leaf remote-discriminator {
      description
        "A unique discriminator value received from remote system, if unknown , set to 0";
      type uint32;
    }
  }

  notification BFD_SUPPRESS_ENDED {
    description
      "BFD change suppression has ended because either the BFD dampening penalty decay is below the reuse threshold, the maximum suppression timer has expired, or the penalty was manually cleared.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "BFD session {local_address} to {remote_address} suppression ended, due to {suppression_end_reason}. BFD session information: local discriminator {local_discriminator}, remote_discriminator {remote_discriminator}, protecting {clients}";
    dn-events-extensions:event-corrective-action-string "No corrective action is required.";
    dn-events-extensions:event-trigger-component-string "BFD";
    dn-events-extensions:event-group "BFD";
    leaf clients {
      description
        "All registered clients for the BFD session, e.g BGP, static, interface,...";
      type string;
    }
    leaf local-address {
      description
        "BFD IP address on local system";
      type string;
    }
    leaf remote-address {
      description
        "BFD IP address on remote system";
      type string;
    }
    leaf local-discriminator {
      description
        "A unique, nonzero discriminator value generated by the transmitting system";
      type uint32;
    }
    leaf remote-discriminator {
      description
        "A unique discriminator value received from remote system, if unknown , set to 0";
      type uint32;
    }
    leaf suppression-end-reason {
      type enumeration {
        enum penalty-decayed-below-reuse-threshold {
          value 0;
        }
        enum max-suppress-timer-expired {
          value 1;
        }
        enum penalty-cleared-manually {
          value 2;
        }
        enum zero-reset {
          value 3;
        }
      }
      description
        "BFD state suppress end reasons";
    }
  }

  notification DNS_SERVER_CONFIG {
    description
      "A DNS server was added/removed to/from the system.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} has {action} DNS server {server-address} on VRF {vrf-name}, server's admin-state {admin-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "System";
    leaf user-name {
      type string;
      description
        "User-name of the user who add/removed DNS server";
    }
    leaf action {
      type string;
      description
        "Configuration action (added/removed)";
    }
    leaf server-address {
      type string;
      description
        "IP address of DNS server that was added/removed";
    }
    leaf vrf-name {
      type string;
      description
        "Name of the VRF";
    }
    leaf admin-state {
      description
        "DNS server admin-state";
      type enumeration {
        enum disabled;
        enum enabled;
      }
    }
  }

  // LDP System events and SNMP traps

  notification LDP_HELLO_ADJACENCY_UP {
    description
      "LDP received discovery hellos on the listed interface. Adjacency has moved to an 'up' state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "LDP interface adjacency on interface {if-name} is up";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "LDP";
    dn-events-extensions:event-group "LDP";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
  }

  notification LDP_HELLO_ADJACENCY_DOWN {
    description
      "LDP stopped receiving discovery hellos on the listed interface. Adjacency has moved to 'down' state.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "LDP interface adjacency on interface {if-name} is down";
    dn-events-extensions:event-corrective-action-string "No corrective action required.";
    dn-events-extensions:event-trigger-component-string "LDP";
    dn-events-extensions:event-group "LDP";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
  }

  notification LDP_TARGETED_HELLO_ADJACENCY_UP {
    description
      "LDP has received discovery hellos from the targeted side. Adjacency has moved to an 'up' state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Targeted LDP adjacency to {ip-address} is up";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "LDP";
    dn-events-extensions:event-group "LDP";
    leaf ip-address {
      type string;
      description
        "Targeted ip-address";
    }
  }

  notification LDP_TARGETED_HELLO_ADJACENCY_DOWN {
    description
      "LDP has stopped receiving discovery hellos from the targeted side. Adjacency has moved to a 'down' state.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Targeted LDP adjacency to {ip-address} is down";
    dn-events-extensions:event-corrective-action-string "No corrective action required.";
    dn-events-extensions:event-trigger-component-string "LDP";
    dn-events-extensions:event-group "LDP";
    leaf ip-address {
      type string;
      description
        "Targeted ip-address";
    }
  }

  notification LDP_TARGETED_HELLO_DISCARDED {
    description
      "The received targeted hello was discarded.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Discarded received targeted hello from {ip-address}";
    dn-events-extensions:event-corrective-action-string "Check if the targeted accept message is enabled and that the peer is allowed according to the allowed-peer filter list.";
    dn-events-extensions:event-trigger-component-string "LDP";
    dn-events-extensions:event-group "LDP";
    leaf ip-address {
      type string;
      description
        "Targeted ip-address";
    }
  }

  notification LDP_IGP_SYNC {
    description
      "This event is triggered when LDP synchronization with IGP has either started or completed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "LDP synchronization. Status: {sync-state} on interface: {if-name}. Sync delay time: {sync-delay}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "LDP";
    dn-events-extensions:event-group "LDP";
    leaf sync-state {
      description
        "The synchronization state";
      type enumeration {
        enum in-progress {
          value 1;
        }
        enum completed {
          value 2;
        }
      }
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf sync-delay {
      type uint16;
      description
        "Synchronization delay in seconds";
    }
  }

  notification LDP_IGP_TUNNELING_SYNC {
    description
      "This event is triggered when LDP synchronization with IGP that is using RSVP tunnels, has either started or completed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "LDP IGP-Tunneling synchronization. Status: {sync-state} for {tunnel-origin} tunnel {tunnel-name} with destination address {ipv4-address}. Sync delay time: {sync-delay}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "LDP";
    dn-events-extensions:event-group "LDP";
    leaf sync-state {
      description
        "The synchronization state";
      type enumeration {
        enum in-progress {
          value 1;
        }
        enum completed {
          value 2;
        }
      }
    }
    leaf tunnel-origin {
      description
        "origin of the tunnel used for ldp tunneling, either RSVP or SR-TE";
      type enumeration {
        enum RSVP;
        enum SR-TE;
      }
    }
    leaf tunnel-name {
      description
        "the name of the head-end rsvp tunnel enabled for ldp-sync for which no ldp session exist with tunnel destination";
      type string;
    }
    leaf ipv4-address {
      type string;
      description
        "Targeted ip-address";
    }
    leaf sync-delay {
      type uint16;
      description
        "synchronization delay in seconds";
    }
  }

  notification LDP_SESSION_UP {
    description
      "The LDP session state has moved to an 'up' state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "LDP session with neighbor {neighbor-ip-address} is up. The TCP port is {session-tcp-port}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "LDP";
    dn-events-extensions:event-group "LDP";
    dn-events-extensions:event-snmp-trap-name "mplsLdpSessionUp";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.10.166.4.0.3";
    dn-events-extensions:event-snmp-trap-vars "mplsLdpSessionState.0 {ldp-session-state}; mplsLdpSessionDiscontinuityTime.0 {session-discontinuity-time}; mplsLdpSessionStatsUnknownMesTypeErrors.0 {session-stats-unknown-mes-type-errors}; mplsLdpSessionStatsUnknownTlvErrors.0 {session-stats-unknown-tlv-errors}";
    leaf neighbor-ip-address {
      type string;
      description
        "Neighbor IP address e.g. 1.2.3.4";
    }
    leaf session-tcp-port {
      type uint16;
      description
        "The neighbor's LDP session TCP port";
    }
    leaf ldp-session-state {
      description
        "The current state of the session, all of the
         states 1 to 5 are based on the state machine for session negotiation behavior";
      type enumeration {
        enum nonexistent {
          value 1;
        }
        enum initialized {
          value 2;
        }
        enum openrec {
          value 3;
        }
        enum opensent {
          value 4;
        }
        enum operational {
          value 5;
        }
      }
    }
    leaf session-discontinuity-time {
      type uint32;
      description
        "The sysUpTime (in hundredths of a second) on the most recent occasion at which any one or more of this LDP session's counters
         suffered a discontinuity";
    }
    leaf session-stats-unknown-mes-type-errors {
      type uint32;
      description
        "This object counts the number of Unknown Message Type
         Errors detected by this LSR/LER during this session.
         Discontinuities in the value of this counter can occur
         at reinitialization of the management system, and at
         other times as indicated by the value of
         mplsLdpSessionDiscontinuityTime";
    }
    leaf session-stats-unknown-tlv-errors {
      type uint32;
      description
        "This object counts the number of Unknown TLV Errors
         detected by this LSR/LER during this session.
         Discontinuities in the value of this counter can occur
         at reinitialization of the management system, and at
         other times as indicated by the value of
         mplsLdpSessionDiscontinuityTime";
    }
  }

  notification LDP_SESSION_DOWN {
    description
      "The LDP session has moved to a 'down' state.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "LDP session with neighbor {neighbor-ip-address} is down. The TCP port is {session-tcp-port}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "LDP";
    dn-events-extensions:event-group "LDP";
    dn-events-extensions:event-snmp-trap-name "mplsLdpSessionDown";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.10.166.4.0.4";
    dn-events-extensions:event-snmp-trap-vars "mplsLdpSessionState.0 {ldp-session-state}; mplsLdpSessionDiscontinuityTime.0 {session-discontinuity-time}; mplsLdpSessionStatsUnknownMesTypeErrors.0 {session-stats-unknown-mes-type-errors}; mplsLdpSessionStatsUnknownTlvErrors.0 {session-stats-unknown-tlv-errors}";
    leaf neighbor-ip-address {
      type string;
      description
        "Neighbor IP address e.g. 1.2.3.4";
    }
    leaf session-tcp-port {
      type uint16;
      description
        "The neighbor's LDP session TCP port";
    }
    leaf ldp-session-state {
      description
        "The current state of the session, all of the
         states 1 to 5 are based on the state machine for session negotiation behavior";
      type enumeration {
        enum nonexistent {
          value 1;
        }
        enum initialized {
          value 2;
        }
        enum openrec {
          value 3;
        }
        enum opensent {
          value 4;
        }
        enum operational {
          value 5;
        }
      }
    }
    leaf session-discontinuity-time {
      type uint32;
      description
        "The sysUpTime (in hundredths of a second) on the most recent occasion at which any one or more of this LDP session's counters
         suffered a discontinuity";
    }
    leaf session-stats-unknown-mes-type-errors {
      type uint32;
      description
        "This object counts the number of Unknown Message Type
         Errors detected by this LSR/LER during this session.
         Discontinuities in the value of this counter can occur
         at reinitialization of the management system, and at
         other times as indicated by the value of
         mplsLdpSessionDiscontinuityTime";
    }
    leaf session-stats-unknown-tlv-errors {
      type uint32;
      description
        "This object counts the number of Unknown TLV Errors
         detected by this LSR/LER during this session.
         Discontinuities in the value of this counter can occur
         at reinitialization of the management system, and at
         other times as indicated by the value of
         mplsLdpSessionDiscontinuityTime";
    }
  }

  notification LDP_NSR_RECOVERY_START {
    description
      "The system has started LDP Non-Stop Routing recovery due to a restart of the ldpd process.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "ldpd process is starting a Non-Stop Routing recovery attempt due to process restart";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "LDP";
    dn-events-extensions:event-group "LDP";
  }

  notification LDP_NSR_RECOVERED {
    description
      "The system performed an LDP Non-Stop Routing recovery due to a restart of the ldpd process.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "LDP Non-Stop Routing recovery was performed due to a restart of the ldpd process";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "LDP";
    dn-events-extensions:event-group "LDP";
  }

  notification LDP_NSR_RECOVERY_FAILED {
    description
      "The LDP process failed to recover in Non-Stop Routing mode.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "LDP process failed to recover in Non-Stop Routing mode";
    dn-events-extensions:event-corrective-action-string "Verify NSR readiness prior to the failure event.";
    dn-events-extensions:event-trigger-component-string "ldp";
    dn-events-extensions:event-group "LDP";
  }

  notification LDP_NSR_DB_NOT_SYNC {
    description
      "The standby NCC LDP Non-Stop Routing database is not synchronized. LDP will not recover in Non-Stop Routing mode if a system switchover occurs.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Standby NCC LDP NSR database is not synchronized. LDP will not recover in Non-Stop Routing mode if a system switchover occurs";
    dn-events-extensions:event-corrective-action-string "Verify connectivity to the standby NCC.";
    dn-events-extensions:event-trigger-component-string "ldp";
    dn-events-extensions:event-group "LDP";
  }

  notification LDP_NSR_DB_SYNC {
    description
      "The standby NCC LDP Non-Stop Routing database is synchronized.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Standby NCC LDP NSR database is synchronized";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ldp";
    dn-events-extensions:event-group "LDP";
  }

