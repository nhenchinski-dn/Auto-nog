    }
  }

  notification TOTAL_EVPN_MAC_IP_TABLE_THRESHOLD_CLEARED {
    description
      "MAC-IP Table entries have been removed, the total number of MAC-IP entries is below the 85% threshold of the limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The total number of MAC-IP entries for all services has dropped below the 85% threshold of the limit {limit}, the current number of entries is {numeric-value}.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
