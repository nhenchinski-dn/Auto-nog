      "NCE reached high level of tasks number running";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "NCE {nce}-{nce-id} reached high level of task number {tasks-number}.";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "Operational-infra";
    dn-events-extensions:event-group "Monitoring";
    leaf nce {
      description
        "Name of element where the process resides, NCC, NCF, NCP";
      type string;
    }
    leaf nce-id {
      description
        "ID of the NCE element";
      type string;
    }
    leaf tasks-number {
      type uint16;
      description
        "Number of tasks running on the NCE";
    }
  }

  notification SYSTEM_NCE_HIGH_TASKS_NO_LEVEL_CLEARED {
    description
      "The number of tasks running on the NCE went below the high level";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of tasks running on NCE {nce}-{nce-id} is {tasks-number} and is below the high level";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "Operational-infra";
    dn-events-extensions:event-group "Monitoring";
    leaf nce {
      description
        "Name of element where the process resides, NCC, NCF, NCP";
      type string;
    }
    leaf nce-id {
      description
        "ID of the NCE element";
      type string;
    }
    leaf tasks-number {
      type uint16;
      description
        "Number of tasks running on the NCE";
    }
  }

  // FIB events

  notification FIB_INSTALL_ERROR {
    description
      "An NCP failed to install a FIB element";
    dn-events-extensions:event-severity-level "Critical";
    dn-events-extensions:event-message-string "NCP {ncp-id} failed to install {fib-object}, due to {error-reason}";
    dn-events-extensions:event-corrective-action-string "Verify routing hasn't exceeded the supported system scale";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "fib-manager";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf fib-object {
      type string;
      description
        "type of fib fib object - route , label or nexthop. followed by object detail
         route - the prefix
         label - label value
         nexthop - nexthop address, egress interface and label";
    }
    leaf error-reason {
      type string;
      description
        "error reason for installation failure - can be HW received error, missing id, etc...";
    }
  }

  notification FIB_EGRESS_OBJECT_LIMIT_REACHED {
    description
      "The number of FIB egress objects has reached the maximum number of system supported scale.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of FIB egress objects has reached the system maximum scale limit of {limit}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf limit {
      type uint8;
      description
        "System FIB egress objects max limit";
    }
  }

  notification FIB_EGRESS_OBJECT_LIMIT_CLEARED {
    description
      "The number of FIB egress objects is below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of FIB egress objects is below the system limit of {limit}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf limit {
      type uint16;
      description
        "System FIB egress objects max limit";
    }
  }

  notification FIB_EGRESS_OBJECT_THRESHOLD_EXCEEDED {
    description
      "The number of FIB egress objects crossed the maximum supported threshold.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of FIB egress objects has crossed the system threshold {threshold}% of the limit ({limit}), the number of FIB egress objects is ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of FIB egress objects";
    }
    leaf limit {
      type uint16;
      description
        "System FIB egress objects max limit";
    }
  }

  notification FIB_EGRESS_OBJECT_THRESHOLD_CLEARED {
    description
      "The number of FIB egress objects is below the threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of FIB egress objects is below the threshold {threshold}% of the limit ({limit}), the number of FIB egress objects is ({numeric-value})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf numeric-value {
      type uint16;
      description
        "Current number of FIB egress objects";
    }
    leaf limit {
      type uint16;
      description
        "System FIB egress objects max limit";
    }
  }

  notification FIB_WECMP_PROFILE_THRESHOLD_REACHED {
    description
      "The number of FIB weighted ecmp hardware profiles crossed the maximum supported threshold.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "NCP {ncp-id}: Number of FIB Weighted ECMP profiles has crossed the system threshold of {threshold}% of overall system support. Using {small} small Weighted ECMP profiles and {medium} medium Weighted ECMP proiles";
    dn-events-extensions:event-corrective-action-string "Reduce ECMP maximum-path";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf small {
      type uint16;
      description
        "Current number of small profile tables";
    }
    leaf medium {
      type uint16;
      description
        "Current number of medium profile tables";
    }
  }

  notification FIB_WECMP_PROFILE_THRESHOLD_CLEARED {
    description
      "The number of FIB weighted ecmp hardware profiles is below the maximum supported threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "NCP {ncp-id}: Number of FIB Weighted ECMP profiles is below {threshold}% of overall system support. Using {small} small Weighted ECMP profiles and {medium}  Weighted ECMP proiles";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf threshold {
      type uint8;
      description
        "Threshold percent";
    }
    leaf small {
      type uint16;
      description
        "Current number of small profile tables";
    }
    leaf medium {
      type uint16;
      description
        "Current number of medium profile tables";
    }
  }

  notification FIB_FAILED_TO_ALLOCATE_WECMP_PROFILE {
    description
      "FIB failed to provide weighted ecmp routing entry and will fallback to uniform ecmp";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "NCP {ncp-id}: FIB failed to allocate Weighted ECMP profile due to {failure-reason}. Uniform ECMP will be provided. Required weighted ECMP structure {weight-group} for nexthop-oid {nhoid}";
    dn-events-extensions:event-corrective-action-string "Reduce ECMP maximum-path";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf failure-reason {
      type string;
      description
        "string of failure reason. For example, 'out of resource'";
    }
    leaf weight-group {
      type string;
      description
        "list specifing the required profile. number of members and weight of each member";
    }
    leaf nhoid {
      type string;
      description
        "the nhoid that required the weighted ecmp group";
    }
  }

  notification NCP_FIB_DISCONNECTED_FROM_RIB {
    description
      "The FIB installation disconnected from the RIB on the listed NCP.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "NCP {ncp-id} FIB disconnected from RIB. Routing updates will not be installed for the NCP";
    dn-events-extensions:event-corrective-action-string "Verify the NCP backplane control connectivity and check the control drop counters.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
  }

  notification NCP_FIB_CONNECTED_TO_RIB {
    description
      "The listed  NCP connected to the  RIB for FIB installations.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "NCP {ncp-id} FIB connected to RIB. Routing updates will be installed for the NCP";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "fib-manager";
    dn-events-extensions:event-group "fib-manager";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
  }

  // HA events

  notification NCC_FAILOVER {
    description
      "The system triggered the NCC switchover. The reason for switchover can vary from an NCC node failure to a failure of a non-restartable process.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "Active NCC failover from {ncc-id-failed} to {ncc-id-stb}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    dn-events-extensions:event-snmp-trap-name "dnNccFailover";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.4.1.49739.2.9.0.1";
    dn-events-extensions:event-snmp-trap-vars "dnNccIdFailed.0 {ncc-id-failed} ; dnNccIdStb.0 {ncc-id-stb}";
    leaf ncc-id-failed {
      type uint8;
      description
        "Active NCC ID that has failed";
    }
    leaf ncc-id-stb {
      type uint8;
      description
        "Standby NCC ID that takes over from the failed NCC";
    }
  }

  notification NCC_SWITCHOVER_USER {
    description
      "The user has requested an NCC switchover";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} has requested NCC switchover from NCC {ncc-id-active} to NCC {ncc-id-old-standby}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    dn-events-extensions:event-snmp-trap-name "dnNccSwitchoverUser";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.4.1.49739.2.9.0.2";
    dn-events-extensions:event-snmp-trap-vars "dnUserName.0 {user-name} ; dnNccIdAct.0 {ncc-id-active} ; dnNccOldStb.0 {ncc-id-old-standby}";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf ncc-id-active {
      type uint8;
      description
        "Active NCC ID on which user requested switchover";
    }
    leaf ncc-id-old-standby {
      type uint8;
      description
        "Standby NCC ID for which user requested switchover to";
    }
  }

  notification NCC_PRIMARY_CONFIG_CHANGE {
    description
      "The user has configured the indicated NCC to be the preferred primary NCC.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} has configured NCC {ncc-id} to be the preferred primary NCC for the DNOS cluster";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf ncc-id {
      type uint8;
      description
        "NCC ID";
    }
  }

  notification SYSTEM_COLD_START {
    description
      "The system has started (cold start).";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "System has started (cold start)";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    dn-events-extensions:event-snmp-trap-name "coldStart";
    dn-events-extensions:event-snmp-trap-generic-type "coldStart";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.6.3.1.1.5.1";
    dn-events-extensions:event-snmp-trap-reachability "True";
  }

  notification SYSTEM_WARM_START {
    description
      "The system has started (warm start).";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "System has started (warm start)";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    dn-events-extensions:event-snmp-trap-name "warmStart";
    dn-events-extensions:event-snmp-trap-generic-type "warmStart";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.6.3.1.1.5.2";
    dn-events-extensions:event-snmp-trap-reachability "True";
  }

  notification SYSTEM_PROCESS_HELD_DOWN {
    description
      "The system process is held down by high-availability policy due to multiple HA violations.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Process {nce}-{nce-id}:{container-name} : {process-name} is held down by high-availability policy.";
    dn-events-extensions:event-corrective-action-string "Manually restart process to bring it back up";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    leaf nce {
      description
        "name of element which process resign, ncc, ncf, ncp";
      type string;
    }
    leaf nce-id {
      description
        "id of the nce element";
      type string;
    }
    leaf process-name {
      type string;
      description
        "System process name (e.g. bgpd, ospfd, CLI)";
    }
    leaf container-name {
      type string;
      description
        "System container name (e.g. routing-engine)";
    }
  }

  notification SYSTEM_PROCESS_STOP {
    description
      "The listed user stopped the system process.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "User {user-name} stopped process {nce}-{nce-id} : {container-name} : {process-name}.";
    dn-events-extensions:event-corrective-action-string "Restart the process to start the process.";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf nce {
      description
        "name of element which process resign, ncc, ncf, ncp";
      type string;
    }
    leaf nce-id {
      description
        "id of the nce element";
      type string;
    }
    leaf process-name {
      type string;
      description
        "System process name (e.g. bgpd, ospfd, CLI)";
    }
    leaf container-name {
      type string;
      description
        "System container name (e.g. routing-engine)";
    }
  }

  notification SYSTEM_PROCESS_RESTART {
    description
      "The system has restarted the process indicated due to a process failure.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "System restarted the process {nce}-{nce-id}:{container-name} : {process-name}. {error-message}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    leaf nce {
      description
        "Name of element where the process resides, NCC, NCF, NCP";
      type string;
    }
    leaf nce-id {
      description
        "ID of the NCE element";
      type string;
    }
    leaf process-name {
      type string;
      description
        "System process name (e.g. bgpd, ospfd, CLI)";
    }
    leaf container-name {
      type string;
      description
        "System container name (e.g. routing-engine)";
    }
    leaf error-message {
      type string;
      description
        "Error description or reason";
    }
  }

  notification SYSTEM_PROCESS_HA_VIOLATION {
    description
      "The system process has violated the high-availability policy.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "System process {nce}-{nce-id}:{container-name} : {process-name} "
                                            + "has violated the high-availability policy. Process exited {num-mitigation} times in {period} seconds. "
                                            + "High-availability escalation action: {escalation-action}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    leaf nce {
      description
        "Name of element where the process resides, NCC, NCF, NCP";
      type string;
    }
    leaf nce-id {
      description
        "ID of the NCE element";
      type string;
    }
    leaf process-name {
      type string;
      description
        "System process name (e.g. bgpd, ospfd, CLI)";
    }
    leaf container-name {
      type string;
      description
        "System container name (e.g. routing-engine)";
    }
    leaf num-mitigation {
      description
        "Number of mitigations in period allowed for process per HA policy";
      type string;
    }
    leaf period {
      description
        "Mitigation period duration specified in HA policy. in seconds";
      type string;
    }
    leaf escalation-action {
      description
        "HA action upon the violation, either list of entities restarted";
      type string;
    }
  }

  notification SYSTEM_PROCESS_FAILED {
    description
      "The system has detected that a process failed and is no longer running.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "System process {nce}-{nce-id}:{container-name} : {process-name} failed. Process importance: {importance}";
    dn-events-extensions:event-corrective-action-string "Review process logs for failure reason";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    leaf nce {
      description
        "Name of element where the process resides, NCC, NCF, NCP";
      type string;
    }
    leaf nce-id {
      description
        "ID of the NCE element";
      type string;
    }
    leaf process-name {
      type string;
      description
        "System process name (e.g. bgpd, ospfd, CLI)";
    }
    leaf container-name {
      type string;
      description
        "System container name (e.g. routing-engine)";
    }
    leaf importance {
      description
        "entity HA importance in system, regular, essential or critical";
      type string;
    }
  }

  notification PROCESS_OPERATIONAL_DATA_RESYNC {
    description
      "Process is resynchronizing its operational database. Counters may be reset or suffer discontinuities.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "Process {process-name} is resynchronizing its operational data due to failure to update the datastore. Counters maintained by the process may be reset or suffer discontinuities.";
    dn-events-extensions:event-corrective-action-string "No corrective action required.";
    dn-events-extensions:event-trigger-component-string "Operational-infra";
    dn-events-extensions:event-group "System";
    leaf process-name {
      type string;
      description
        "System process name (e.g. bgpd, ospfd, CLI).";
    }
  }

  notification PROCESS_ABNORMAL_MEMORY_USAGE {
    description
      "System detected abnormal process memory consumption";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "System process {nce}-{nce-id}:{container-name} : {process-name} detected with abnormal memory consumption. Process RSS memory {memory-in-use} KB. Process PID {process-id} exec-cmd {exec-cmd}";
    dn-events-extensions:event-corrective-action-string "Investigate process memory usage. Reduce system scale or restart/stop process. In the case of memory leaks, contact Customer Support.";
    dn-events-extensions:event-trigger-component-string "Operational-infra";
    dn-events-extensions:event-group "Monitoring";
    leaf nce {
      description
        "Name of element where the process resides, NCC, NCF, NCP";
      type string;
    }
    leaf nce-id {
      description
        "ID of the NCE element";
      type string;
    }
    leaf process-name {
      type string;
      description
        "System process name (e.g. bgpd, ospfd, CLI)";
    }
    leaf container-name {
      type string;
      description
        "System container name (e.g. routing-engine)";
    }
    leaf memory-in-use {
      description
        "The amount of RAM used by the process in human readable format";
      type string;
    }
    leaf process-id {
      description
        "process id on baseOS";
      type string;
    }
    leaf exec-cmd {
      description
        "baseOS process execution command";
      type string;
    }
  }

  notification PROCESS_ABNORMAL_MEMORY_USAGE_CLEARED {
    description
      "System process memory consumption stablizied and went below 95% of expected memory upper limit";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "System process {nce}-{nce-id}:{container-name} : {process-name} memory consumption stablizied and went below 95% of expected memory upper limit. Process RSS memory {memory-in-use} KB. Process PID {process-id} exec-cmd {exec-cmd}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Operational-infra";
    dn-events-extensions:event-group "Monitoring";
    leaf nce {
      description
        "Name of element where the process resides, NCC, NCF, NCP";
      type string;
    }
    leaf nce-id {
      description
        "ID of the NCE element";
      type string;
    }
    leaf process-name {
      type string;
      description
        "System process name (e.g. bgpd, ospfd, CLI)";
    }
    leaf container-name {
      type string;
      description
        "System container name (e.g. routing-engine)";
    }
    leaf memory-in-use {
      description
        "The amount of RAM used by the process in human readable format";
      type string;
    }
    leaf process-id {
      description
        "process id on baseOS";
      type string;
    }
    leaf exec-cmd {
      description
        "baseOS process execution command";
      type string;
    }
  }

  notification SYSTEM_CONTAINER_RESTART {
    description
      "The container described in the text was restarted by the system.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "System restarted container {nce}-{nce-id}:{container-name}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    leaf nce {
      description
        "Name of element where the process resides, NCC, NCF, NCP";
      type string;
    }
    leaf nce-id {
      description
        "ID of the NCE element";
      type string;
    }
    leaf container-name {
      type string;
      description
        "System container name (e.g. routing-engine)";
    }
  }

  notification SYSTEM_CONTAINER_HA_VIOLATION {
    description
      "The system container has violated the high-availability policy.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "System container {nce}-{nce-id}:{container-name} "
                                            + "has violated the high-availability policy. Container exited {num-mitigation} times in {period} seconds. "
                                            + "High-availability escalation action: {escalation-action}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "HA-manager";
    dn-events-extensions:event-group "System";
    leaf nce {
      description
        "Name of element where the process resides, NCC, NCF, NCP";
      type string;
    }
    leaf nce-id {
      description
        "ID of the NCE element";
      type string;
    }
    leaf container-name {
      type string;
      description
        "System container name (e.g. routing-engine)";
    }
    leaf num-mitigation {
      description
        "Number of mitigations in period allowed for process per HA policy";
      type string;
    }
    leaf period {
      description
        "Mitigation period duration specified in HA policy. in seconds";
      type string;
    }
    leaf escalation-action {
      description
        "HA action upon the violation, restart node";
      type string;
    }
  }

