  notification PLATFORM_TEMP_SENSOR_STATE_CHANGE {
    description
      "The temperature sensor state changed.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Temperature sensor {sensor-name} in {node-type} {node-id} state changed to {current-state}. Temperature value of the sensor is {temperature-value} {temperature-type}";
    dn-events-extensions:event-corrective-action-string "Check the node environment to identify a cause of the temperature change.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Platform";
    dn-events-extensions:event-snmp-trap-name "dnHwMonTemperatureStateChange";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.4.1.49739.2.7.0.5";
    dn-events-extensions:event-snmp-trap-vars
      "entPhysicalContainedIn.CONVERTIDX(tempSensorID,{node-type},{node-id},{sensor-index}) CONVERT nodeID({node-type}) {node-id};
       dnHwMonTemperatureStatus.CONVERTIDX(tempSensorID,{node-type},{node-id},{sensor-index}) CONVERT sensorOpStC {current-state};
       dnHwMonTemperatureValue.CONVERTIDX(tempSensorID,{node-type},{node-id},{sensor-index}) {temperature-value-snmp};
       dnHwMonTemperatureHighCriticalThreshold.CONVERTIDX(tempSensorID,{node-type},{node-id},{sensor-index}) {high-critical-threshold};
       dnHwMonTemperatureHighWarningThreshold.CONVERTIDX(tempSensorID,{node-type},{node-id},{sensor-index}) {high-warning-threshold}";
    leaf sensor-name {
      type string;
      description
        "Temperature sensor name";
    }
    leaf node-type {
      type string;
      description
        "Node type";
    }
    leaf node-id {
      type string;
      description
        "Node ID";
    }
    leaf current-state {
      type string;
      description
        "Current sensor operational state";
    }
    leaf temperature-value {
      type string;
      description
        "Current measured temperature value";
    }
    leaf temperature-type {
      type string;
      description
        "Celsius / Fahrenheit";
    }
    leaf sensor-index {
      type uint16;
      description
        "Temperature sensor running index";
    }
    leaf temperature-value-snmp {
      type ieeefloat32;
      description
        "Current measured temperature value in degrees Celsius";
    }
    leaf high-warning-threshold {
      type int32;
      description
        "High warning temperature threshold of the sensor in degrees Celsius";
    }
    leaf high-critical-threshold {
      type int32;
      description
        "High critical temperature threshold of the sensor in degrees Celsius";
    }
  }

