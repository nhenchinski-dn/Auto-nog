  notification BGP_IPV6_NEIGHBOR_ADJACENCY_DOWN {
    description
      "The state of the BGP neighbor has changed, the neighbor has moved from an 'up' state to a 'down' state.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: Neighbor {neighbor-address} adjacency is {bgp-peer-state}, due to {reason}";
