      "All of the NCPs in the cluster have changed state to system-down because the number of NCFs in the cluster is below the minimum number required. The minimum number of NCFs is displayed in the field 'configured-min-ncf-threshold'.";
    dn-events-extensions:event-severity-level "Critical";
    dn-events-extensions:event-message-string "Number of active NCF modules in the system is below the expected value ({configured-min-ncf-threshold}), the current number of active ncf modules is {active-ncf}";
