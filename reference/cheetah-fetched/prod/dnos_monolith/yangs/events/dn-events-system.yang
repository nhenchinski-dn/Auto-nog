  notification SSH_SERVER_CLIENT_LIST_CONFIG {
    description
      "The list of restricted users for the SSH server was configured/updated.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "List of restricted users for SSH server was configured/updated in VRF {vrf-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
