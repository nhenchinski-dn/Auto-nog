  notification SSH_SECURITY_MACS_CONFIG {
    description
      "The list of MAC algorithms configured to be used by SSH and NETCONF servers have been updated.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "List of configured MAC algorithms used by SSH and Netconf servers was updated";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "Management";
    dn-events-extensions:event-group "Management";
  }

  notification SSH_SECURITY_CIPHERS_CONFIG {
    description
      "The list of ciphers configured to be used by SSH and NETCONF servers have been updated.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "List of configured ciphers used by SSH and Netconf servers was updated";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "Management";
    dn-events-extensions:event-group "Management";
