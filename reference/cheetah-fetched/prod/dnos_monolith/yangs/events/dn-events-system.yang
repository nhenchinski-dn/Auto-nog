  notification SSH_SECURITY_HOSTKEY_ALGORITHMS_CONFIG {
    description
      "The list of host-Key algorithms configured to be used by SSH and NETCONF servers have been updated.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "List of configured host-Key algorithms used by SSH and Netconf servers was updated";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "Management";
    dn-events-extensions:event-group "Management";
  }

  notification SSH_SECURITY_ACCEPTED_PUBLIC_KEY_ALGORITHMS_CONFIG {
    description
      "The list of accepted public key algorithms configured to be used by SSH and NETCONF servers have been updated.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "List of configured accepted public key algorithms used by SSH and Netconf servers was updated";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "Management";
