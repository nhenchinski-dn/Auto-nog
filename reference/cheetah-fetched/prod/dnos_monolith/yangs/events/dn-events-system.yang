         this tunnel";
    }
    leaf ingress-lsr-id {
      description
        "uint32 value of the tunnel source-address
         SNMP: Identity of the ingress LSR associated with this
         tunnel instance. When the MPLS signalling protocol
         is rsvp(2) this value SHOULD be equal to the Tunnel
         Sender Address in the Sender Template object and MAY
         be equal to the Extended Tunnel Id field in the
         SESSION object. When the MPLS signalling protocol is
         crldp(3) this value SHOULD be equal to the Ingress
         LSR Router ID field in the LSPID TLV object.";
      type uint32;
    }
    leaf egress-lsr-id {
      description
        "uint32 value of the tunnel destination address
         SNMP: Identity of the egress LSR associated with this
         tunnel instance.";
      type uint32;
    }
  }

  notification RSVP_FRR_ACTIVE {
    description
      "The RSVP bypass tunnel has become active and is providing protection for the interface.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "RSVP bypass tunnel {tunnel-name} from {source-address} to {destination-address}, tunnel ID {tunnel-id}, LSP ID {lsp-id} is active. Protecting interface {interface-name}. Protected bandwidth {bandwidth} kbps";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "RSVP";
    dn-events-extensions:event-snmp-trap-name "dnRsvpFrrActive";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.4.1.49739.2.10.0.1";
    dn-events-extensions:event-snmp-trap-vars "dnTunnelName.0 {tunnel-name} ; dnSourceAddress.0 {source-address} ; dnDestinationAddress.0 {destination-address} ; dnTunnelId.0 {tunnel-id} ; dnLspId.0 {lsp-id} ; dnInterfaceName.0 {interface-name} ; dnBandwidth.0 {bandwidth}";
    leaf tunnel-name {
      type string;
      description
        "Tunnel name";
    }
    leaf source-address {
      type string;
      description
        "Tunnel source IPv4 address";
    }
    leaf destination-address {
      type string;
      description
        "Tunnel destination IPv4 address";
    }
    leaf tunnel-id {
      description
        "Tunnel local ID";
      type string;
    }
    leaf lsp-id {
      description
        "LSP ID";
      type string;
    }
    leaf interface-name {
      description
        "Protected interface name";
      type string;
    }
    leaf bandwidth {
      description
        "Aggregated bandwidth of all protected tunnels";
      type string;
    }
  }

  notification RSVP_FRR_INACTIVE {
    description
      "The RSVP bypass tunnel became inactive and no longer provides protection.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "RSVP bypass tunnel {tunnel-name} from {source-address} to {destination-address}, tunnel ID {tunnel-id}, LSP ID {lsp-id} is inactive. Protecting interface {interface-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "RSVP";
    dn-events-extensions:event-snmp-trap-name "dnRsvpFrrInactive";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.4.1.49739.2.10.0.2";
    dn-events-extensions:event-snmp-trap-vars "dnTunnelName.0 {tunnel-name} ; dnSourceAddress.0 {source-address} ; dnDestinationAddress.0 {destination-address} ; dnTunnelId.0 {tunnel-id} ; dnLspId.0 {lsp-id} ; dnInterfaceName.0 {interface-name}";
    leaf tunnel-name {
      type string;
      description
        "Tunnel name";
    }
    leaf source-address {
      type string;
      description
        "Tunnel source IPv4 address";
    }
    leaf destination-address {
      type string;
      description
        "Tunnel destination IPv4 address";
    }
    leaf tunnel-id {
      description
        "Tunnel local ID";
      type string;
    }
    leaf lsp-id {
      description
        "LSP ID";
      type string;
    }
    leaf interface-name {
      description
        "Protected interface name";
      type string;
    }
  }

  notification RSVP_INTERNAL_ERROR {
    description
