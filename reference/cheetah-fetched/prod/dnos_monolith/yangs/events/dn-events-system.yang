  notification IF_BREAKOUT_MODE_STATE_CONFIG {
    description
      "The interface breakout mode configuration has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} changed interface {if-name} breakout mode configuration to {new-mode}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Interfaces";
    leaf user-name {
      type string;
      description
        "User name";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf new-mode {
      type enumeration {
        enum 10g-4x;
        enum 100g-4x;
        enum 200g-2x;
        enum 100g-2x;
        enum 400g-2x;
        enum 200g-4x;
        enum 100g-4x-sdr100;
        enum 400g-4x;
        enum 800g-2x;
        enum none;
      }
      description
        "Interface breakout new mode";
    }
  }

  notification IF_BREAKOUT_HW_LIMITATION_CONFIG {
    description
      "The interface breakout configuration not supported due to hardware limitation.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "Due to hardware limitation, breakout mode of both interfaces {if-name-1} and {if-name-2} must be configured to either 10g-4x or none.";
    dn-events-extensions:event-corrective-action-string "Correct configuration.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Interfaces";
    leaf if-name-1 {
      type string;
      description
        "Interface name";
    }
    leaf if-name-2 {
      type string;
      description
        "Interface name";
    }
  }

  notification IF_MTU_PROFILES_LIMIT_REACHED {
    description
      "The maximum MTU profile configuration (100%) has been reached. No new MTU profiles can be established.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of current MTU profiles has reached the configured limit ({max-mtu-profiles})";
    dn-events-extensions:event-corrective-action-string
      "<p>Update the MTU configuration:</p>
       <ol>
       <li>Run command 'show interfaces' to view the existing MTU configurations.</li>
       <li>Update interface MTU configuration to be similar as other interfaces.</li>
       </ol>";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Interfaces";
    leaf max-mtu-profiles {
      type uint8;
      description
        "Maximum MTU profiles per system";
    }
  }

  notification IF_MTU_PROFILES_LIMIT_CLEARED {
    description
      "The number of MTU profiles has moved below the maximum MTU profile configuration limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of MTU profiles is below the maximum MTU profile limit: ({max-mtu-profiles})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Interfaces";
    leaf max-mtu-profiles {
      type uint8;
      description
        "Maximum MTU profiles per system";
    }
  }

  notification IF_VLAN_EDITING_INGRESS_PROFILES_LIMIT_REACHED {
    description
      "The maximum ingress VLAN editing profiles configuration has been reached. No new ingress VLAN editing profiles can be added in the system.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of current ingress VLAN editing profiles has reached its limit of {max-vlan-editing-ingress-profiles} profiles";
    dn-events-extensions:event-corrective-action-string
      "<p>Update the VLAN manipulation configuration:</p>
       <ol>
       <li>Run command 'show system npu-resources' to view the existing VLAN editing profiles.</li>
       <li>Update interface VLAN manipulation configuration to be similar to that of other interfaces to free profiles.</li>
       </ol>";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Interfaces";
    leaf max-vlan-editing-ingress-profiles {
      type uint8;
      description
        "Maximum ingerss VLAN editing profiles per system";
    }
  }

  notification IF_VLAN_EDITING_INGRESS_PROFILES_LIMIT_CLEARED {
