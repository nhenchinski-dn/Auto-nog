  notification BGP_IPV4_NEIGHBOR_ADJACENCY_BACKWARD_CHANGE {
    description
      "The state of the BGP neighbor has changed from a non-established state to a lower state. A non-established state has a state value of 5, 4, 3, 2, or 1. From high to low, the state value ranges are, established(6), openconfirm(5), opensent(4), active(3), connect(2), and idle(1). For example, if a BGP neighbor state changes from openconfirm(5) to opensent(4), this system event is triggered.";
    dn-events-extensions:event-severity-level "notice";
    dn-events-extensions:event-message-string "Instance {vrf} BGP {as-number}: Neighbor {neighbor-address} adjacency moved from {bgp-peer-old-state} to {bgp-peer-state}";
    dn-events-extensions:event-corrective-action-string "Verify that the peer configuration is the samed at both ends.";
    dn-events-extensions:event-trigger-component-string "BGP";
    dn-events-extensions:event-group "BGP";
    dn-events-extensions:event-snmp-trap-name "bgpBackwardTransNotification";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.15.0.2";
    dn-events-extensions:event-snmp-trap-vars "bgpPeerRemoteAddr.{neighbor-address} {neighbor-address} ; bgpPeerLastError.{neighbor-address} {bgp-peer-last-error} ; bgpPeerState.{neighbor-address} {bgp-peer-state}";
    leaf vrf {
      description
        "Routing instance";
      type string;
    }
    leaf as-number {
      type uint32;
      description
        "BGP AS number";
    }
    leaf neighbor-address {
      type string;
      description
        "The BGP neighbor";
    }
    leaf bgp-peer-last-error {
      type binary {
        length "2";
      }
      description
        "SNMP: The last error code and subcode seen by this
         peer on this connection.  If no error has
         occurred, this field is zero.  Otherwise, the
         first byte of this two byte OCTET STRING
         contains the error code, and the second byte
         contains the subcode.
         view: https://www.iana.org/assignments/bgp-parameters/bgp-parameters.xhtml#bgp-parameters-3";
    }
    leaf bgp-peer-old-state {
      type enumeration {
        enum idle {
          value 1;
        }
        enum connect {
          value 2;
        }
        enum active {
          value 3;
        }
        enum opensent {
          value 4;
        }
        enum openconfirm {
          value 5;
        }
        enum established {
          value 6;
        }
      }
    }
    leaf bgp-peer-state {
      type enumeration {
        enum idle {
          value 1;
        }
        enum connect {
          value 2;
        }
        enum active {
          value 3;
        }
        enum opensent {
          value 4;
        }
        enum openconfirm {
          value 5;
        }
        enum established {
          value 6;
        }
      }
      description
        "SNMP Peer State, expected value established(6)
         idle(1), connect(2), active(3), opensent(4), openconfirm(5),  established(6)";
    }
  }

