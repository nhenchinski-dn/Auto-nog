    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Dynamic NACM group {nacm-group} is not found in LDAP server. User {user-name} is denied";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Netconf";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "Username that was sent to the server";
    }
    leaf nacm-group {
      type string;
      description
        "NACM groups recived from the server";
    }
  }

  notification LDAP_REMOTE_HOLDDOWN_START {
    description
      "DNOS failed to contact remote LDAP servers, will perform LDAP locally until remote LDAP hold-down timer expires.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "All the LDAP servers are not available.";
    dn-events-extensions:event-corrective-action-string "Check LDAP servers status and availability.";
    dn-events-extensions:event-trigger-component-string "Netconf";
    dn-events-extensions:event-group "Management";
  }

  // Techsupport events

  notification TECHSUPPORT_FILE_CREATION_STOPPED {
    description
      "The creation of techsupport file had stopped";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Techsupport file {filename} requested by user {user-name} at {timestamp} was not created because of {reason}";
    dn-events-extensions:event-corrective-action-string "In case of file size problem, use the available filters to reduce the amount of collected information.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "System";
    leaf filename {
      type string;
      description
        "the name of the techsupport file requested to be created";
    }
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf timestamp {
      type string;
      description
        "date and time of when techsupport file was requrested";
    }
    leaf reason {
      type string;
      description
        "Reason for why techsupport file creation had stopped";
    }
  }

  // Transactions events

  notification TRANSACTION_COMMIT_REQUEST {
    description
      "A new configuration request was committed by the user listed.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "User {user-name} requested {command-type} operation";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf command-type {
      type string;
      description
        "Commit command type (i.e commit no-warning)";
    }
  }

  notification TRANSACTION_COMMIT_SUCCEEDED {
    description
      "A new configuration was committed successfully by the user listed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} successfully committed configuration {commit-id}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf commit-id {
      type uint16;
      description
        "Commit ID";
    }
  }

  notification TRANSACTION_COMMIT_CONFIRM {
    description
      "A new configuration was committed using commit confirm operation. If the configuration is not confirmed within the indicated number of minutes, the configuration will rollback automatically.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} successfully committed configuration {commit-id} using commit-confirm operation waiting {confirm-time} minutes ";
    dn-events-extensions:event-corrective-action-string "Confirm the commit or wait for auto revert.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf commit-id {
      type uint16;
      description
        "Commit ID";
    }
    leaf confirm-time {
      type uint16;
      description
        "Confirm time in minutes";
    }
  }

  notification TRANSACTION_COMMIT_FAILED {
    description
      "A new configuration was committed, but the commit has failed.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "User {user-name} committed configuration {commit-id}. However, configuration commit has failed";
    dn-events-extensions:event-corrective-action-string
      "When the commit fails, an error is displayed which specifies the line within the configuration that
       failed. Correct the configuration error and commit the configuration again. You may need to compare your current configuration to the failed configuration to understand why the commit failed.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf commit-id {
      type uint16;
      description
        "Commit ID";
    }
  }

  notification TRANSACTION_COMMIT_CHECK_FAILED {
    description
      "There was an error while trying to check the candidate configuration.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "User {user-name} committed commit check operation. However, configuration commit check has failed at {configuration-line}";
    dn-events-extensions:event-corrective-action-string
      "When the commit fails, an error is displayed which specifies the line within the configuration that
       failed. Correct the configuration error and commit the configuration again. You may need to compare your current configuration to the failed configuration to understand why the commit failed.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf configuration-line {
      type string;
      description
        "First failed configuration-line";
    }
  }

  notification TRANSACTION_COMMIT_CHECK_SUCCEEDED {
    description
      "The commit check operation was performed successfully.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} successfully performed commit check operation";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
  }

  notification TRANSACTION_COMMIT_STATE {
    description
      "The system commit transactions current state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} committed configuration {commit-id}. Transaction is at current state {transaction-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf commit-id {
      type uint16;
      description
        "Commit ID";
    }
    leaf transaction-state {
      type string;
      description
        "Current transaction state";
    }
  }

  notification TRANSACTION_ROLLBACK_COMPLETED {
    description
      "The user listed completed a rollback to a previous configuration.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} rollback configuration {commit-id} completed successfully";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf commit-id {
      type uint16;
      description
        "Commit ID";
    }
  }

  notification TRANSACTION_ROLLBACK_FAILED {
    description
      "The rollback to a previous configuration failed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} rollback configuration {commit-id} upload failed";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf commit-id {
      type uint16;
      description
        "Commit ID";
    }
  }

  // Timezone events

  notification SYSTEM_TIME_DST_START {
    description
      "The system time has changed to Daylight Saving Time. The system clock has moved one hour forward.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "System time changed to Daylight Saving Time. Clock time is now in summer time and moved 1 hour forward";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Management";
    dn-events-extensions:event-group "Management";
  }

  notification SYSTEM_TIME_DST_END {
    description
      "The system time has changed as Daylight Saving Time has ended. The system clock has moved one hour back.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "System time changed as Daylight Saving Time ended. Clock time is now in winter time and moved 1 hour back";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Management";
    dn-events-extensions:event-group "Management";
  }

  notification SYSTEM_TIMEZONE_CHANGE {
    description
      "User has changed the system timezone";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} modified system timezone to {timezone-name} {timezone-utc-offset}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Management";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf timezone-name {
      type string;
      description
        "timezone name, matching supported timezones in dn-timezone";
    }
    leaf timezone-utc-offset {
      type string;
      description
        "timezone offset from utc time. e.g UTC+2:00";
    }
  }

  // SSH events

  notification SSH_SESSION_LOGIN_DENIED {
    description
      "SSH has rejected a new session to the system due to client-list configuration.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "SSH login attempt from remote host {remote-host} on {vrf-name} has been rejected due to client-list configuration";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification SSH_SESSION_LIMIT_CLEARED {
    description
      "The number of concurrent SSH sessions to the system is below the configured maximum number of connections.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of SSH sessions is below the configured maximum ({max-sessions})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf max-sessions {
      type uint8;
      description
        "Maximum number of sessions";
    }
  }

  notification SSH_SESSION_LIMIT_REACHED {
    description
      "The number of concurrent SSH sessions to the system has reached the maximum number of sessions. No new SSH sessions can be established.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of SSH sessions has reached the configured maximum ({max-sessions})";
    dn-events-extensions:event-corrective-action-string
      "<p>Terminate active SSH sessions to the system:</p>
       <ol>
       <li>Run command 'show system ssh sessions' to view the existing SSH sessions.</li>
       <li>Select a session-id for the connection you want to terminate.</li>
       <li>Run the command 'clear ssh session [session-id]'.</li>
       </ol>";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf max-sessions {
      type uint8;
      description
        "Maximum number of sessions";
    }
  }

  notification SSH_SESSION_CLOSED {
    description
      "The user indicated closed the SSH session via the remote host.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} closed the SSH session {session-id} (remote host {remote-host} VRF {vrf-name}) ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
    leaf session-id {
      type uint16;
      description
        "Session ID";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification SSH_SESSION_LOGIN {
    description
      "The user and remote host indicated has logged into the system using SSH.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} has logged in using SSH (remote host {remote-host} VRF {vrf-name}) ";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification SSH_SESSION_TERMINATED {
    description
      "The SSH session to system was terminated by the user indicated using the command 'clear ssh session'.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "SSH session {session-id} (remote host {remote-host} VRF {vrf-name}) terminated by user {user-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
    leaf session-id {
      type uint16;
      description
        "Session ID";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification SSH_SESSION_TIMEOUT {
    description
      "The SSH session to system was terminated by the system due to session inactivity.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "SSH session {session-id} (remote host {remote-host} VRF {vrf-name}) was terminated due to timeout";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
    leaf session-id {
      type uint16;
      description
        "Session ID";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification SSH_MAXIMUM_SESSION_LIMIT_REJECT {
    description
      "A new SSH session to the system was rejected since the number of concurrent SSH sessions has reached the configured limit.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "A new SSH session of user {user-name} from remote host {remote-host} has been rejected since the number of concurrent active SSH sessions has reached the configured limit of {max-sessions}";
    dn-events-extensions:event-corrective-action-string
      "<p>Terminate some active SSH sessions to the system:</p>
       <ol>
       <li>Run command 'show system ssh sessions' to view the existing SSH sessions.</li>
       <li>Select a session-id for the connection you want to terminate.</li>
       <li>Run the command 'clear ssh session [session-id]'.</li>
       </ol>";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf max-sessions {
      type uint8;
      description
        "Maximum number of sessions";
    }
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
  }

  notification SSH_SESSION_LOGIN_LOCKED {
    description
      "A new SSH session by the user indicated was rejected due to maximum number of login attempts. The user must wait for the holdoff period.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Maximum number of login attempts ({login-attempts}) was reached by user {user-name}";
    dn-events-extensions:event-corrective-action-string "Wait for holdoff time defined by 'system login session-holdoff'.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf login-attempts {
      type uint8;
      description
        "Maximum number of failed logins";
    }
  }

  notification SSH_SESSION_LOGIN_FAILED {
    description
      "The user login attempt was rejected due to incorrect credentials.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} login attempt from remote host {remote-host} VRF {vrf-name} rejected due to incorrect credentials";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification SSH_SESSION_TIMEOUT_CONFIG {
    description
      "The user indicated changed the SSH session timeout parameter.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "User {user-name} has changed SSH Session timeout parameter";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
  }

  notification SSH_CLIENT_SESSION_TERMINATED {
    description
      "The SSH client session was terminated by the user indicated using the command 'clear ssh session'.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "SSH client session {session-id} (remote host {remote-host} VRF {vrf-name}) was terminated by user {user-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "CLI";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf remote-host {
      type string;
      description
        "Remote host address, can be an IP address or as hostname";
    }
    leaf session-id {
      type uint16;
      description
        "Session ID";
    }
    leaf vrf-name {
      description
        "the vrf in which event happened";
      type string;
    }
  }

  notification SSH_CLIENT_CONFIG {
    description
      "The user indicated changed the SSH client capability.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} changed SSH client capability to {client-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf client-state {
      type enumeration {
        enum enabled;
        enum disabled;
      }
      description
        "SSH client configuration state";
    }
    leaf user-name {
      type string;
      description
        "System user-name";
    }
  }

  notification SSH_SERVER_CONFIG {
    description
      "The user indicated changed the SSH server capability.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} changed SSH server capability to {server-state} in VRF {vrf-name}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Management";
    leaf server-state {
      type enumeration {
        enum enabled;
        enum disabled;
      }
      description
        "SSH server configuration state";
    }
    leaf user-name {
      type string;
      description
