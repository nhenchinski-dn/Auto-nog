      type string;
      description
        "Tunnel name";
    }
    leaf source-address {
      type string;
      description
        "LSP source IPv4 address";
    }
    leaf destination-address {
      type string;
      description
        "LSP destination IPv4 address";
    }
    leaf tunnel-id {
      description
        "Tunnel local ID";
      type string;
    }
    leaf lsp-id {
      type string;
      description
        "LSP unique local ID";
    }
    leaf event {
      type string;
      description
        "Event code";
    }
    leaf bandwidth {
      description
        "LSP requested bandwidth in kbps";
      type string;
    }
    leaf originator {
      type string;
      description
        "Originator IPv4 address";
    }
  }

