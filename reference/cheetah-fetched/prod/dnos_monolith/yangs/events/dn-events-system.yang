  notification RSVP_TUNNEL_LSP_SWITCH {
    description
      "The RSVP tunnel switched between primary and secondary lsp.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "RSVP tunnel {tunnel-name} from {source-address} to {destination-address}, tunnel ID {tunnel-id}, switch from {previous-active-lsp} LSP ID {previous-lsp-id} to {new-active-lsp} LSP ID {new-lsp-id}. Reason: {reason}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "RSVP";
    dn-events-extensions:event-snmp-trap-name "mplsTunnelRerouted";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.2.1.10.166.3.0.3";
    dn-events-extensions:event-snmp-trap-vars "mplsTunnelAdminStatus.{tunnel-id}.{new-lsp-id}.{ingress-lsr-id}.{egress-lsr-id} {admin-status} ; mplsTunnelOperStatus.{tunnel-id}.{new-lsp-id}.{ingress-lsr-id}.{egress-lsr-id} {oper-status} ";
    leaf tunnel-name {
      type string;
      description
        "Tunnel name";
    }
    leaf source-address {
      type string;
      description
        "Tunnel source IPv4 address";
    }
    leaf destination-address {
      type string;
      description
        "Tunnel destination IPv4 address";
    }
    leaf tunnel-id {
      description
        "Tunnel local ID";
      type uint32 {
        range "0..65535";
      }
    }
    leaf previous-active-lsp {
      description
        "Previous active lsp type, either primary or secondary";
      type enumeration {
        enum primary;
        enum secondary;
      }
    }
    leaf new-active-lsp {
      description
        "New active lsp type, either primary or secondary";
      type enumeration {
        enum primary;
        enum secondary;
      }
    }
    leaf previous-lsp-id {
      description
        "LSP ID";
      type uint32;
    }
    leaf new-lsp-id {
      description
        "LSP ID";
      type uint32;
    }
    leaf reason {
