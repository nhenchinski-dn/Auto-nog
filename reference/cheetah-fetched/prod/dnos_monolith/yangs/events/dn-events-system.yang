    dn-events-extensions:event-group "Management";
    leaf policy-name {
      type string;
      description
        "The name of the policy.";
    }
    leaf policy-type {
      type string;
      description
        "The type of the policy.";
    }
    leaf reason {
      type string;
      description
        "The reason why policy inactive
         (e.g. policy finished execution, configuration change, misconfiguration, other)";
