    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "TBD";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
  }

