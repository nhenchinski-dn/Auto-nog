  notification OSPF_GRACEFUL_RESTART_STATUS_CHANGE {
    description
      "The OSPF Graceful Restart state has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "OSPF router {router-id} process restarted. Graceful Restart state {gr-state} {gr-sub-state}. Graceful Restart grace period {grace-period} seconds";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ospf";
    dn-events-extensions:event-group "OSPF";
    dn-events-extensions:event-snmp-trap-name "ospfRestartStatusChange";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.2.1.14.16.2.18";
    dn-events-extensions:event-snmp-trap-vars
      "ospfRouterId.0 {router-id} ; ospfRestartStatus.0 {gr-state} ;
       ospfRestartInterval.0 {grace-period} ; ospfRestartExitReason.0 {gr-sub-state}";
    leaf router-id {
      type string;
      description
        "OSPF Router ID";
    }
    leaf gr-state {
      type enumeration {
        enum not-restarting {
          value 1;
        }
        enum planned-restart {
          value 2;
        }
        enum unplanned-restart {
          value 3;
        }
      }
      description
        "Current status of OSPF graceful restart.";
    }
    leaf grace-period {
      type uint16 {
        range "60..1800";
      }
      description
        "Configured OSPF graceful restart timeout interval.";
    }
    leaf gr-sub-state {
      type enumeration {
        enum none {
          value 1;
        }
        enum in-progress {
          value 2;
        }
        enum completed {
          value 3;
        }
        enum time-out {
          value 4;
        }
        enum topology-changed {
          value 5;
        }
      }
      description
        "Describes the outcome of the last attempt at a
         graceful restart.  If the value is 'none', no restart
         has yet been attempted.  If the value is 'inProgress',
         a restart attempt is currently underway.";
    }
  }

  notification OSPF_NEIGHBOR_GRACEFUL_RESTART_HELPER_STATUS_CHANGE {
    description
      "The Graceful Restart Helper state for an OSPF neighbor has changed.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "OSPF router {router-id} neighbor {neighbor-router-id} on interface {if-name} restarted. Neighbor address {neighbor-address}. Graceful Restart Helper state {gr-helper-state} {gr-helper-sub-state}. Graceful Restart timeout {gr-interval-timeout} seconds";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ospf";
    dn-events-extensions:event-group "OSPF";
    dn-events-extensions:event-snmp-trap-name "ospfNbrRestartHelperStatusChange";
    dn-events-extensions:event-snmp-trap-oid ".1.3.6.1.2.1.14.16.2.19";
    dn-events-extensions:event-snmp-trap-vars
      "ospfRouterId.0 {router-id} ; ospfNbrIpAddr.0 {neighbor-address} ;
       ospfNbrAddressLessIndex.0 {if-index} ; ospfNbrRtrId.0 {neighbor-router-id} ;
       ospfNbrRestartHelperStatus.0 {gr-helper-state} ; ospfNbrRestartHelperAge.0 {gr-interval-timeout} ;
       ospfNbrRestartHelperExitReason.0 {gr-helper-sub-state}";
    leaf router-id {
      type string;
      description
        "OSPF Router ID";
    }
    leaf neighbor-address {
      type string;
      description
        "Neighbor peer IP address";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf if-index {
      type uint32 {
        range "1..2147483647";
      }
      description
        "The identifier of this interface relevant to this notification";
    }
    leaf neighbor-router-id {
      type string;
      description
        "The OSPF neighbor Router ID";
    }
    leaf gr-helper-state {
      type enumeration {
        enum not-helping {
          value 1;
        }
        enum helping {
          value 2;
        }
      }
      description
        "Indicates whether the router is acting
         as a graceful restart helper for the neighbor.";
    }
    leaf gr-interval-timeout {
      type uint32;
      description
        "Remaining time (in seconds) in current OSPF graceful restart
         interval, if the router is acting as a restart
         helper for the neighbor.";
    }
    leaf gr-helper-sub-state {
      type enumeration {
        enum none {
          value 1;
        }
        enum in-progress {
          value 2;
        }
        enum completed {
          value 3;
        }
        enum time-out {
          value 4;
        }
        enum topology-changed {
          value 5;
        }
      }
      description
        "Describes the outcome of the last attempt at acting
         as a graceful restart helper for the neighbor.";
    }
  }

  notification OSPF_NSR_RECOVERED {
    description
      "The system performed an OSPF Non-Stop Routing recovery due to a restart of the ospfd process.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "OSPF Non-Stop Routing recovery was performed due to a restart of the ospfd process";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "OSPF";
