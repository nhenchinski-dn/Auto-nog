  notification MPLS_BGP_L2VPN_VPLS_LABEL_ALLOCATION_FAILED {
    description
      "Cannot allocate labels for BGP-L2VPN services because no contiguous block exists in the label pool.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "Cannot allocate label block of {block-size-to-allocate} for instance {instance-type} '{instance-name}' - no contiguous block exists in the pool. This local NLRI will not be advertised to any peer.";
    dn-events-extensions:event-corrective-action-string "Modify the label block size and restart the system.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf block-size-to-allocate {
      description
        "block size to allocate";
      type uint32;
    }
    leaf instance-type {
      description
        "Type of L2VPN service this PW belongs to";
      type enumeration {
        enum EVPN-VPWS-SEAMLESS-INTEGRATION;
        enum EVPN-SEAMLESS-INTEGRATION;
      }
    }
    leaf instance-name {
      description
        "Name of L2VPN service this PW belongs to";
      type string;
    }
  }

  notification EVPN_VPWS_FXC_SUB_SERVICE_ESTABLISHED {
    description
      "The referenced EVPN-VPWS-FXC sub-service changed to an 'up' state and can be used to forward traffic.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "The EVPN-VPWS-FXC sub-service {service-name}:{interface-name} state is UP.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "L2VPN";
    dn-events-extensions:event-group "L2VPN";
    leaf service-name {
      description
