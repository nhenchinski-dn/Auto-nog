  // PCEP events

  notification PCEP_SESSION_UP {
    description
      "The PCEP session with the listed PCE server has moved from a 'down' state to an 'up' state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "PCEP session with PCE server {server-address} established. PCE priority {priority}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "PCEP";
    leaf server-address {
      type string;
      description
        "The PCE server address";
    }
    leaf priority {
      type uint8;
      description
        "The PCE server priority";
    }
  }

  notification PCEP_SESSION_DOWN {
    description
      "The PCEP session with the listed PCE server has moved from an 'up' state to a 'down' state.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "PCEP session with PCE server {server-address} disconnected. PCE server priority {priority}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "PCEP";
    leaf server-address {
      type string;
      description
        "The PCE server address";
    }
    leaf priority {
      type uint8;
      description
        "The PCE server priority";
    }
  }

  notification PCEP_TUNNEL_LSP_DELEGATION_CHANGE {
    description
      "The RSVP tunnel changed its PCEP delegation state from either 'enabled' to 'disabled' or 'disabled' to 'enabled'.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "RSVP tunnel {tunnel-name} is {delegation-status} to  PCE {pce-address}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "PCEP";
    leaf tunnel-name {
      type string;
      description
        "Tunnel name";
    }
    leaf delegation-status {
      description
        "Tunnel operational delegation status, either 'delegated' or 'no longer delegated'";
      type string;
    }
    leaf pce-address {
      description
        "PCE IP address";
      type string;
    }
  }

  notification PCEP_MESSAGE_ERROR {
    description
      "The PCEP server has sent an error message listed.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "PCC {direction} PCEP server {server-address} with priority {priority} an error message {description} (type {type}, value {value})";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "RSVP";
    dn-events-extensions:event-group "PCEP";
    leaf direction {
      description
        "Indicate whether PCC sent or received the error msg";
      type enumeration {
        enum sent_to;
        enum received_from;
      }
    }
    leaf server-address {
      type string;
      description
        "The PCE server address";
    }
    leaf priority {
      type uint8;
      description
        "The PCE server priority";
    }
    leaf description {
      type string;
      description
        "PCEP error code";
    }
    leaf type {
      type uint8;
      description
        "PCEP error code";
    }
    leaf value {
      type uint8;
      description
        "PCEP error code";
    }
  }

  notification PCEP_SESSION_LIMIT_REACHED {
    description
      "The maximum number of 5 PCEP sessions has been reached.";
