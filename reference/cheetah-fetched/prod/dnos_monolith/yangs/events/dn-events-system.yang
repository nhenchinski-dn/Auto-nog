    dn-events-extensions:event-trigger-component-string "";
    dn-events-extensions:event-group "Management";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf node-type {
      type string;
      description
        "Node-type (NCC/NCP/NCF)";
    }
    leaf node-id {
      type string;
      description
        "Node ID (0-191)";
    }
  }

  notification CONSOLE_NODE_LOGIN_FAILED {
    description
      "The user login attempt to the console of the node was rejected due to incorrect credentials.";
    dn-events-extensions:event-severity-level "Warning";
