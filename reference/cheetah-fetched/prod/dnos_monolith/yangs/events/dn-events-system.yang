    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "RIB";
    dn-events-extensions:event-group "RIB";
    leaf limit {
      type uint32;
      description
        "The accumulated IPv4 & IPv6 routes scale";
    }
  }

  notification RIB_MAXIMUM_ROUTES_LIMIT_CLEARED {
    description
      "The number of routes have moved below the system limit.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "RIB is below the system limit of {limit} routes";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "RIB";
