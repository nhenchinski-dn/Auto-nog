    leaf control-connection-id {
      type uint16;
      description
        "TWAMP Control connection ID";
    }
    leaf vrf-name {
      type string;
      description
        "The VRF in which the event has occured";
    }
  }

  notification TWAMP_SESSION_CONTROL_DOWN {
    description
      "The TWAMP control session is down.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "TWAMP control connection ID {control-connection-id} is down. (remote address {remote-ip-address}:{remote-port}, local address {local-ip-address}:{local-port}, VRF {vrf-name})";
    dn-events-extensions:event-corrective-action-string "No corrective action required.";
    dn-events-extensions:event-trigger-component-string "Twampd";
    dn-events-extensions:event-group "Services";
    leaf local-ip-address {
      type string;
      description
        "Local IP address";
    }
    leaf local-port {
      type uint16;
      description
        "Local port";
    }
    leaf remote-ip-address {
      type string;
      description
        "Remote IP address";
    }
    leaf remote-port {
      type uint16;
      description
        "Remote port";
    }
    leaf control-connection-id {
      type uint16;
      description
        "TWAMP Control connection ID";
    }
    leaf vrf-name {
      type string;
      description
        "The VRF in which the event has occured";
    }
  }

  notification TWAMP_SESSION_DATA_STATE_CHANGE {
    description
      "The TWAMP data session has changed its state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "TWAMP data session {data-session-id} under control connection ID {control-connection-id} state has changed from {old-state} to {new-state}. (remote address {remote-ip-address}:{remote-port}, local address {local-ip-address}:{local-port}, VRF {vrf-name})";
    dn-events-extensions:event-corrective-action-string "Contact Customer Support.";
    dn-events-extensions:event-trigger-component-string "Twampd";
    dn-events-extensions:event-group "Services";
    leaf old-state {
      type string;
      description
        "TWAMP data session old state";
    }
    leaf new-state {
      type string;
      description
        "TWAMP data session new state";
    }
    leaf local-ip-address {
      type string;
      description
        "Local IP address";
    }
    leaf local-port {
      type uint16;
      description
        "Local port";
    }
    leaf remote-ip-address {
      type string;
      description
        "Remote IP address";
    }
    leaf remote-port {
      type uint16;
      description
        "Remote port";
    }
    leaf control-connection-id {
      type uint16;
      description
        "TWAMP Control connection ID";
    }
    leaf data-session-id {
      type uint32;
      description
        "TWAMP Data session ID";
    }
    leaf vrf-name {
      type string;
      description
        "The VRF in which the event has occured";
    }
  }

  notification TWAMP_MAXIMUM_SESSIONS_CONTROL_LIMIT_REACHED {
    description
      "The number of concurrent TWAMP control sessions has reached the maximum number of sessions. No new TWAMP control sessions can be established.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of TWAMP control sessions has reached the configured maximum ({max-twamp-control-sessions})";
    dn-events-extensions:event-corrective-action-string
      "<p>Terminate active TWAMP sessions to the system:</p>
       <ol>
       <li>Run command 'show services twamp sessions' to view the existing TWAMP sessions.</li>
       <li>Select a connection-id for the connection you want to terminate.</li>
       <li>Run the command 'clear twamp session [connection-id]'.</li>
       </ol>";
    dn-events-extensions:event-trigger-component-string "Twampd";
    dn-events-extensions:event-group "Services";
    leaf max-twamp-control-sessions {
      type uint8;
      description
        "Maximum number of TWAMP control sessions";
    }
  }

  notification TWAMP_MAXIMUM_SESSIONS_CONTROL_LIMIT_CLEARED {
    description
      "The TWAMP control session has cleared its limit, new control sessions are available.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of TWAMP control sessions is below the configured maximum ({max-twamp-control-sessions})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Twampd";
    dn-events-extensions:event-group "Services";
    leaf max-twamp-control-sessions {
      type uint8;
      description
        "Maximum number of TWAMP control sessions";
    }
  }

  notification TWAMP_MAXIMUM_SESSIONS_DATA_LIMIT_REACHED {
    description
      "The number of concurrent TWAMP data sessions has reached the maximum number of sessions. No new TWAMP data sessions can be established.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Number of TWAMP data sessions under control session ID {control-connection-id} has reached the configured maximum ({max-twamp-data-sessions})";
    dn-events-extensions:event-corrective-action-string
      "<p>Terminate active TWAMP sessions to the system:</p>
       <ol>
       <li>Run command 'show services twamp sessions' to view the existing TWAMP sessions.</li>
       <li>Select a connection-id for the connection you want to terminate.</li>
       <li>Run the command 'clear twamp session [connection-id]'.</li>
       </ol>";
    dn-events-extensions:event-trigger-component-string "Twampd";
    dn-events-extensions:event-group "Services";
    leaf max-twamp-data-sessions {
      type uint8;
      description
        "Maximum number of twamp data sessions";
    }
    leaf control-connection-id {
      type uint16;
      description
        "TWAMP Control connection ID";
    }
  }

  notification TWAMP_MAXIMUM_SESSIONS_DATA_LIMIT_CLEARED {
    description
      "The TWAMP control session has cleared its limit, new control sessions are available.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Number of TWAMP data sessions under control session ID {control-connection-id} is below the configured maximum ({max-twamp-data-sessions})";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Twampd";
    dn-events-extensions:event-group "Services";
    leaf max-twamp-data-sessions {
      type uint8;
      description
        "Maximum number of TWAMP data sessions";
    }
    leaf control-connection-id {
      type uint16;
      description
        "TWAMP Control connection ID";
    }
  }

  notification TWAMP_CLIENT_LOGIN_DENIED {
    description
      "TWAMP client access is denied due to incorrect credentials.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "TWAMP client login attempt from {remote-ip-address}:{remote-port} in VRF {vrf-name} was rejected due to client list configuration";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Twampd";
    dn-events-extensions:event-group "Services";
    leaf remote-ip-address {
      type string;
      description
        "Remote IP address";
    }
    leaf remote-port {
      type uint16;
      description
        "Remote port";
    }
    leaf vrf-name {
      type string;
      description
        "The VRF in which the event has occured";
    }
  }

  notification TWAMP_CLIENT_LIST_CONFIG {
    description
      "The user listed changed the TWAMP client list configuration.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} changed the TWAMP client-list configuration for VRF {vrf-name}";
    dn-events-extensions:event-corrective-action-string "No corrective action.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Services";
    leaf user-name {
      type string;
      description
        "System user-name";
    }
    leaf vrf-name {
      type string;
      description
        "The VRF in which the event has occured";
    }
  }

  // Simple TWAMP events

  notification STAMP_TEST_FAILURE {
    description
      "The simple TWAMP test has failed due to threshold violation.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Simple TWAMP session {session-name} from {source-address-and-port} to {destination-address-and-port} on VRF {vrf-name} has failed due to a violation of the configured {threshold-name} threshold of {threshold-value-and-units}.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Stampd";
    dn-events-extensions:event-group "Services";
    leaf session-name {
      type string;
      description
        "Simple TWAMP session name";
    }
    leaf source-address-and-port {
      type string;
      description
        "The source IP address and port used for the Simple TWAMP monitoring session";
    }
    leaf destination-address-and-port {
      type string;
      description
        "The destination IP address and port used for the Simple TWAMP monitoring session";
    }
    leaf vrf-name {
      type string;
      description
        "The target VRF used for the Simple TWAMP monitoring session";
    }
    leaf threshold-name {
      type string;
      description
        "The name of the IP performance threshold that was violated";
    }
    leaf threshold-value-and-units {
      type string;
      description
        "The value (and units) that triggered the violation and caused the test to fail";
    }
  }

  notification STAMP_LINK_DELAY_ADVERTISEMENT {
    description
      "Link Delay advertisement was generated for the Simple TWAMP session.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Link delay advertisement has been generated for the Simple TWAMP session on interface {interface-name}. Reason: {reason}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Stampd";
    dn-events-extensions:event-group "Services";
    leaf interface-name {
      type string;
      description
        "Interface name";
    }
    leaf reason {
      type string;
      description
        "The reason and that triggered the link delay advertisement";
    }
  }

  // ICMP Echo IP performance measurement events

  notification ICMP_ECHO_TEST_FAILURE {
    description
      "The ICMP echo IP performance measurement test has failed due to a threshold violation.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "ICMP echo IP performance measurement test session {session-name} (ID: {session-id}) from {source-address} to "
                                            + "{destination-address} in VRF {vrf-name} has failed due to a violation of the configured "
                                            + "{threshold-name} threshold of {threshold-value-and-units}. Recorded value: {calculated-violating-metric-and-units}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "NETPM";
    dn-events-extensions:event-group "NETPM";
    dn-events-extensions:event-snmp-trap-name "dnNetpmTestFailure";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.12.0.1";
    dn-events-extensions:event-snmp-trap-vars "dnSessionName.0 {session-name}; dnSourceAddress.0 {source-address}; dnDestinationAddress.0 {destination-address}; dnVrfName.0 {vrf-name}; dnThresholdName.0 {threshold-name}; dnThresholdValueAndUnits.0 {threshold-value-and-units}; dnCalculatedMetric.0 {calculated-violating-metric-and-units}";
    leaf session-name {
      type string;
      description
        "ICMP echo IP performance measurement test session name";
    }
    leaf session-id {
      type string;
      description
        "ICMP echo IP performance measurement test session id";
    }
    leaf source-address {
      type string;
      description
        "The source IP address used for the ICMP echo IP performance measurement test session";
    }
    leaf destination-address {
      type string;
      description
        "The destination IP address used for the ICMP echo IP performance measurement test session";
    }
    leaf vrf-name {
      type string;
      description
        "The target VRF used for the ICMP echo IP performance measurement test session";
    }
    leaf threshold-name {
      type string;
      description
        "The name of the IP performance metric threshold that was violated";
    }
    leaf threshold-value-and-units {
      type string;
      description
        "The configured threshold value (and units) that was breached";
    }
    leaf calculated-violating-metric-and-units {
      type string;
      description
        "The value (and units) that triggered the violation and caused the test to fail";
    }
  }

  // QoS events

  notification QOS_INTERNAL_ERROR {
    description
      "Internal Quality of Service error.";
    dn-events-extensions:event-severity-level "Error";
    dn-events-extensions:event-message-string "Quality of Service has encountered an error: {error-type}, {error-message}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "QOS";
    dn-events-extensions:event-group "QOS";
    leaf error-type {
      type string;
      description
        "Quality of Service error message type. i.e Hardware error";
    }
    leaf error-message {
      type string;
      description
        "Error description";
    }
  }

  notification QOS_RESOURCES_LIMIT_EXCEEDED {
    description
      "The number of Quality of Service resource configurations have reached the system limit, you cannot make any further commits.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "QoS resource configurations have reached system limit of {limit}. User {user-name} attempted to configure limited resource {resource-name} causing commit to fail";
    dn-events-extensions:event-corrective-action-string "Update QoS resource configuration to either increase the system limit or remove some resource configurations.";
    dn-events-extensions:event-trigger-component-string "QOS";
    dn-events-extensions:event-group "QOS";
    leaf limit {
      type string;
      description
        "Limit number";
    }
    leaf resource-name {
      type string;
      description
        "Quality of Service available hardware resource";
    }
    leaf user-name {
      type string;
      description
        "User name";
    }
  }

  notification QOS_PFC_DEADLOCK_FLAP_SUPPRESSION_THRESHOLD_EXCEEDED {
    description
      "PFC deadlock flap suppression threshold has been violated.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "The PFC deadlock flap suppression threshold was exceeded on interface {if-name} for traffic class {traffic-class} after {deadlock-occurrences} deadlock occurrences within {period} seconds.";
    dn-events-extensions:event-corrective-action-string "Check network configuration and reset PFC manually.";
    dn-events-extensions:event-trigger-component-string "QOS";
    dn-events-extensions:event-group "QOS";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf traffic-class {
      type uint8 {
        range "0..7";
      }
      description
        "The applicable traffic class on the interface";
    }
    leaf deadlock-occurrences {
      type uint16 {
        range "1..500";
      }
      description
        "The number of deadlock occurrences on the interface within the sampling window";
    }
    leaf period {
      type uint16 {
        range "1..60";
      }
      description
        "The sampling window for PFC deadlock flap suppression";
      units "seconds";
    }
  }

  notification QOS_PFC_DEADLOCK_FLAP_SUPPRESSION_THRESHOLD_CLEARED {
    description
      "PFC deadlock flap suppression has moved below the configured threshold.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "PFC deadlock flap suppression threshold cleared on interface {if-name} for traffic class {traffic-class}.";
    dn-events-extensions:event-corrective-action-string "No corrective action is required.";
    dn-events-extensions:event-trigger-component-string "QOS";
    dn-events-extensions:event-group "QOS";
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf traffic-class {
      type uint8 {
        range "0..7";
      }
      description
        "The applicable traffic class on the interface";
    }
  }

  // RIB events

  notification RIB_MAXIMUM_ROUTES_LIMIT_REACHED {
    description
      "The RIB has reached the maximum system limit of supported routes.";
    dn-events-extensions:event-severity-level "Warning";
