    }
  }

  notification NCP_TO_NCP_REACHABILITY_STATE_UP {
    description
      "The NCP has reachability to the listed NCP neighbor.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "NCP {ncp-id} has reachability to neighbor NCP {neighbor-ncp-id}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Cluster Manager";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
      type uint16;
      description
        "NCP ID";
    }
    leaf neighbor-ncp-id {
      type uint16;
      description
        "NCP ID";
    }
  }

  notification NCP_TO_NCP_REACHABILITY_STATE_DOWN {
    description
      "The NCP has no reachability with the listed NCP neighbor.";
    dn-events-extensions:event-severity-level "Critical";
    dn-events-extensions:event-message-string "NCP {ncp-id} lost reachability to neighbor NCP {neighbor-ncp-id}";
    dn-events-extensions:event-corrective-action-string "Check the connectivity between the nodes.";
    dn-events-extensions:event-trigger-component-string "Cluster Manager";
    dn-events-extensions:event-group "System";
    leaf ncp-id {
