  // Interfaces events

  notification IF_ADMIN_STATE_CONFIG {
    description
      "The user has changed the indicated interface admin-state.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "User {user-name} has changed interface {if-name} state to {new-state}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Transaction-manager";
    dn-events-extensions:event-group "Interfaces";
    leaf new-state {
      type string;
      description
        "Interface state";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf user-name {
      type string;
      description
        "System user-name";
    }
  }

  notification IF_LINK_STATE_CHANGE_DOWN {
    description
      "The link state on the interface has moved to a 'down' state. The link state changed due to a link failure.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Interface {if-name} link state has changed to {new-state}. Down reason {down-reason}";
    dn-events-extensions:event-corrective-action-string
      "<p>If the link state change was expected, for example due to planned maintenance, no corrective action is required. If the link state changed unexpectedly:</p>
       <ol>
       <li>Check that the cable is properly connected at both ends.</li>
       <li>Check if the interface configuration on either side of the connection has changed. If it has changed, make sure that the interface is properly configured. See the CLI configuration guide.</li>
       <li>If the problem persists, contact Customer Support.</li>
       </ol>";
    dn-events-extensions:event-trigger-component-string "WB Agent";
    dn-events-extensions:event-group "Interfaces";
    dn-events-extensions:event-snmp-trap-name "linkDown";
    dn-events-extensions:event-snmp-trap-generic-type "linkDown";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.6.3.1.1.5.3";
    dn-events-extensions:event-snmp-trap-vars "ifIndex.{if-index} {if-index} ; ifAdminStatus.{if-index} {if-admin-status} ; ifOperStatus.{if-index} {if-oper-status} ; ifName.{if-index} {if-name}";
    leaf new-state {
      type string;
      description
        "Interface state";
    }
    leaf if-name {
      type string;
      description
        "Interface name";
    }
    leaf if-index {
      type uint32;
      description
        "SNMP Interface index";
    }
    leaf if-admin-status {
      type uint32;
      description
        "SNMP Admin Status
         SYNTAX INTEGER up(1), down(2), testing(3)";
    }
    leaf if-oper-status {
      type uint32;
      description
        "SNMP Oper Status
         SYNTAX INTEGER up(1), down(2), testing(3)";
    }
    leaf down-reason {
      type string;
      description
        "Interface down cause reason";
    }
  }

  notification IF_LINK_STATE_CHANGE_UP {
    description
      "The link state on the interface has moved to an 'up' state.";
