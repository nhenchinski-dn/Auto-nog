  // ISIS nsr events

  notification ISIS_NSR_RECOVERED {
    description
      "The system performed an IS-IS Non-Stop Routing recovery due to a restart of the isisd process.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "IS-IS Non-Stop Routing recovery was performed due to a restart of the isisd process";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
  }

  notification ISIS_NSR_RECOVERY_FAILED {
    description
      "The IS-IS process failed to recover in Non-Stop Routing mode.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "isisd process failed to recover in Non-Stop Routing mode";
    dn-events-extensions:event-corrective-action-string "Verify NSR readiness prior to the failure event. If the database was synchronized prior to the failure event, contact Customer Support.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
  }

  // Segment Routing events
  // IS-IS

  notification ISIS_SR_CONFIG_PREFIX_SID_OUT_OF_RANGE {
    description
      "The configured Prefix-SID is out of the currently in use SRGB range.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Configured Prefix-SID value {sid-value} on {if-name}, is outside the currently in use SRGB range";
    dn-events-extensions:event-corrective-action-string "Update the Prefix-SID configuration or restart the router to add the new SRGB values.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf sid-value {
      type uint32;
      description
        "Absolute value of the Prefix-SID";
    }
    leaf if-name {
      type string;
      description
        "Interface name on which Prefix-SID was configured";
    }
    leaf sid-index {
      type int32;
      description
        "Index value of the Prefix-SID";
    }
  }

  notification ISIS_SR_CONFIG_BINDING_SID_OUT_OF_RANGE {
    description
      "The configured Binding-SID is out of the currently in use SRLB range.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Configured SR-TE policy {policy-name} Binding-SID value {sid-value}, is outside the currently in use SRLB range";
    dn-events-extensions:event-corrective-action-string "Update the Binding-SID configuration or restart the router to add the new SRLB values.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf policy-name {
      type string;
      description
        "SR-TE policy name";
    }
    leaf sid-value {
      type uint32;
      description
        "Absolute value of the Prefix-SID";
    }
  }

  notification ISIS_SR_CONFIG_ADJ_SID_OUT_OF_RANGE {
    description
      "The configured Adjacency-SID is out of the currently in use SRLB range.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Configured Adjacency-SID value {sid-value} on {if-name}, is outside the currently in use SRLB range";
    dn-events-extensions:event-corrective-action-string "Update the Adjacency-SID configuration or restart the router to add the new SRLB values.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf sid-value {
      type uint32;
      description
        "Absolute label value of the Prefix-SID";
    }
    leaf if-name {
      type string;
      description
        "Interface name on which Prefix-SID was configured";
    }
  }

  notification ISIS_SR_RECEIVED_PREFIX_SID_OUT_OF_RANGE {
    description
      "A Prefix-SID was received which is outside of the ISIS SRGB range.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Received {sid-type} {sid-value} from {remote-hostname}. {sid-type} is outside the SRGB range";
    dn-events-extensions:event-corrective-action-string "Align the network SID requirements with the SRGB values.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf sid-type {
      type string;
      description
        "The received SID-type, either Prefix-SID or Binding-SID";
    }
    leaf sid-value {
      type uint32;
      description
        "Absolute value of the Prefix-SID";
    }
    leaf remote-hostname {
      type string;
      description
        "The hostname of removed node from which SID was received, if not known, display system-ID";
    }
  }

  notification ISIS_SR_PREFIX_SID_CONFLICT {
    description
      "A Prefix-SID was received which is the same for different Forwarding Equivalence Classes (FEC)s.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Prefix-SID {sid-value} originated by {hostname-1} for {prefix-1} {algorithm-1} conflicts with Prefix-SID originated by {hostname-2} {algorithm-2} for {prefix-2}. Conflict resolved as {resolution}";
    dn-events-extensions:event-corrective-action-string "Change the Prefix-SID setting on either nodes.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf sid-value {
      type uint32;
      description
        "Absolute value of the Prefix-SID";
    }
    leaf hostname-1 {
      type string;
      description
        "The hostname of removed node from which SID was received, if not known, display system-ID";
    }
    leaf prefix-1 {
      type string;
      description
        "The prefix for which node-1 advertise the Prefix-SID";
    }
    leaf algorithm-1 {
      description
        "The prefix-SID algorithm, SPF or S-SFP";
      type string;
    }
    leaf hostname-2 {
      type string;
      description
        "The hostname of removed node from which SID was received, if not known, display system-ID";
    }
    leaf prefix-2 {
      type string;
      description
        "The prefix for which node-1 advertise the Prefix-SID";
    }
    leaf algorithm-2 {
      description
        "The prefix-SID algorithm, SPF or S-SFP";
      type string;
    }
    leaf resolution {
      type string;
      description
        "how conflict is resolved, i.e which prefix is assigned to sid";
    }
  }

  notification ISIS_SR_PREFIX_CONFLICT {
    description
      "Different Prefix-SIDs were received for the same Forwarding Equivalence Classes (FEC)s.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "ISIS {level} Prefix {ipv4-prefix} originated by {hostname-1} with Prefix-SID {sid-value-1} conflicts with Prefix-SID {sid-value-2} originated by {hostname-2}. Conflict resolved as {resolution}";
    dn-events-extensions:event-corrective-action-string "Change the Prefix-SID setting on either nodes.";
    dn-events-extensions:event-trigger-component-string "ISIS";
    dn-events-extensions:event-group "ISIS";
    leaf level {
      type enumeration {
        enum level1 {
          value 1;
        }
        enum level2 {
          value 2;
        }
      }
      description
        "The ISIS prefix level";
    }
    leaf ipv4-prefix {
      type string;
      description
        "The prefix received from multiple nodes";
    }
    leaf hostname-1 {
      type string;
      description
        "The hostname of removed node from which SID was received, if not known, display system-ID";
    }
    leaf sid-value-1 {
      type uint32;
      description
        "Absolute value of the Prefix-SID";
    }
    leaf sid-value-2 {
      type uint32;
      description
        "Absolute value of the Prefix-SID";
    }
    leaf hostname-2 {
      type string;
      description
        "The hostname of removed node from which SID was received, if not known, display system-ID";
    }
    leaf resolution {
      type string;
      description
        "how conflict is resolved, i.e which prefix-sid is assigned to prefix";
    }
  }

  // OSPF

  notification OSPF_SR_CONFIG_PREFIX_SID_OUT_OF_RANGE {
    description
      "The configured Prefix-SID is out of the currently in use SRGB range.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "OSPF instance {instance}: Configured Prefix-SID value {sid-value} on {if-name}, is outside the currently in use SRGB range";
    dn-events-extensions:event-corrective-action-string "Update the Prefix-SID configuration or restart the router to add the new SRGB values.";
    dn-events-extensions:event-trigger-component-string "OSPF";
    dn-events-extensions:event-group "OSPF";
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
    leaf sid-value {
      type uint32;
      description
        "Absolute value of the Prefix-SID";
    }
    leaf if-name {
      type string;
      description
        "Interface name on which Prefix-SID was configured";
    }
    leaf sid-index {
      type int32;
      description
        "Index value of the Prefix-SID";
    }
  }

  notification OSPF_SR_RECEIVED_PREFIX_SID_OUT_OF_RANGE {
    description
      "A Prefix-SID was received which is outside of the OSPF SRGB range.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "OSPF instance {instance}: Received {sid-type} {sid-value} from {remote-hostname}. {sid-type} is outside the SRGB range";
    dn-events-extensions:event-corrective-action-string "Align the network SID requirements with the SRGB values.";
    dn-events-extensions:event-trigger-component-string "OSPF";
    dn-events-extensions:event-group "OSPF";
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
    leaf sid-type {
      type string;
      description
        "The received SID-type, either Prefix-SID or Binding-SID";
    }
    leaf sid-value {
      type uint32;
      description
        "Absolute value of the Prefix-SID";
    }
    leaf remote-hostname {
      type string;
      description
        "The hostname of removed node from which SID was received, if not known, display system-ID";
    }
  }

  notification OSPF_SR_PREFIX_SID_CONFLICT {
    description
      "A Prefix-SID was received which is the same for different Forwarding Equivalence Classes (FEC)s.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "OSPF instance {instance}: Prefix-SID {sid-value} originated by {router-1-id} for {prefix-1} {algorithm-1} conflicts with Prefix-SID originated by {router-2-id} {algorithm-2} for {prefix-2}. Conflict resolved as {resolution}";
    dn-events-extensions:event-corrective-action-string "Change the Prefix-SID setting on either nodes.";
    dn-events-extensions:event-trigger-component-string "OSPF";
    dn-events-extensions:event-group "OSPF";
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
    leaf sid-value {
      type uint32;
      description
        "Absolute value of the Prefix-SID";
    }
    leaf router-1-id {
      type string;
      description
        "The router-id of remote node from which SID was received, if not known, display system-ID";
    }
    leaf prefix-1 {
      type string;
      description
        "The prefix for which node-1 advertise the Prefix-SID";
    }
    leaf algorithm-1 {
      description
        "The prefix-SID algorithm, SPF or S-SFP";
      type string;
    }
    leaf router-2-id {
      type string;
      description
        "The router-id of remote node from which SID was received, if not known, display system-ID";
    }
    leaf prefix-2 {
      type string;
      description
        "The prefix for which node-1 advertise the Prefix-SID";
    }
    leaf algorithm-2 {
      description
        "The prefix-SID algorithm, SPF or S-SFP";
      type string;
    }
    leaf resolution {
      type string;
      description
        "how conflict is resolved, i.e which prefix is assigned to sid";
    }
  }

  notification OSPF_SR_PREFIX_CONFLICT {
    description
      "Different Prefix-SIDs were received for the same Forwarding Equivalence Classes (FEC)s.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "OSPF instance {instance} Area {area-id} Prefix {ipv4-prefix} originated by {router-1-id} with Prefix-SID {sid-value-1} conflicts with Prefix-SID {sid-value-2} originated by {router-2-id}. Conflict resolved as {resolution}";
    dn-events-extensions:event-corrective-action-string "Change the Prefix-SID setting on either nodes.";
    dn-events-extensions:event-trigger-component-string "OSPF";
    dn-events-extensions:event-group "OSPF";
    leaf instance {
      type string;
      description
        "OSPF instance name";
    }
    leaf area-id {
      type string;
      description
        "area id";
    }
    leaf ipv4-prefix {
      type string;
      description
        "The prefix received from multiple nodes";
    }
    leaf router-1-id {
      type string;
      description
        "The router-id of remote node from which SID was received, if not known, display system-ID";
    }
    leaf sid-value-1 {
      type uint32;
      description
        "Absolute value of the Prefix-SID";
    }
    leaf sid-value-2 {
      type uint32;
      description
        "Absolute value of the Prefix-SID";
    }
    leaf router-2-id {
      type string;
      description
        "The router-id of remote node from which SID was received, if not known, display system-ID";
    }
    leaf resolution {
      type string;
      description
        "how conflict is resolved, i.e which prefix-sid is assigned to prefix";
    }
  }

  notification SR_SRGB_CONFIG_USER {
    description
      "The user listed changed the SRGB configuration.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "User {user-name} has configured the {config-level} Segement-Routing Global block. New block base: {base-sid}, range: {range}. Label Block reservation will take place at the next system restart";
    dn-events-extensions:event-corrective-action-string "Perform a system restart to apply the configuration changes.";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
    dn-events-extensions:event-group "Segment-Routing";
    leaf user-name {
      type string;
      description
        "User name";
    }
    leaf config-level {
      type string;
      description
        "Configuration level on which SRGB was changed, routing-options, ISIS or OSPF";
    }
    leaf base-sid {
      type uint32;
      description
        "Absolute value of the SRGB lower bound SID";
    }
    leaf range {
      type uint32;
      description
        "Range of the SRGB";
    }
  }

  notification SR_SRLB_CONFIG_USER {
    description
      "The user listed changed the SRLB configuration.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "User {user-name} has configured the {config-level} Segement-Routing Local block. New block base: {base-sid}, range: {range}. Label Block reservation will take place at the next system restart";
    dn-events-extensions:event-corrective-action-string "Perform a system restart to apply the configuration changes.";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
    dn-events-extensions:event-group "Segment-Routing";
    leaf user-name {
      type string;
      description
        "User name";
    }
    leaf config-level {
      type string;
      description
        "Configuration level on which SRLB was changed, routing-options, ISIS or OSPF";
    }
    leaf base-sid {
      type uint32;
      description
        "Absolute value of the SRLB lower bound SID";
    }
    leaf range {
      type uint32;
      description
        "Range of the SRLB";
    }
  }

  notification SR_POLICY_UP {
    description
      "The Segment-Routing policy moved to an 'up' state and can be used to forward traffic.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Segment-routing policy {policy-name} from {source-address} to {destination-address} with color {color}, switched to an UP state";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
    dn-events-extensions:event-group "Segment-Routing";
    dn-events-extensions:event-snmp-trap-name "dnSrPolicyUp";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.14.0.1";
    dn-events-extensions:event-snmp-trap-vars "dnSrPolicyName.0 {policy-name}; dnSrPolicySrcAddress.0 {source-address}; dnSrPolicyDestAddress.0 {destination-address}; dnSrPolicyColor.0 {color}";
    leaf policy-name {
      type string;
      description
        "Policy name";
    }
    leaf source-address {
      type string;
      description
        "Policy source IPv4/6 address";
    }
    leaf destination-address {
      type string;
      description
        "Policy destination IPv4 address";
    }
    leaf color {
      description
        "Policy color";
      type string;
    }
  }

  notification SR_POLICY_DOWN {
    description
      "The Segment-Routing policy moved to either 'down' or 'admin-down' state and cannot be used to forward traffic.";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "Segment-routing policy {policy-name} from {source-address} to {destination-address} with color {color}, switched to an {state} state";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
    dn-events-extensions:event-group "Segment-Routing";
    dn-events-extensions:event-snmp-trap-name "dnSrPolicyDown";
    dn-events-extensions:event-snmp-trap-oid "1.3.6.1.4.1.49739.2.14.0.2";
    dn-events-extensions:event-snmp-trap-vars "dnSrPolicyName.0 {policy-name}; dnSrPolicySrcAddress.0 {source-address}; dnSrPolicyDestAddress.0 {destination-address}; dnSrPolicyColor.0 {color}; dnSrPolicyState.0 {state}";
    leaf policy-name {
      type string;
      description
        "Policy name";
    }
    leaf source-address {
      type string;
      description
        "Policy source IPv4 address";
    }
    leaf destination-address {
      type string;
      description
        "Policy destination IPv4 address";
    }
    leaf color {
      description
        "Policy color";
      type string;
    }
    leaf state {
      description
        "Policy new state, either down or admin-down";
      type enumeration {
        enum down {
          value 0;
        }
        enum admin-down {
          value 1;
        }
        enum down-cleanup {
          value 2;
        }
      }
    }
  }

  notification SR_POLICY_FAILED_COMPUTATION {
    description
      "All path options were found invalid for the Segment-Routing policy";
    dn-events-extensions:event-severity-level "Warning";
    dn-events-extensions:event-message-string "All path options were found invalid for the segment-routing policy {policy-name} from {source-address} to {destination-address} with color {color}";
    dn-events-extensions:event-corrective-action-string "Verify network connectivity and if used SIDs are valid";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
    dn-events-extensions:event-group "Segment-Routing";
    leaf policy-name {
      type string;
      description
        "Policy name";
    }
    leaf source-address {
      type string;
      description
        "Policy source IPv4 address";
    }
    leaf destination-address {
      type string;
      description
        "Policy destination IPv4 address";
    }
    leaf color {
      description
        "Policy color";
      type string;
    }
  }

  notification SR_POLICY_PATH_REOPTIMIZED {
    description
      "The Segment-Routing policy improved path in used and moved to a new path.";
    dn-events-extensions:event-severity-level "Info";
    dn-events-extensions:event-message-string "Segment-routing policy {policy-name} from {source-address} to {destination-address} with color {color}, changed active path from path {old-path-name} with priority {old-priority} to path {new-path-name} with priority {new-priority} due to {reoptimization-type} reoptimization.";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
    dn-events-extensions:event-group "Segment-Routing";
    leaf policy-name {
      type string;
      description
        "Policy name";
    }
    leaf source-address {
      type string;
      description
        "Policy source IPv4 address";
    }
    leaf destination-address {
      type string;
      description
        "Policy destination IPv4 address";
    }
    leaf color {
      description
        "Policy color";
      type string;
    }
    leaf old-path-name {
      description
        "The name of the path policy was previously using";
      type string;
    }
    leaf old-priority {
      description
        "Policy previous path option priority";
      type uint16;
    }
    leaf new-path-name {
      description
        "The name of the path policy has moved to";
      type string;
    }
    leaf new-priority {
      description
        "Policy new path option priority";
      type uint16;
    }
    leaf reoptimization-type {
      description
        "type of reoptimization trigger. could be one of the following: 'periodic', 'user-request', 'user-config'";
      type string;
    }
  }

  notification SR_POLICY_PATH_CHANGED {
    description
      "The Segment-Routing policy improved path in used and moved to a new path.";
    dn-events-extensions:event-severity-level "Notice";
    dn-events-extensions:event-message-string "Segment-routing policy {policy-name} from {source-address} to {destination-address} with color {color}, changed active path from path {old-path-name} with priority {old-priority} to path {new-path-name} with priority {new-priority} due to {reason}";
    dn-events-extensions:event-corrective-action-string "This is informational, no corrective action required.";
    dn-events-extensions:event-trigger-component-string "Segment-Routing";
    dn-events-extensions:event-group "Segment-Routing";
    leaf policy-name {
      type string;
      description
        "Policy name";
    }
    leaf source-address {
      type string;
      description
        "Policy source IPv4 address";
    }
    leaf destination-address {
      type string;
      description
        "Policy destination IPv4 address";
    }
    leaf color {
      description
        "Policy color";
      type string;
    }
    leaf old-path-name {
      description
        "The name of the path policy was previously using";
      type string;
    }
    leaf old-priority {
      description
        "Policy previous path option priority";
      type uint16;
    }
    leaf new-path-name {
      description
        "The name of the path policy has moved to";
      type string;
    }
    leaf new-priority {
      description
        "Policy new path option priority";
      type uint16;
    }
    leaf reason {
      description
        "reason for the path change. could be one of the following: 'path invalid'";
      type string;
    }
  }

  // ODN SR auto-policies

  notification SR_MAXIMUM_AUTO_POLICIES_LIMIT_REACHED {
    description
      "The maximum number of concurrent SR auto-policies has been reached.";
