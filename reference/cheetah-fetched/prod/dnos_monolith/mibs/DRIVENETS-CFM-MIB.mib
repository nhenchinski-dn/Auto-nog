    ::= { dnCfmProactiveSlmSessionEntry 3 }

dnCfmProactiveSlmSessionId OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Synthetic Loss Measurement session identifier."
    ::= { dnCfmProactiveSlmSessionEntry 4 }

dnCfmProactiveSlmSourceMdName OBJECT-TYPE
    SYNTAX      DnCfmNameString
