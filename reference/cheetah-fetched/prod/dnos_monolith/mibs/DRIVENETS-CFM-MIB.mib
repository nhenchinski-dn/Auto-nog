    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Target MAC address. When dnCfmProactiveSlmTargetType is mepId(2),
         this object is set to 00:00:00:00:00:00."
    ::= { dnCfmProactiveSlmSessionEntry 8 }

dnCfmProactiveSlmTargetMepId OBJECT-TYPE
    SYNTAX      DnCfmMepIdOrNone
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Target MEP ID. If TargetType is mepId(2), MUST be 1..8191.
         If TargetType is macAddress(1), this is 0 unless the agent
         can unambiguously resolve the remote MEP-ID."
    ::= { dnCfmProactiveSlmSessionEntry 9 }

dnCfmProactiveSlmSourceInterface OBJECT-TYPE
    SYNTAX      DisplayString (SIZE (1..255))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Source interface name."
    ::= { dnCfmProactiveSlmSessionEntry 10 }

dnCfmProactiveSlmSourceMacAddress OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Source MAC address."
    ::= { dnCfmProactiveSlmSessionEntry 11 }

dnCfmProactiveSlmComputationInterval OBJECT-TYPE
    SYNTAX      DnCfmSeconds
    UNITS       "seconds"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Computation interval."
    ::= { dnCfmProactiveSlmSessionEntry 12 }

dnCfmProactiveSlmCount OBJECT-TYPE
    SYNTAX      DnCfmSyntheticLossPduCount (1..65535)
    UNITS       "PDUs"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Number of SLM probes per computation interval."
    ::= { dnCfmProactiveSlmSessionEntry 13 }

dnCfmProactiveSlmInterval OBJECT-TYPE
    SYNTAX      DnCfmSeconds (1..65535)
    UNITS       "seconds"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Inter-probe interval."
    ::= { dnCfmProactiveSlmSessionEntry 14 }

dnCfmProactiveSlmTimeout OBJECT-TYPE
    SYNTAX      DnCfmSeconds (1..65535)
    UNITS       "seconds"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Timeout awaiting SLR replies."
    ::= { dnCfmProactiveSlmSessionEntry 15 }

dnCfmProactiveSlmPcp OBJECT-TYPE
    SYNTAX      DnCfmPcp
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "802.1p priority for probes."
    ::= { dnCfmProactiveSlmSessionEntry 16 }

-- =====================================================================
-- PROACTIVE ETH-SLM RESULT TABLE (report-only)
-- =====================================================================

dnCfmProactiveSlmResultTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF DnCfmProactiveSlmResultEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Results for proactive ETH-SLM test sessions (report-only)."
    ::= { dnCfmObjects 18 }

dnCfmProactiveSlmResultEntry OBJECT-TYPE
    SYNTAX      DnCfmProactiveSlmResultEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "A set of ETH-SLM statistics for one computation interval (report-only)."
    INDEX { dnCfmProactiveSlmResultMdIndex, dnCfmProactiveSlmResultMaIndex, dnCfmProactiveSlmResultMepId,
            dnCfmProactiveSlmResultSessionId, dnCfmProactiveSlmResultIndex }
    ::= { dnCfmProactiveSlmResultTable 1 }

DnCfmProactiveSlmResultEntry ::= SEQUENCE {
    dnCfmProactiveSlmResultMdIndex                  DnCfmMdIndex,
    dnCfmProactiveSlmResultMaIndex                  DnCfmMaIndex,
    dnCfmProactiveSlmResultMepId                    DnCfmMepId,
    dnCfmProactiveSlmResultSessionId                Unsigned32,
    dnCfmProactiveSlmResultIndex                    Unsigned32,
    dnCfmProactiveSlmStartTime                      DateAndTime,
    dnCfmProactiveSlmEndTime                        DateAndTime,
    dnCfmProactiveSlmMeasurementValidity            INTEGER,
    dnCfmProactiveSlmSyntheticLossPdusSent          DnCfmSyntheticLossPduCount,
    dnCfmProactiveSlmSyntheticLossPdusReceived      DnCfmSyntheticLossPduCount,
    dnCfmProactiveSlmSentPdusReceivedByRemoteMep    DnCfmSyntheticLossPduCount,
    dnCfmProactiveSlmMissingSlr                     DnCfmSyntheticLossPduCount,
    dnCfmProactiveSlmLocalTxfclValue                Unsigned32,
    dnCfmProactiveSlmLocalRxfclValue                Unsigned32,
    dnCfmProactiveSlmLastSlrTxfcfTc                 Unsigned32,
    dnCfmProactiveSlmLastSlrTxfcbTc                 Unsigned32,
    dnCfmProactiveSlmFrameLossNearEndCount          Unsigned32,
    dnCfmProactiveSlmFrameLossNearEndPercent        DnPercentHundredths,
    dnCfmProactiveSlmFrameLossFarEndCount           Unsigned32,
    dnCfmProactiveSlmFrameLossFarEndPercent         DnPercentHundredths
}

dnCfmProactiveSlmResultMdIndex OBJECT-TYPE
    SYNTAX      DnCfmMdIndex
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Maintenance Domain index."
    ::= { dnCfmProactiveSlmResultEntry 1 }

dnCfmProactiveSlmResultMaIndex OBJECT-TYPE
    SYNTAX      DnCfmMaIndex
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Maintenance Association index."
    ::= { dnCfmProactiveSlmResultEntry 2 }

dnCfmProactiveSlmResultMepId OBJECT-TYPE
    SYNTAX      DnCfmMepId
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "MEP identifier."
    ::= { dnCfmProactiveSlmResultEntry 3 }

dnCfmProactiveSlmResultSessionId OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Synthetic Loss Measurement session identifier."
    ::= { dnCfmProactiveSlmResultEntry 4 }

dnCfmProactiveSlmResultIndex OBJECT-TYPE
    SYNTAX      Unsigned32 (0..9)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Measurement result index for this computation interval.
         The index increments for each completed computation interval
         and wraps at the fixed maximum of the last 10 results.
         Older results are aged out when the maximum limit is reached."
    ::= { dnCfmProactiveSlmResultEntry 5 }

dnCfmProactiveSlmStartTime OBJECT-TYPE
    SYNTAX      DateAndTime
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION 
        "Timestamp encoded per DateAndTime (RFC 2579) for the start of a computation interval. 
         The agent SHOULD use UTC ('Z'); a timezone offset MAY be supplied."
    ::= { dnCfmProactiveSlmResultEntry 6 }

dnCfmProactiveSlmEndTime OBJECT-TYPE
    SYNTAX      DateAndTime
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION 
        "Timestamp encoded per DateAndTime (RFC 2579) for the end of a computation interval. 
         The agent SHOULD use UTC ('Z'); a timezone offset MAY be supplied."
    ::= { dnCfmProactiveSlmResultEntry 7 }

dnCfmProactiveSlmMeasurementValidity OBJECT-TYPE
    SYNTAX      INTEGER { valid(1), invalid(2), incomplete(3) }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Validity of the measurement set."
    ::= { dnCfmProactiveSlmResultEntry 8 }

dnCfmProactiveSlmSyntheticLossPdusSent OBJECT-TYPE
    SYNTAX      DnCfmSyntheticLossPduCount
    UNITS       "PDUs"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Number of SLM PDUs transmitted."
    ::= { dnCfmProactiveSlmResultEntry 9 }

dnCfmProactiveSlmSyntheticLossPdusReceived OBJECT-TYPE
    SYNTAX      DnCfmSyntheticLossPduCount
    UNITS       "PDUs"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Number of valid SLR PDUs received."
    ::= { dnCfmProactiveSlmResultEntry 10 }

dnCfmProactiveSlmSentPdusReceivedByRemoteMep OBJECT-TYPE
    SYNTAX      DnCfmSyntheticLossPduCount
    UNITS       "PDUs"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Number of SLM PDUs received by remote MEP."
    ::= { dnCfmProactiveSlmResultEntry 11 }

dnCfmProactiveSlmMissingSlr OBJECT-TYPE
    SYNTAX      DnCfmSyntheticLossPduCount
    UNITS       "PDUs"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Number of SLR PDUs that were not received from the remote MEP.
         Calculated as [SLM PDUs sent] - [valid SLR PDUs received] for this 
         computation interval, or 0 if no SLM were sent."
    ::= { dnCfmProactiveSlmResultEntry 12 }

dnCfmProactiveSlmLocalTxfclValue OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "frames"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Local TXFCl value."
    ::= { dnCfmProactiveSlmResultEntry 13 }

dnCfmProactiveSlmLocalRxfclValue OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "frames"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Local RXFCl value."
    ::= { dnCfmProactiveSlmResultEntry 14 }

dnCfmProactiveSlmLastSlrTxfcfTc OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "frames"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Last received SLR TXFCf(tc) value."
    ::= { dnCfmProactiveSlmResultEntry 15 }

dnCfmProactiveSlmLastSlrTxfcbTc OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "frames"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Last received SLR TXFCb(tc) value."
    ::= { dnCfmProactiveSlmResultEntry 16 }

dnCfmProactiveSlmFrameLossNearEndCount OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "frames"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Near-end frame loss count."
    ::= { dnCfmProactiveSlmResultEntry 17 }

dnCfmProactiveSlmFrameLossNearEndPercent OBJECT-TYPE
    SYNTAX      DnPercentHundredths
    UNITS       "percent"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Near-end frame loss percentage.
         The value reported is the conceptual percent multiplied by 100 and rounded to the 
         nearest integer (i.e., hundredths of a percent; e.g., 95.90% -> 9590)."
    ::= { dnCfmProactiveSlmResultEntry 18 }

dnCfmProactiveSlmFrameLossFarEndCount OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "frames"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Far-end frame loss count."
    ::= { dnCfmProactiveSlmResultEntry 19 }

dnCfmProactiveSlmFrameLossFarEndPercent OBJECT-TYPE
    SYNTAX      DnPercentHundredths
    UNITS       "percent"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Far-end frame loss percentage.
         The value reported is the conceptual percent multiplied by 100 and rounded to the 
         nearest integer (i.e., hundredths of a percent; e.g., 95.90% -> 9590)."
    ::= { dnCfmProactiveSlmResultEntry 20 }

-- =====================================================================
-- NOTIFICATIONS
-- =====================================================================

dnCfmFaultAlarm NOTIFICATION-TYPE
    OBJECTS {
        dnCfmTrapMdLevel,
        dnCfmTrapMdName,
        dnCfmTrapMaName,
        dnCfmTrapHighestDefectPri
    }
    STATUS      current
    DESCRIPTION
        "Sent when any MEP enters a persistent defect state in the MA."
    ::= { dnCfmNotifications 1 }

dnCfmFaultAlarmCleared NOTIFICATION-TYPE
    OBJECTS {
        dnCfmTrapMdLevel,
        dnCfmTrapMdName,
        dnCfmTrapMaName,
        dnCfmTrapHighestDefectPri
    }
    STATUS      current
    DESCRIPTION
        "Sent when all defect conditions have cleared for the MA
         (i.e., all MEPs in the MA are non-defective). For this
         notification dnCfmTrapHighestDefectPri MUST be none(0)."
    ::= { dnCfmNotifications 2 }

dnCfmProactiveTestFailure NOTIFICATION-TYPE
    OBJECTS {
        dnCfmTrapMdLevel,
        dnCfmTrapMdName,
        dnCfmTrapMaName,
        dnCfmTrapMepId,
        dnCfmTrapSessionType,
        dnCfmTrapSessionId,
        dnCfmTrapThresholdType,
        dnCfmTrapThresholdValue,
        dnCfmTrapMeasuredValue
    }
    STATUS      current
    DESCRIPTION
        "Sent when a CFM proactive performance monitoring test detects a
         threshold violation. The notification includes:
           - MD/MA/level context (domain, association, level)
           - MEP identifier (source MEP that detected the violation)
           - Session details (type: ETH-DM or ETH-SLM, and session ID)
           - Threshold details (which metric, configured threshold, measured value)"
    ::= { dnCfmNotifications 3 }

-- =====================================================================
-- CONFORMANCE (groups & compliance)
-- =====================================================================

dnCfmCompliances OBJECT IDENTIFIER ::= { dnCfmConformance 1 }
dnCfmGroups      OBJECT IDENTIFIER ::= { dnCfmConformance 2 }

dnCfmCompliance MODULE-COMPLIANCE
    STATUS      current
    DESCRIPTION "Compliance statement for DriveNets CFM implementation."
    MODULE
        MANDATORY-GROUPS {
            dnCfmNotificationsGroup,
            dnCfmProactiveDmSessionGroup,
            dnCfmProactiveDmResultsGroup,
            dnCfmProactiveSlmSessionGroup,
            dnCfmProactiveSlmResultsGroup,
            dnCfmOnDemandDmInfoGroup,
            dnCfmOnDemandDmResultsGroup,
            dnCfmOnDemandSlmInfoGroup,
            dnCfmOnDemandSlmResultsGroup
        }
    ::= { dnCfmCompliances 1 }

dnCfmNotificationsGroup NOTIFICATION-GROUP
    NOTIFICATIONS {
        dnCfmFaultAlarm,
        dnCfmFaultAlarmCleared,
        dnCfmProactiveTestFailure
    }
    STATUS      current
    DESCRIPTION "CFM notifications supported by the agent."
    ::= { dnCfmGroups 1 }

dnCfmProactiveDmSessionGroup OBJECT-GROUP
    OBJECTS {
        dnCfmProactiveDmSourceMdName,
        dnCfmProactiveDmSourceMaName,
        dnCfmProactiveDmTargetType,
        dnCfmProactiveDmTargetMacAddress,
        dnCfmProactiveDmTargetMepId,
        dnCfmProactiveDmSourceInterface,
        dnCfmProactiveDmSourceMacAddress,
        dnCfmProactiveDmComputationInterval,
        dnCfmProactiveDmCount,
        dnCfmProactiveDmInterval,
        dnCfmProactiveDmTimeout,
        dnCfmProactiveDmPcp
    }
    STATUS      current
    DESCRIPTION "Objects for proactive ETH-DM test session."
    ::= { dnCfmGroups 6 }

dnCfmProactiveDmResultsGroup OBJECT-GROUP
    OBJECTS {
        dnCfmProactiveDmStartTime,
        dnCfmProactiveDmEndTime,
        dnCfmProactiveDmMeasurementValidity,
        dnCfmProactiveDmDmmTransmitted,
        dnCfmProactiveDmDmrReceived,
        dnCfmProactiveDmSuccessRatePercent,
        dnCfmProactiveDmFrameDelayTwoWayMin,
        dnCfmProactiveDmFrameDelayTwoWayAvg,
        dnCfmProactiveDmFrameDelayTwoWayMax,
        dnCfmProactiveDmIfdvTwoWayAvg,
        dnCfmProactiveDmIfdvTwoWayMax
    }
    STATUS      current
    DESCRIPTION "Objects for proactive ETH-DM test results."
    ::= { dnCfmGroups 7 }

dnCfmProactiveSlmSessionGroup OBJECT-GROUP
    OBJECTS {
        dnCfmProactiveSlmSourceMdName,
        dnCfmProactiveSlmSourceMaName,
        dnCfmProactiveSlmTargetType,
        dnCfmProactiveSlmTargetMacAddress,
        dnCfmProactiveSlmTargetMepId,
        dnCfmProactiveSlmSourceInterface,
        dnCfmProactiveSlmSourceMacAddress,
        dnCfmProactiveSlmComputationInterval,
        dnCfmProactiveSlmCount,
        dnCfmProactiveSlmInterval,
        dnCfmProactiveSlmTimeout,
        dnCfmProactiveSlmPcp
    }
    STATUS      current
    DESCRIPTION "Objects for proactive ETH-SLM test session."
    ::= { dnCfmGroups 8 }

dnCfmProactiveSlmResultsGroup OBJECT-GROUP
    OBJECTS {
        dnCfmProactiveSlmStartTime,
        dnCfmProactiveSlmEndTime,
        dnCfmProactiveSlmMeasurementValidity,
        dnCfmProactiveSlmSyntheticLossPdusSent,
        dnCfmProactiveSlmSyntheticLossPdusReceived,
        dnCfmProactiveSlmSentPdusReceivedByRemoteMep,
        dnCfmProactiveSlmMissingSlr,
        dnCfmProactiveSlmLocalTxfclValue,
        dnCfmProactiveSlmLocalRxfclValue,
        dnCfmProactiveSlmLastSlrTxfcfTc,
        dnCfmProactiveSlmLastSlrTxfcbTc,
        dnCfmProactiveSlmFrameLossNearEndCount,
        dnCfmProactiveSlmFrameLossNearEndPercent,
        dnCfmProactiveSlmFrameLossFarEndCount,
        dnCfmProactiveSlmFrameLossFarEndPercent
    }
    STATUS      current
    DESCRIPTION "Objects for proactive ETH-SLM test results."
    ::= { dnCfmGroups 9 }

dnCfmOnDemandDmInfoGroup OBJECT-GROUP
    OBJECTS {
        dnCfmOnDemandDmSourceMdName,
        dnCfmOnDemandDmSourceMaName,
        dnCfmOnDemandDmTargetType,
        dnCfmOnDemandDmTargetMacAddress,
        dnCfmOnDemandDmTargetMepId,
        dnCfmOnDemandDmSourceInterface,
        dnCfmOnDemandDmSourceMacAddress,
        dnCfmOnDemandDmStartTime,
        dnCfmOnDemandDmEndTime,
        dnCfmOnDemandDmCount,
        dnCfmOnDemandDmInterval,
        dnCfmOnDemandDmTimeout,
        dnCfmOnDemandDmPcp
    }
    STATUS      current
    DESCRIPTION "Objects describing on-demand ETH-DM tests (report-only)."
    ::= { dnCfmGroups 2 }

dnCfmOnDemandDmResultsGroup OBJECT-GROUP
    OBJECTS {
        dnCfmOnDemandDmMeasurementValidity,
        dnCfmOnDemandDmDmmTransmitted,
        dnCfmOnDemandDmDmrReceived,
        dnCfmOnDemandDmSuccessRatePercent,
        dnCfmOnDemandDmFrameDelayTwoWayMin,
        dnCfmOnDemandDmFrameDelayTwoWayAvg,
        dnCfmOnDemandDmFrameDelayTwoWayMax,
        dnCfmOnDemandDmIfdvTwoWayAvg,
        dnCfmOnDemandDmIfdvTwoWayMax
    }
    STATUS      current
    DESCRIPTION "Objects reporting on-demand ETH-DM results."
    ::= { dnCfmGroups 3 }

dnCfmOnDemandSlmInfoGroup OBJECT-GROUP
    OBJECTS {
        dnCfmOnDemandSlmSourceMdName,
        dnCfmOnDemandSlmSourceMaName,
        dnCfmOnDemandSlmTargetType,
        dnCfmOnDemandSlmTargetMacAddress,
        dnCfmOnDemandSlmTargetMepId,
        dnCfmOnDemandSlmSourceInterface,
        dnCfmOnDemandSlmSourceMacAddress,
        dnCfmOnDemandSlmStartTime,
        dnCfmOnDemandSlmEndTime,
        dnCfmOnDemandSlmCount,
        dnCfmOnDemandSlmInterval,
        dnCfmOnDemandSlmTimeout,
        dnCfmOnDemandSlmPcp
    }
    STATUS      current
    DESCRIPTION "Objects describing on-demand ETH-SLM tests (report-only)."
    ::= { dnCfmGroups 4 }

dnCfmOnDemandSlmResultsGroup OBJECT-GROUP
    OBJECTS {
        dnCfmOnDemandSlmMeasurementValidity,
        dnCfmOnDemandSlmSyntheticLossPdusSent,
        dnCfmOnDemandSlmSyntheticLossPdusReceived,
        dnCfmOnDemandSlmSentPdusReceivedByRemoteMep,
        dnCfmOnDemandSlmMissingSlr,
        dnCfmOnDemandSlmLocalTxfclValue,
        dnCfmOnDemandSlmLocalRxfclValue,
        dnCfmOnDemandSlmLastSlrTxfcfTc,
        dnCfmOnDemandSlmLastSlrTxfcbTc,
        dnCfmOnDemandSlmFrameLossNearEndCount,
        dnCfmOnDemandSlmFrameLossNearEndPercent,
        dnCfmOnDemandSlmFrameLossFarEndCount,
        dnCfmOnDemandSlmFrameLossFarEndPercent
    }
    STATUS      current
    DESCRIPTION "Objects reporting on-demand ETH-SLM results."
    ::= { dnCfmGroups 5 }

END
